{"name": "kirbyam", "game": "Kirby & The Amazing Mirror", "version": "0.2.0", "hidden": false, "groups": [{"name": "Game Options", "options": [{"name": "progression_balancing", "display_name": "Progression Balancing", "description": "A system that can move progression earlier, to try and prevent the player from getting stuck and bored early.\n\nA lower setting means more getting stuck. A higher setting means less getting stuck.", "randomizable": true, "visibility": 15, "type": "NamedRange", "default": 50, "min": 0, "max": 99, "presets": {"disabled": 0, "normal": 50, "extreme": 99}}, {"name": "accessibility", "display_name": "Accessibility", "description": "Set rules for reachability of your items/locations.\n\n**Full:** ensure everything can be reached and acquired.\n\n**Minimal:** ensure what is needed to reach your goal can be acquired.", "randomizable": true, "visibility": 15, "type": "Choice", "default": 0, "choices": [{"name": "full", "display_name": "Full", "value": 0}, {"name": "minimal", "display_name": "Minimal", "value": 2}]}, {"name": "goal", "display_name": "Goal", "description": "Determines what your goal is to consider the game beaten.\n\n- Dark Mind: Defeat Dark Mind and beat the game.\n- Defeat Any Area Boss: Defeat any one eligible area boss.\n- Defeat Random Hidden Area Boss: Defeat one hidden, seed-selected area boss.", "randomizable": true, "visibility": 15, "type": "Choice", "default": 0, "choices": [{"name": "dark_mind", "display_name": "Dark Mind", "value": 0}, {"name": "defeat_any_area_boss", "display_name": "Defeat Any Area Boss", "value": 1}, {"name": "defeat_random_hidden_area_boss", "display_name": "Defeat Random Hidden Area Boss", "value": 2}]}, {"name": "shards", "display_name": "Randomize Shards", "description": "Controls where Mirror Shards can appear.\n\n- Vanilla: Each area's boss defeat location contains its matching shard.\n- Completely Random: Shards can appear from any location. Default.", "randomizable": true, "visibility": 15, "type": "Choice", "default": 2, "choices": [{"name": "vanilla", "display_name": "Vanilla", "value": 0}, {"name": "completely_random", "display_name": "Completely Random", "value": 2}]}], "collapsed": false}, {"name": "Make the game easier", "options": [{"name": "start_with_all_maps", "display_name": "Start With All Maps", "description": "Start the game with all nine area maps already acquired.\n  Off by default. Intended for new players who find exploring unmapped areas daunting.\n  All map items are removed from the item pool and replaced with filler.", "randomizable": true, "visibility": 15, "type": "Toggle", "default": false}], "collapsed": false}, {"name": "Make the game last longer", "options": [{"name": "room_sanity", "display_name": "Room Sanity", "description": "Adds room-visit checks (for example, `Room X-*`). Off by default because it adds 263 locations.", "randomizable": true, "visibility": 15, "type": "Toggle", "default": false}], "collapsed": false}, {"name": "Make the game harder", "options": [{"name": "no_extra_lives", "display_name": "No Extra Lives", "description": "Start with zero lives and clamp all extra-life gains to zero during gameplay.\n  Starts after the tutorial. Off by default.\n\n  Yes, you can combine this with One-Hit Mode for an extra challenge.", "randomizable": true, "visibility": 15, "type": "Toggle", "default": false}, {"name": "enable_traps", "display_name": "Enable Traps", "description": "Allow negative trap items to appear in the randomized item pool.\nOff by default.\nWhen disabled, no KirbyAM traps are placed.", "randomizable": true, "visibility": 15, "type": "Toggle", "default": false}, {"name": "trap_fill_percentage", "display_name": "Trap Fill Percentage", "description": "Sets what percentage of eligible filler slots become traps when `Enable Traps` is on.\n\nEligible filler slots are the locations left after all progression/useful items are placed.\nTrap items are sampled with replacement, so duplicate traps are allowed when the pool is large enough.\n\n- 0: No filler slots become traps.\n- 25: One quarter of eligible filler slots become traps. Default.\n- 100: Every eligible filler slot becomes a trap.", "randomizable": true, "visibility": 15, "type": "Range", "default": 25, "min": 0, "max": 100}, {"name": "one_hit_mode", "display_name": "One-Hit Mode", "description": "Controls whether Kirby's maximum health is reduced to 1 HP at the start (one-hit mode).\n  Starts after the tutorial. Off by default.\n  Yes, you can combine this with No Extra Lives for an extra challenge.\n\n- Off: Kirby's maximum health is unmodified (native 6 HP base, plus 1 per\n    Vitality Counter found).\n- Exclude Vitality Counters: Kirby starts with a maximum of 1 HP. All four Vitality Counter items are\n    removed from the item pool and replaced with filler. Kirby's HP cap stays at 1 for the entire run.\n- Include Vitality Counters: Kirby starts with a maximum of 1 HP. Vitality Counter items remain in the\n    pool; each one received increases Kirby's HP cap by 1 (up to 5 with all four). This is known to\n    cause a visual artifact on the screen when a vitality counter is received, but it is functional.", "randomizable": true, "visibility": 15, "type": "Choice", "default": 0, "choices": [{"name": "off", "display_name": "Off", "value": 0}, {"name": "exclude_vitality_counters", "display_name": "Exclude Vitality Counters", "value": 1}, {"name": "include_vitality_counters", "display_name": "Include Vitality Counters", "value": 2}]}, {"name": "death_link", "display_name": "Death Link", "description": "When you die, everyone who enabled death link dies. Of course, the reverse is true too.", "randomizable": true, "visibility": 15, "type": "Toggle", "default": false}], "collapsed": false}, {"name": "Ability Randomization", "options": [{"name": "ability_randomization_mode", "display_name": "Ability Randomization Mode", "description": "Controls randomization of enemy-granted copy abilities.\nIf statue randomization is enabled, statues inherit this same mode.\n\n- Off: Enemy copy abilities stay at native defaults. Default.\n- Shuffled: Enemy types are remapped deterministically so all enemies of the\n    same type grant the same ability.\n- Completely Random: Eligible enemy ability grants are remapped independently\n    (deterministic per grant event).", "randomizable": true, "visibility": 15, "type": "Choice", "default": 0, "choices": [{"name": "off", "display_name": "Off", "value": 0}, {"name": "shuffled", "display_name": "Shuffled", "value": 1}, {"name": "completely_random", "display_name": "Completely Random", "value": 2}]}, {"name": "ability_randomization_boss_spawns", "display_name": "Ability Randomization: Boss Spawns", "description": "Include boss-spawned ability grants in randomization.\n  Only applies when Ability Randomization Mode is not Off.\n  On by Default, but ability_randomization_mode is Off by Default.", "randomizable": true, "visibility": 15, "type": "Toggle", "default": true}, {"name": "ability_randomization_minibosses", "display_name": "Ability Randomization: Minibosses", "description": "Include mini-boss ability grants in randomization.\n  Only applies when Ability Randomization Mode is not Off.\n  On by Default, but ability_randomization_mode is Off by Default.", "randomizable": true, "visibility": 15, "type": "Toggle", "default": true}, {"name": "ability_randomization_minny", "display_name": "Ability Randomization: Minny", "description": "Include Minny in copy-ability randomization.\n        Only applies when Ability Randomization Mode is not Off.\n        If ability statue randomization is enabled, statues also respect this toggle.\n        Off by Default.", "randomizable": true, "visibility": 15, "type": "Toggle", "default": false}, {"name": "ability_randomization_passive_enemies", "display_name": "Ability Randomization: Passive Enemies", "description": "When enabled, enemies that normally do not grant a copy ability can receive a\nrandomized ability.\n  Only applies when Ability Randomization Mode is not Off.\n  Enemy sources only. Ability statues are not affected by this toggle.\n\n  On by Default, but ability_randomization_mode is Off by Default.", "randomizable": true, "visibility": 15, "type": "Toggle", "default": true}, {"name": "ability_randomization_no_ability_weight", "display_name": "Ability Randomization: No Ability Weight", "description": "Sets the percentage chance that an included randomized enemy grant resolves to\nno ability instead of a copy ability.\n\n- 0: Included randomized enemies always grant a copy ability.\n- 55: 55% of included randomized enemies grant no ability, 45% grant a copy ability.\n        Default. This matches the in-game percentage when enemies that normally\n        grant no ability are included in the randomization pool.\n- 100: Included randomized enemies always grant no ability.\n\nThis only affects enemies already included by the ability randomization mode and\nthe boss/miniboss/passive-enemy toggles.\nAbility statues are not affected; randomized statues always grant an ability.\n\n    You can set a custom percentage by adding a custom number as the subkey,\n    then supply the \"percentage\" chance for generation to roll that value.\n  For example:\n    25: 50\nThe above says you want 25% of ability granting enemies to provide no ability\ninstead of a copy ability, and 75% to provide a copy ability. Further,\n    25: 10\n    50: 10\n    75: 10\n        The above says you want generation to have equal chances of creating\n        worlds where 25%, 50%, and 75% of ability granting enemies provide no\n        ability instead of a copy ability.", "randomizable": true, "visibility": 15, "type": "Range", "default": 55, "min": 0, "max": 100}, {"name": "ability_randomization_statues", "display_name": "Ability Randomization: Statues", "description": "Include ability statues (sometimes called ability trophies or ability stands)\nin copy-ability randomization.\n\nThis toggle only controls whether statues participate at all.\nOnly applies when Ability Randomization Mode is not Off.\nParticipating statues use the currently selected Ability Randomization Mode\n(Off, Shuffled, or Completely Random).\nRandomized statues always grant an ability and do not use\n`ability_randomization_no_ability_weight` or\n`ability_randomization_passive_enemies`.\nRandomized statues do respect `ability_randomization_minny`.\n\nOff by default.", "randomizable": true, "visibility": 15, "type": "Toggle", "default": false}], "collapsed": false}, {"name": "Cosmetics", "options": [{"name": "starting_kirby_color", "display_name": "Starting Kirby Color", "description": "Choose Kirby's default starting color palette.\n  Pink is the in-game default and requires no native color override.\nNon-Pink colors become visible after the first room transition or after an\nenemy hit refreshes Kirby's runtime color state.\n\nSupported color names (as listed on Kirby Wiki Spray Paint):\n  Pink, Yellow, Red, Green, Snow, Carbon, Ocean, Sapphire, Grape, Emerald, Orange, Chocolate, Cherry, Chalk\n\nSet to `random_color` to resolve to one supported color at generation.", "randomizable": true, "visibility": 15, "type": "Choice", "default": 0, "choices": [{"name": "random_color", "display_name": "Random Color", "value": 255}, {"name": "pink", "display_name": "Pink", "value": 0}, {"name": "yellow", "display_name": "Yellow", "value": 1}, {"name": "red", "display_name": "Red", "value": 2}, {"name": "green", "display_name": "Green", "value": 3}, {"name": "snow", "display_name": "Snow", "value": 4}, {"name": "carbon", "display_name": "Carbon", "value": 5}, {"name": "ocean", "display_name": "Ocean", "value": 6}, {"name": "sapphire", "display_name": "Sapphire", "value": 7}, {"name": "grape", "display_name": "Grape", "value": 8}, {"name": "emerald", "display_name": "Emerald", "value": 9}, {"name": "orange", "display_name": "Orange", "value": 10}, {"name": "chocolate", "display_name": "Chocolate", "value": 11}, {"name": "cherry", "display_name": "Cherry", "value": 12}, {"name": "chalk", "display_name": "Chalk", "value": 13}]}], "collapsed": false}, {"name": "Item & Location Options", "options": [{"name": "local_items", "display_name": "Local Items", "description": "Forces these items to be in their native world.", "randomizable": false, "visibility": 15, "type": "OptionSet", "default": [], "options": ["1 Up", "Small Food", "Energy Drink", "Hunk of Meat", "Cell Phone Battery", "Max Tomato", "Invincibility Candy", "Health Down Trap", "Life Down Trap", "Bomb Trap", "Battery Drain Trap", "Life Wipeout Trap", "Mustard Mountain - Mirror Shard", "Moonlight Mansion - Mirror Shard", "Candy Constellation - Mirror Shard", "Olive Ocean - Mirror Shard", "Peppermint Palace - Mirror Shard", "Cabbage Cavern - Mirror Shard", "Carrot Castle - Mirror Shard", "Radish Ruins - Mirror Shard", "Rainbow Route - Map", "Mustard Mountain - Map", "Moonlight Mansion - Map", "Candy Constellation - Map", "Olive Ocean - Map", "Peppermint Palace - Map", "Cabbage Cavern - Map", "Carrot Castle - Map", "Radish Ruins - Map", "Carrot Castle - Vitality Counter", "Olive Ocean - Vitality Counter", "Radish Ruins - Vitality Counter", "Candy Constellation - Vitality Counter", "Sound Player", "Life", "Filler", "Health", "Consumable", "Battery", "Invincibility", "Trap", "Unique", "Shards", "Maps", "Useful", "Vitality", "SoundPlayer", "Everything"]}, {"name": "non_local_items", "display_name": "Non-local Items", "description": "Forces these items to be outside their native world.", "randomizable": false, "visibility": 15, "type": "OptionSet", "default": [], "options": ["1 Up", "Small Food", "Energy Drink", "Hunk of Meat", "Cell Phone Battery", "Max Tomato", "Invincibility Candy", "Health Down Trap", "Life Down Trap", "Bomb Trap", "Battery Drain Trap", "Life Wipeout Trap", "Mustard Mountain - Mirror Shard", "Moonlight Mansion - Mirror Shard", "Candy Constellation - Mirror Shard", "Olive Ocean - Mirror Shard",
{"name": "wargroove", "game": "Wargroove", "version": "1.0.0", "hidden": false, "groups": [{"name": "Game Options", "options": [{"name": "progression_balancing", "display_name": "Progression Balancing", "description": "A system that can move progression earlier, to try and prevent the player from getting stuck and bored early.\n\nA lower setting means more getting stuck. A higher setting means less getting stuck.", "randomizable": true, "visibility": 15, "type": "NamedRange", "default": 50, "min": 0, "max": 99, "presets": {"disabled": 0, "normal": 50, "extreme": 99}}, {"name": "accessibility", "display_name": "Accessibility", "description": "Set rules for reachability of your items/locations.\n\n**Full:** ensure everything can be reached and acquired.\n\n**Minimal:** ensure what is needed to reach your goal can be acquired.", "randomizable": true, "visibility": 15, "type": "Choice", "default": 0, "choices": [{"name": "full", "display_name": "Full", "value": 0}, {"name": "minimal", "display_name": "Minimal", "value": 2}]}, {"name": "death_link", "display_name": "Death Link", "description": "When you die, everyone who enabled death link dies. Of course, the reverse is true too.", "randomizable": true, "visibility": 15, "type": "Toggle", "default": false}], "collapsed": false}, {"name": "General Options", "options": [{"name": "income_boost", "display_name": "Income Boost", "description": "How much extra income the player gets per turn per boost received.", "randomizable": true, "visibility": 15, "type": "Range", "default": 25, "min": 0, "max": 100}, {"name": "commander_defense_boost", "display_name": "Commander Defense Boost", "description": "How much extra defense the player's commander gets per boost received.", "randomizable": true, "visibility": 15, "type": "Range", "default": 2, "min": 0, "max": 8}, {"name": "commander_choice", "display_name": "Commander Choice", "description": "How the player's commander is selected for missions.\nLocked Random: The player's comm
{"name": "trombone", "game": "Trombone Champ", "version": "0.3.4", "hidden": false, "groups": [{"name": "Game Options", "options": [{"name": "progression_balancing", "display_name": "Progression Balancing", "description": "A system that can move progression earlier, to try and prevent the player from getting stuck and bored early.\n\nA lower setting means more getting stuck. A higher setting means less getting stuck.", "randomizable": true, "visibility": 15, "type": "NamedRange", "default": 50, "min": 0, "max": 99, "presets": {"disabled": 0, "normal": 50, "extreme": 99}}, {"name": "accessibility", "display_name": "Accessibility", "description": "Set rules for reachability of your items/locations.\n\n**Full:** ensure everything can be reached and acquired.\n\n**Minimal:** ensure what is needed to reach your goal can be acquired.", "randomizable": true, "visibility": 15, "type": "Choice", "default": 0, "choices": [{"name": "full", "display_name": "Full", "value": 0}, {"name": "minimal", "display_name": "Minimal", "value": 2}]}, {"name": "bypass_options", "display_name": "Bypass Option Restrictions", "description": "If enabled, bypasses option restrictions that throw an OptionError but are not strictly mistakes.\nWARNING: This may result in generation failures, especially solo.", "randomizable": true, "visibility": 0, "type": "Toggle", "default": false}], "collapsed": false}, {"name": "Goal Options", "options": [{"name": "goal", "display_name": "Goal Tracks Count", "description": "How many tracks need to be beaten to goal.\nIf set to 0, the goal is instead to beat the goal track specified.\nWill cap at the total number of tracks.", "randomizable": true, "visibility": 15, "type": "Range", "default": 10, "min": 0, "max": 200}, {"name": "goal_track", "display_name": "Goal Track", "description": "Determines which track is the goal track.\nMust be set if goal tracks count is 0.\nDoes nothing if goal tracks count is above 0.\nMust be set to a short track name that exists in the track list based on stars settings.", "randomizable": true, "visibility": 15, "type": "TextChoice", "default": -1, "choices": [{"name": "none", "display_name": "None", "value": -1}]}, {"name": "rating", "display_name": "Goal Rating", "description": "Required rating for a track to count as beaten.", "randomizable": true, "visibility": 15, "type": "Choice", "default": 1, "choices": [{"name": "c", "display_name": "C", "value": 0}, {"name": "b", "display_name": "B", "value": 1}, {"name": "a", "display_name": "A", "value": 2}, {"name": "s", "display_name": "S", "value": 3}]}, {"name": "rating_start", "display_name": "Initial Rating Required", "description": "Initial required rating to beat tracks, Rating Reduction items are created to allow this to match Goal Rating.\nMust be larger than or equal to goal rating.", "randomizable": true, "visibility": 15, "type": "Choice", "default": 3, "choices": [{"name": "c", "display_name": "C", "value": 0}, {"name": "b", "display_name": "B", "value": 1}, {"name": "a", "display_name": "A", "value": 2}, {"name": "s", "display_name": "S", "value": 3}]}, {"name": "hot_dogs", "display_name": "Hot Dogs", "description": "How many Hot Dog items are required to unlock the goal track.\nDoes nothing if goal tracks count is above 0.", "randomizable": true, "visibility": 15, "type": "Range", "default": 0, "min": 0, "max": 20}, {"name": "extra_hot_dogs", "display_name": "Extra Hot Dogs", "description": "How many extra Hot Dog items to add.\nDoes nothing if goal tracks count is above 0.", "randomizable": true, "visibility": 15, "type": "Range", "default": 0, "min": 0, "max": 20}], "collapsed": false}, {"name": "Track List Options", "options": [{"name": "easy_track", "display_name": "Easy Track Difficulty Gap", "description": "Easier tracks will require a higher rating to count as completed, based on the star difference.\nSet to 0 to disable. Values above 0 indicate how many stars below the hardest track needed per rating nudge.\nExample: Hardest is 10 stars, goal is B rank, setting is 2. A 6 star track requires S rank (4 below, nudges twice).", "randomizable": true, "visibility": 15, "type": "Range", "default": 1, "min": 0, "max": 5}, {"name": "min_diff", "display_name": "Min Stars", "description": "Minimum star rating for a track to be included.\nThe starting track will be the easiest track with this difficulty.", "randomizable": true, "visibility": 15, "type": "Range", "default": 3, "min": 1, "max": 9}, {"name": "max_diff", "display_name": "Max Stars", "description": "Maximum star rating for a track to be included.\nIf Goal Tracks is 0, the goal track is the longest track with this difficulty.\nMust be higher than Min Stars, and will auto-increase as required.", "randomizable": true, "visibility": 15, "type": "Range", "default": 7, "min": 2, "max": 10}, {"name": "unsafe", "display_name": "Unsafe Tracks", "description": "Include tracks that are marked as streamer unsafe.\nThis is required for DLC tracks, which are all marked unsafe.", "randomizable": true, "visibility": 15, "type": "Toggle", "default": false}, {"name": "celeste", "display_name": "Celeste DLC", "description": "Include tracks from the Celeste DLC.\nDoes nothing if Unsafe Tracks is not selected.", "randomizable": true, "visibility": 15, "type": "Toggle", "default": false}, {"name": "pizza_tower", "display_name": "Pizza Tower DLC", "description": "Include tracks from the Pizza Tower DLC.\nDoes nothing if Unsafe Tracks is not selected.", "randomizable": true, "visibility": 15, "type": "Toggle", "default": false}, {"name": "undertale_deltarune", "display_name": "Toby Fox DLC", "description": "Include tracks from the Undertale+Deltarune DLC.\nDoes nothing if Unsafe Tracks is not selected.", "randomizable": true, "visibility": 15, "type": "Toggle", "default": false}, {"name": "removed_tracks", "display_name": "Removed Tracks", "description": "A list of tracks to remove after prior filtering.\nMust not include the goal track if specified.\nMust no
{"name": "minishoot", "game": "Minishoot Adventures", "version": "0.0.0", "hidden": false, "groups": [{"name": "Game Options", "options": [{"name": "progression_balancing", "display_name": "Progression Balancing", "description": "A system that can move progression earlier, to try and prevent the player from getting stuck and bored early.\n\nA lower setting means more getting stuck. A higher setting means less getting stuck.", "randomizable": true, "visibility": 15, "type": "NamedRange", "default": 50, "min": 0, "max": 99, "presets": {"disabled": 0, "normal": 50, "extreme": 99}}, {"name": "accessibility", "display_name": "Accessibility", "description": "Set rules for reachability of your items/locations.\n\n**Full:** ensure everything can be reached and acquired.\n\n**Minimal:** ensure what is needed to reach your goal can be acquired.", "randomizable": true, "visibility": 15, "type": "Choice", "default": 0, "choices": [{"name": "full", "display_name": "Full", "value": 0}, {"name": "minimal", "display_name": "Minimal", "value": 2}]}, {"name": "npc_sanity", "display_name": "NPC Sanity", "description": "Randomizes the freeable NPCs in the world, making them obtainable from any source.", "randomizable": true, "visibility": 15, "type": "Toggle", "default": false}, {"name": "scarab_sanity", "display_name": "Scarab Sanity", "description": "Randomizes the scarabs in the world.", "randomizable": true, "visibility": 15, "type": "Toggle", "default": false}, {"name": "spirit_sanity", "display_name": "Spirit Sanity", "description": "Randomizes the spirit in the world.", "randomizable": true, "visibility": 15, "type": "Toggle", "default": false}, {"name": "shard_sanity", "display_name": "Shard Sanity", "description": "Randomizes the XP shards \"groups\" (not individual crystals) in the world.", "randomizable": true, "visibility": 15, "type": "Toggle", "default": false}, {"name": "key_sanity", "display_name": "Key Sanity", "description": "Randomizes the small keys of dungeons in the world.", "randomizable": true, "visibility": 15, "type": "Toggle", "default": false}, {"name": "boss_key_sanity", "display_name": "Boss Key Sanity", "description": "Randomizes the boss keys of dungeons in the world.", "randomizable": true, "visibility": 15, "type": "Toggle", "default": false}, {"name": "add_trap_items", "display_name": "Add Trap Items", "description": "Add trap items to the item pool.\nIn Minishoot' Adventures, trap items will force the primordial scarab to be a little chatty and make references to other games.\n(some of which are playable on Archipelago !)", "randomizable": true, "visibility": 15, "type": "Toggle", "default": false}, {"name": "trap_items_appearance", "display_name": "Trap Items Appearance", "description": "Set the appearance of trap items.\nWhen set to \"Major Items Only\", trap items will be disguised as major items.\nWhen set to \"Junk Items Only\", trap items will be disguised as junk items.\nWhen set to \"Anything\", trap items can be disguised as any other items.", "randomizable": true, "visibility": 15, "type": "Choice", "default": 0, "choices": [{"name": "major_items_only", "display_name": "Major Items Only", "value": 0}, {"name": "junk_items_only", "display_name": "Junk Items Only", "value": 1}, {"name": "anything", "display_name": "Anything", "value": 2}]}, {"name": "shop_cost_modifier", "display_name": "Shop Cost Modifier", "description": "Set the super crystal cost modifier for items in shops.\nThe value can be between 10 and 200.\nThe value is a percentage, so 100 means that the cost will be the same as in vanilla.", "randomizable": true, "visibility": 15, "type": "Range", "default": 100, "min": 10, "max": 200}, {"name": "scarab_items_cost", "display_name": "Scarab Items Cost", "description": "Set the scarab cost for items in shops.\nThe value can be between 1 and 3.\nThe value is the number each item will cost in scarabs.\nNote that extra scarabs will remain in the item pool.", "randomizable": true, "visibility": 15, "type": "Range", "default": 3, "min": 1, "max": 3}, {"name": "spirit_tower_requirement", "display_name": "Spirit Tower Requirement", "description": "Set the number of spirits required to enter the Spirit Tower.\nThe value can be between 0 and 8.\nThis setting does not affect the total number of spirit items in the world, only the number required to access the tower.", "randomizable": true, "visibility": 15, "type": "Range", "default": 8, "min": 0, "max": 8}, {"name": "show_archipelago_item_category", "display_name": "Show Archipelago item category", "description": "When enabled, Archipelago items sprites will indicate if its an important item (with an arrow pointing up), an helpful one (with the default icon), or not important (with a black and white sprite).", "randomizable": true, "visibility": 15, "type": "Toggle", "default": true}, {"name": "blocked_forest", "display_name": "Blocked Forest", "description": "Replace the bushes of the secret pond in the forest with rocks. This make the south forest area blocked until you have the supershot.\nWith this option enabled, the forest area no longer contains sphere 0 locations locked behind a particular difficult fight without any additional offensive capabilities.", "randomizable": true, "visibility": 15, "type": "Toggle", "default": true}, {"name": "ignore_cannon_level_requirements", "display_name": "Ignore Cannon Level Requirements", "description": "By default, the game will ensure that progressive cannon levels are accessible before fights in late game areas.\nSo for example, you will be able to enter Dungeon 3 in logic, but you will need the cannon level 4 to beat the boss, or items behind fights in this dungeon.\nIf you enable this option, the cannon level requirements will be ignored, and the logic will expect you to be able to beat all fights with a level 1 cannon.", "randomizable": true, "visibility": 15, "type": "Toggle", "default": false}, {"name": "boostless_springboards", "display_name": "Boostless Springboards", "description": "When this setting is off, the logic will require you to use the boost to jump from springboards.\nWhen this setting is on, the dash will be enough to jump from springboards logically, which make the dash even more useful.", "randomizable": true, "visibility": 15, "type": "Toggle", "default": false}, {"name": "boostless_spirit_races", "display_name": "Boostless Spirit Races", "description": "When this setting is off, races against spirits will logically require the boost.\nWhen this setting is on, the logic will assume that you can complete those races with the dash instead.\nNote that you will still need the boost to complete the the spirits races of the Beach, Scarab Temple and Sunken City.\nAlso note that this setting may require you to farm some XP to level up your speed.", "randomizable": true, "visibility": 15, "type": "Toggle", "default": false}, {"name": "boostless_torch_races", "display_name": "Boostless Torch Races", "description": "When this setting is off, timed torch races will logically require the boost.\nWhen this setting is on, the logic will assume that you can complete those races without it.\nNote that this setting may require you to farm some XP to level up your speed.", "randomizable": true, "visibility": 15, "type": "Toggle", "default": false}, {"name": "enable_primordial_crystal_logic", "display_name": "Enable Primordial Crystal Logic", "description": "When this setting is on, the Primordial Crystal will be considered in logic to blow up rocks and walls.\nWhen this setting is off, the logic will assume that you imperatively need Supershot to do that.", "randomizable": true, "visibility": 15, "type": "Toggle", "default": false}, {"name": "progressive_dash", "display_name": "Progressive Dash", "description": "When enabled, the game will fuse the Dash and the Spirit Dash into two cumulative progressive upgrades.\nThe first upgrade will always allow you to dash, and the second one will allow you to dash through bullets.", "randomizable": true, "visibility": 15, "type": "Toggle", "default": false}, {"name": "dashless_gaps", "display_name": "Dashless Gaps", "description": "When set on \"Needs Dash\", you will need the dash to cross gaps, regardless of their size.\nWhen set on \"Needs Boost\", you will be able to logically cross gaps with the boost if the gap is small enough.\nWhen set on \"Needs neither\", you will be able to cross certains, very tight gaps without any upgrade.\nNote that this last value may require you to farm some XP to level up your speed.", "randomizable": true, "visibility": 15, "type": "Choice", "default": 0, "choices": [{"name": "needs_dash", "display_name": "Needs Dash", "value": 0}, {"name": "needs_boost", "display_name": "Needs Boost", "value": 1}, {"name": "needs_neither", "display_name": "Needs Neither", "value": 2}]}, {"name": "completion_goals", "display_name": "Completion Goals", "description": "Set the goals required to finish the game.\n* Dungeon 5 : Beat the boss of Dungeon 5 and get to the normal ending.\n* Snow : Beat the Unchosen inside the tree and get to the true ending.\n* Dungeon 5 and Snow : Beat both the normal and true ending.\n* Spirit Tower : Collect all spirits and get to the Spirit Tower ending. The number of spirits required to enter the tower can be set with the \"Spirit Tower Requirement\" option.", "randomizable": true, "visibility": 15, "type": "Choice", "default": 0, "choices": [{"name": "dungeon_5", "display_name": "Dungeon 5", "value": 0}, {"name": "snow", "display_name": "Snow", "value": 1}, {"name": "dungeon_5_and_snow", "display_name": "Dungeon 5 And Snow", "value": 2}, {"name": "spirit_tower", "display_name": "Spirit Tower", "value": 3}]}], "collapsed": false}, {"name": "Item & Location Options", "options": [{"name": "local_items", "display_name": "Local Items", "description": "Forces these items to be in their native world.", "randomizable": false, "visibility": 15, "type": "OptionSet", "default": [], "options": ["Abyss Map",
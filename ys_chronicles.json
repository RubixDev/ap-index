{"name": "ys_chronicles", "game": "Ys I Chronicles", "version": "0.0.0", "hidden": false, "groups": [{"name": "Game Options", "options": [{"name": "progression_balancing", "display_name": "Progression Balancing", "description": "A system that can move progression earlier, to try and prevent the player from getting stuck and bored early.\n\nA lower setting means more getting stuck. A higher setting means less getting stuck.", "randomizable": true, "visibility": 15, "type": "NamedRange", "default": 50, "min": 0, "max": 99, "presets": {"disabled": 0, "normal": 50, "extreme": 99}}, {"name": "accessibility", "display_name": "Accessibility", "description": "Set rules for reachability of your items/locations.\n\n**Full:** ensure everything can be reached and acquired.\n\n**Minimal:** ensure what is needed to reach your goal can be acquired.", "randomizable": true, "visibility": 15, "type": "Choice", "default": 0, "choices": [{"name": "full", "display_name": "Full", "value": 0}, {"name": "minimal", "display_name": "Minimal", "value": 2}]}, {"name": "goal", "display_name": "Goal", "description": "What is required to complete the game.\n\nDark Fact: Defeat Dark Fact (standard ending)\nAll Books: Collect all 6 Books of Ys and defeat Dark Fact\nAll Bosses: Defeat all bosses", "randomizable": true, "visibility": 15, "type": "Choice", "default": 0, "choices": [{"name": "dark_fact", "display_name": "Dark Fact", "value": 0}, {"name": "all_books", "display_name": "All Books", "value": 1}, {"name": "all_bosses", "display_name": "All Bosses", "value": 2}]}, {"name": "shuffle_equipment", "display_name": "Shuffle Equipment", "description": "Include weapons, armor, and shields in the item pool.\nIf disabled, equipment is found in vanilla locations.", "randomizable": true, "visibility": 15, "type": "Toggle", "default": true}, {"name": "shuffle_rings", "display_name": "Shuffle Rings", "description": "Include rings in the item pool.", "randomizable": true, "visibility": 15, "type": "Toggle", "default": true}, {"name": "shuffle_keys", "display_name": "Shuffle Keys", "description": "Include keys in the item pool.\nKeys are always progression items.", "randomizable": true, "visibility": 15, "type": "Toggle", "default": true}, {"name": "shuffle_quest_items", "display_name": "Shuffle Quest Items", "description": "Include quest items (Books of Ys, Harmonica, etc.) in the pool.", "randomizable": true, "visibility": 15, "type": "Toggle", "default": true}, {"name": "shuffle_consumables", "display_name": "Shuffle Consumables", "description": "Include consumable items (Heal Potions, Mirrors) in the pool.\nThese become filler items from other players' worlds.", "randomizable": true, "visibility": 15, "type": "Toggle", "default": false}, {"name": "shuffle_shops", "display_name": "Shuffle Shops", "description": "Shop purchases are location checks.\nFirst purchase of each shop item gives the randomized item.\nSubsequent purchases give the vanilla item.", "randomizable": true, "visibility": 15, "type": "Toggle", "default": true}, {"name": "boss_checks", "display_name": "Boss Checks", "description": "Boss kills are location checks that can contain randomized items.\nWhen enabled, Books of Ys are shuffled into the item pool.\nWhen disabled, bosses give their vanilla rewards.", "randomizable": true, "visibility": 15, "type": "Toggle", "default": true}, {"name": "boss_randomization", "display_name": "Boss Randomization", "description": "How bosses are handled.\n\nVanilla: Bosses appear in their normal locations\nShuffled: Boss order is randomized (same progression requirements)", "randomizable": true, "visibility": 15, "type": "Choice", "default": 0, "choices": [{"name": "vanilla", "display_name": "Vanilla", "value": 0}, {"name": "shuffled", "display_name": "Shuffled", "value": 1}]}, {"name": "starting_weapon", "display_name": "Starting Weapon", "description": "What weapon you start with.\n\nNone: Start with no weapon (hard mode)\nShort Sword: Start with Short Sword (vanilla)\nLong Sword: Start with Long Sword (easier)", "randomizable": true, "visibility": 15, "type": "Choice", "default": 0, "choices": [{"name": "none", "display_name": "None", "value": 0}, {"name": "short_sword", "display_name": "Short Sword", "value": 1}, {"name": "long_sword", "display_name": "Long Sword", "value": 2}]}, {"name": "experience_multiplier", "display_name": "Experience Multiplier", "description": "Multiplier for experience gained from enemies.\n100 = normal, 200 = double, 50 = half", "randomizable": true, "visibility": 15, "type": "Range", "default": 100, "min": 25, "max": 400}, {"name": "gold_multiplier", "display_name": "Gold Multiplier", "description": "Multiplier for gold gained from enemies.\n100 = normal, 200 = double, 50 = half", "randomizable": true, "visibility": 15, "type": "Range", "default": 100, "min": 25, "max": 400}, {"name": "death_link", "display_name": "Death Link", "description": "When you die, everyone with DeathLink enabled also dies.\nWhen someone else dies, you die too.", "randomizable": true, "visibility": 15, "type": "Toggle", "default": false}], "collapsed": false}, {"name": "Item & Location Options", "options": [{"name": "local_items", "display_name": "Local Items", "description": "Forces these items to be in their native world.", "randomizable": false, "visibility": 15, "type": "OptionSet", "default": [], "options": ["Short Sword", "Long Sword", "Talwar", "Silver Sword", "Flame Sword", "Small Shield", "Middle Shield", "Large Shield", "Battle Shield", "Silver Shield", "Chain Mail", "Plate Mail", "Reflex", "Battle Armor", "Silver Armor", "Power Ring", "Shield Ring", "Timer Ring", "Heal Ring", "Evil Ring", "Book of Ys (Hadal)", "Book of Ys (Tovah)", "Book of Ys (Dabbie)", "Book of Ys (Mesa)", "Book of Ys (Gemma)", "Book of Ys (Fact)", "Treasure Box Key", "Prison Key", "Shrine Key", "Ivory Key", "Marble Key", "Darm Key", "Sara's Crystal", "Roda Tree Seed", "Silver Bell", "Silver Harmonica", "Idol", "Rod", "Monocle", "Blue Amul
{"name": "repo", "game": "R.E.P.O", "version": "0.4.1", "hidden": false, "groups": [{"name": "Game Options", "options": [{"name": "progression_balancing", "display_name": "Progression Balancing", "description": "A system that can move progression earlier, to try and prevent the player from getting stuck and bored early.\n\nA lower setting means more getting stuck. A higher setting means less getting stuck.", "randomizable": true, "visibility": 15, "type": "NamedRange", "default": 50, "min": 0, "max": 99, "presets": {"disabled": 0, "normal": 50, "extreme": 99}}, {"name": "accessibility", "display_name": "Accessibility", "description": "Set rules for reachability of your items/locations.\n\n**Full:** ensure everything can be reached and acquired.\n\n**Minimal:** ensure what is needed to reach your goal can be acquired.", "randomizable": true, "visibility": 15, "type": "Choice", "default": 0, "choices": [{"name": "full", "display_name": "Full", "value": 0}, {"name": "minimal", "display_name": "Minimal", "value": 2}]}, {"name": "pellys_required", "display_name": "Pellys Required", "description": "Choose how many Pellys will be required for victory.", "randomizable": true, "visibility": 15, "type": "Range", "default": 12, "min": 0, "max": 12}, {"name": "level_quota", "display_name": "Level Quota", "description": "Choose how many levels must be completed for your goal, in addition to gathering enough Pellys.", "randomizable": true, "visibility": 15, "type": "Range", "default": 8, "min": 1, "max": 20}, {"name": "valuable_hunt", "display_name": "Valuable Hunt", "description": "Determines if extracting all valuables (excluding pellys) is required for your goal.", "randomizable": true, "visibility": 15, "type": "Toggle", "default": false}, {"name": "monster_hunt", "display_name": "Monster Hunt", "description": "Determines if extracting all monster souls is required for your goal.", "randomizable": true, "visibility": 15, "type": "Toggle", "default": false}, {"name": "combat_logic", "display_name": "Combat Logic", "description": "Determines what items are logically required to fight monsters.\nEasy: Guns or Explosives\nMedium: Strength Upgrades + Stun Items, Melee Weapons, Guns, or Explosives\nHard: No combat logic. Player may have to kill monsters with valuables found in levels.", "randomizable": true, "visibility": 15, "type": "Choice", "default": 1, "choices": [{"name": "easy", "display_name": "Easy", "value": 0}, {"name": "medium", "display_name": "Medium", "value": 1}, {"name": "hard", "display_name": "Hard", "value": 2}]}, {"name": "shop_stock", "display_name": "Progressive Shop Stock Amount", "description": "Choose how many Archipelago Shop Items are unlocked with each Progressive Shop Stock.", "randomizable": true, "visibility": 15, "type": "Range", "default": 10, "min": 5, "max": 50}, {"name": "shop_upgrade_total", "display_name": "Total Shop Upgrade Locations", "description": "Choose how many Archipelago Items show up in the Upgrades section of the Shop.", "randomizable": true, "visibility": 15, "type": "Range", "default": 80, "min": 20, "max": 100}, {"name": "shop_upgrade_logical", "display_name": "Shop Upgrade Locations in Logic", "description": "Choose how many shop upgrades will potentially be logically relevant.\nItems past this number will not have progression items.\nThis number gets set to the Total Shop Upgrade Locations if it is greater.", "randomizable": true, "visibility": 15, "type": "Range", "default": 60, "min": 20, "max": 100}, {"name": "starting_level_type", "display_name": "Starting Level Type", "description": "Choose which level type to start with.", "randomizable": true, "visibility": 15, "type": "TextChoice", "default": "random", "choices": [{"name": "swiftbroom_academy", "display_name": "Swiftbroom Academy", "value": 0}, {"name": "headman_manor", "display_name": "Headman Manor", "value": 1}, {"name": "mcjannek_station", "display_name": "Mcjannek Station", "value": 2}, {"name": "museum_of_human_art", "displ
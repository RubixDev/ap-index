{"name": "fp2", "game": "Freedom Planet 2", "version": "0.0.0", "hidden": false, "groups": [{"name": "Game Options", "options": [{"name": "progression_balancing", "display_name": "Progression Balancing", "description": "A system that can move progression earlier, to try and prevent the player from getting stuck and bored early.\n\nA lower setting means more getting stuck. A higher setting means less getting stuck.", "randomizable": true, "visibility": 15, "type": "NamedRange", "default": 50, "min": 0, "max": 99, "presets": {"disabled": 0, "normal": 50, "extreme": 99}}, {"name": "accessibility", "display_name": "Accessibility", "description": "Set rules for reachability of your items/locations.\n\n**Full:** ensure everything can be reached and acquired.\n\n**Minimal:** ensure what is needed to reach your goal can be acquired.", "randomizable": true, "visibility": 15, "type": "Choice", "default": 0, "choices": [{"name": "full", "display_name": "Full", "value": 0}, {"name": "minimal", "display_name": "Minimal", "value": 2}]}, {"name": "chapters", "display_name": "Chapter Unlocks", "description": "Determines how stages should be unlocked.\nIndividual = Stages unlock in sets, based on their grouping in the Adventure Mode.\nProgressive = Stages unlock in sets in a set order.\nOpen = Stages unlock individually, without their Star Card requirements.", "randomizable": true, "visibility": 15, "type": "Choice", "default": 1, "choices": [{"name": "individual", "display_name": "Individual", "value": 0}, {"name": "progressive", "display_name": "Progressive", "value": 1}, {"name": "open", "display_name": "Open", "value": 2}]}, {"name": "filler_star_cards", "display_name": "Filler Star Cards", "description": "Allow extra Star Cards to be added as Filler Items.", "randomizable": true, "visibility": 15, "type": "Toggle", "default": false}, {"name": "filler_time_capsules", "display_name": "Filler Time Capsules", "description": "Allow extra Time Capsules to be added as Filler Items.", 
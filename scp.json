{"name": "scp", "game": "Super Cat Planet", "version": "0.0.0", "hidden": false, "groups": [{"name": "Game Options", "options": [{"name": "progression_balancing", "display_name": "Progression Balancing", "description": "A system that can move progression earlier, to try and prevent the player from getting stuck and bored early.\n\nA lower setting means more getting stuck. A higher setting means less getting stuck.", "randomizable": true, "visibility": 15, "type": "NamedRange", "default": 50, "min": 0, "max": 99, "presets": {"disabled": 0, "normal": 50, "extreme": 99}}, {"name": "accessibility", "display_name": "Accessibility", "description": "Set rules for reachability of your items/locations.\n\n**Full:** ensure everything can be reached and acquired.\n\n**Minimal:** ensure what is needed to reach your goal can be acquired.", "randomizable": true, "visibility": 15, "type": "Choice", "default": 0, "choices": [{"name": "full", "display_name": "Full", "value": 0}, {"name": "minimal", "display_name": "Minimal", "value": 2}]}, {"name": "cat_rando", "display_name": "Randomize Cats", "description": "Includes Cats into randomization.", "randomizable": true, "visibility": 15, "type": "Toggle", "default": true}, {"name": "local_cats", "display_name": "Local Cat Percentage", "description": "Forces some percent of Cat items to be found inside of your slot.\nReduces flooding in the multiworld.", "randomizable": true, "visibility": 0, "type": "NamedRange", "default": -1, "min": 0, "max": 100, "presets": {"off": -1, "weak": 50, "strong": 75, "all": 100}}, {"name": "strange_cat_rando", "display_name": "Randomize Strange Cats", "description": "Includes Strange Cats into randomization.", "randomizable": true, "visibility": 15, "type": "Toggle", "default": true}, {"name": "extra_walls", "display_name": "Extra Button Walls", "description": "Adds button walls between areas to break up progression. Highly recommended.", "randomizable": true, "visibility": 15, "type": "Toggle", "default"
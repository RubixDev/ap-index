{"name": "pd2_crimdawn", "game": "PAYDAY 2: Criminal Dawn", "version": "0.7.3", "hidden": false, "groups": [{"name": "Game Options", "options": [{"name": "progression_balancing", "display_name": "Progression Balancing", "description": "A system that can move progression earlier, to try and prevent the player from getting stuck and bored early.\n\nA lower setting means more getting stuck. A higher setting means less getting stuck.", "randomizable": true, "visibility": 15, "type": "NamedRange", "default": 50, "min": 0, "max": 99, "presets": {"disabled": 0, "normal": 50, "extreme": 99}}, {"name": "accessibility", "display_name": "Accessibility", "description": "Set rules for reachability of your items/locations.\n\n**Full:** ensure everything can be reached and acquired.\n\n**Minimal:** ensure what is needed to reach your goal can be acquired.", "randomizable": true, "visibility": 15, "type": "Choice", "default": 0, "choices": [{"name": "full", "display_name": "Full", "value": 0}, {"name": "minimal", "display_name": "Minimal", "value": 2}]}, {"name": "goal", "display_name": "Goal", "description": "ORIGINAL: Finish a run consisting of random tiered heists.\nCAMPAIGN: Finish a preset run with a fixed set of heists.\nSCORE: Send every score check. Heists are completely random.", "randomizable": true, "visibility": 15, "type": "Choice", "default": 1, "choices": [{"name": "original", "display_name": "Original", "value": 1}, {"name": "campaign", "display_name": "Campaign", "value": 2}, {"name": "score", "display_name": "Score", "value": 3}]}, {"name": "campaign", "display_name": "Campaign", "description": "Only used if 'Campaign' is selected as the goal.\nYou need to own all the DLC in a campaign to be able to play it!\n\nCLASSICS: First World Bank, Heat Street, Panic Room, Green Bridge, Diamond Heist, Slaughterhouse.\nYOU GUYS NO FUN: Four Stores, Mallcrasher, Nightclub, Aftershock, Meltdown.\nRETURN OF THE RAT: Watchdogs, Firestarter day 1, Rats, Hoxton Breakout day 2, Hoxton Revenge.\nDEATH OF DEMOCRACY: Framing Frame day 3, Election Day bank, Big Oil day 2.\nMURKY DAY: Shadow Raid, Meltdown, Beneath the Mountain (DLC), Henry's Rock.\nI NEED MY PAYDAY TOO: Big Bank (DLC), The Diamond (DLC), Hotline Miami (DLC), Hoxton Breakout day 1, Golden Grin Casino (DLC).\nGREATEST HEIST OF ALL: Reservoir Dogs (DLC), Brooklyn Bank, Shacklethorne Auction, Breakin' Feds, Hell's Island, White House.\nSILK ROAD: Border Crossing (DLC), San Mart\u00edn Bank (DLC), Breakfast in Tijuana (DLC), Buluc's Mansion (DLC).\nCITY OF GOLD: Dragon Heist (DLC), Black Cat (DLC), Mountain Master (DLC).\nTEXAS HEAT: Midland Ranch (DLC), Hostile Takeover (DLC), Crude Awakening (DLC).\nFOLLOW THE MONEY: Bank Heist: Cash, GO Bank, Brooklyn Bank, San Mart\u00edn Bank (DLC), First World Bank, Big Bank (DLC).\nGUN RUNNERS: Firestarter day 1, Aftershock, Brooklyn 10-10 (DLC), Bomb: Dockyard (DLC), Midland Ranch (DLC), Border Crossing (DLC).\nSTEALTH MISSION: Breakin' Feds, Yacht Heist (DLC), Murky Station (licensed), Shadow Raid, Car Shop.", "randomizable": true, "visibility": 15, "type": "Choice", "default": 1, "choices": [{"name": "classics", "display_name": "Classics", "value": 1}, {"name": "you_guys_no_fun", "display_name": "You Guys No Fun", "value": 2}, {"name": "return_of_the_rat", "display_name": "Return Of The Rat", "value": 3}, {"name": "death_of_democracy", "display_name": "Death Of Democracy", "value": 4}, {"name": "murky_day", "display_name": "Murky Day", "value": 5}, {"name": "i_need_my_payday_too", "display_name": "I Need My Payday Too", "value": 6}, {"name": "greatest_heist_of_all", "display_name": "Greatest Heist Of All", "value": 7}, {"name": "silk_road", "display_name": "Silk Road", "value": 8}, {"name": "city_of_gold", "display_name": "City Of Gold", "value": 9}, {"name": "texas_heat", "display_name": "Texas Heat", "value": 10}, {"name": "follow_the_money", "display_name": "Follow The Money", "value": 11}, {"name": "gun_runners", "display_name": "Gun Runners", "value": 12}, {"name": "stealth_mission", "display_name": "Stealth Mission", "value": 100}]}, {"name": "run_length", "display_name": "Run Length", "description": "Only used if 'Original' is selected as the goal.\n\nHow many heists you need to finish to win.\nThe final heist is always White House or Crude Awakening (if you own it).", "randomizable": true, "visibility": 15, "type": "Range", "default": 4, "min": 1, "max": 6}, {"name": "score_checks", "display_name": "Score Checks", "description": "Base number of score checks. Each check requires one more point than the last, so this scales quite fast!\nThis is increased by other options, so the actual number of score checks will often be higher.\nSolo worlds will fail to generate if this is set too low. 60 is a good starting point!", "randomizable": true, "visibility": 15, "type": "Range", "default": 68, "min": 0, "max": 100}, {"name": "safehouse_tiers", "display_name": "Safe House Tiers", "description": "How many times you can upgrade the safe house. Adds 8 score checks per tier.\nThe 'Score' goal can fail to generate if this is too high.", "randomizable": true, "visibility": 15, "type": "Range", "default": 4, "min": 0, "max": 6}, {"name": "early_bot", "display_name": "Early Bot", "description": "Force a bot to generate in sphere 1, guaranteeing that you get an early bot.\nThis can make the early game significantly easier. If you are playing alone, keeping this on is recommended!", "randomizable": true, "visibility": 15, "type": "Toggle", "default": true}, {"name": "biglobby", "display_name": "BigLobby", "description": "Whether BigLobby is installed. Adds 20 extra score checks when enabled.\nEnabling this increases the number of extra bots from 3 all the way up to 21, however the game may become less stable:\nhttps://modworkshop.net/mod/21582", "randomizable": true, "visibility": 15, "type": "Toggle", "default": false}], "collapsed": false}, {"name": "Item & Location Options", "options": [{"name": "local_items"
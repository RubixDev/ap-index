{"name": "baba_is_you", "game": "Baba Is You", "version": "0.3.0", "hidden": false, "groups": [{"name": "Game Options", "options": [{"name": "progression_balancing", "display_name": "Progression Balancing", "description": "A system that can move progression earlier, to try and prevent the player from getting stuck and bored early.\n\nA lower setting means more getting stuck. A higher setting means less getting stuck.", "randomizable": true, "visibility": 15, "type": "NamedRange", "default": 50, "min": 0, "max": 99, "presets": {"disabled": 0, "normal": 50, "extreme": 99}}, {"name": "accessibility", "display_name": "Accessibility", "description": "Set rules for reachability of your items/locations.\n\n**Full:** ensure everything can be reached and acquired.\n\n**Minimal:** ensure what is needed to reach your goal can be acquired.", "randomizable": true, "visibility": 15, "type": "Choice", "default": 0, "choices": [{"name": "full", "display_name": "Full", "value": 0}, {"name": "minimal", "display_name": "Minimal", "value": 2}]}, {"name": "goal", "display_name": "Goal", "description": "Determines the requirements to beat the game.\nend: Reach the normal ending in \"A Way Out?\".\nflower: Reach the area \"???\".\ndepths: Reach the area \"Depths\".\nmeta: Reach the area \"Meta\" (UNIMPLEMENTED).\ndone: Reach the secret ending in \"The End\" (UNIMPLEMENTED).\nlevels: Win a specified amount of levels.\nblossoms: Collect a specified amount of blossoms.", "randomizable": true, "visibility": 15, "type": "Choice", "default": 0, "choices": [{"name": "end", "display_name": "End", "value": 0}, {"name": "flower", "display_name": "Flower", "value": 1}, {"name": "depths", "display_name": "Depths", "value": 2}, {"name": "meta", "display_name": "Meta", "value": 3}, {"name": "done", "display_name": "Done", "value": 4}, {"name": "levels", "display_name": "Levels", "value": 5}, {"name": "blossoms", "display_name": "Blossoms", "value": 6}]}, {"name": "goal_levels", "display_name": "Goal Levels", "description": "Determines how many levels need to be won when the goal is set to \"levels\". The max for each area access setting is as follows:\nearly: 160\nmap: 165\nflower: 195\ndepths: 206\nmeta: 229\nfull: 231\nIf Gallery or Whoa are excluded and accessible, the max is lowered by 1 for each.", "randomizable": true, "visibility": 15, "type": "Range", "default": 80, "min": 0, "max": 231}, {"name": "goal_blossoms", "display_name": "Goal Blossoms", "description": "Determines how many blossoms need to be obtained when the goal is set to \"blossoms\".", "randomizable": true, "visibility": 15, "type": "Range", "default": 7, "min": 0, "max": 12}, {"name": "logic_difficulty", "display_name": "Logic Difficulty", "description": "Determines the logic difficulty for levels.\neasy: All interactable words are expected to complete a level.\nnormal: Only the necessary words will be expected to complete a level. You may have to use alternative solutions.\nhard: Like normal, but also includes very difficult solutions, some of which require advanced techniques like parsing bugs and object priority.", "randomizable": true, "visibility": 15, "type": "Choice", "default": 1, "choices": [{"name": "easy", "display_name": "Easy", "value": 0}, {"name": "normal", "display_name": "Normal", "value": 1}, {"name": "hard", "display_name": "Hard", "value": 2}]}, {"name": "start_with_default_words", "display_name": "Start With Default Words", "description": "Start with the 9 words that appear in the level \"Baba Is You\".\nDisabling this will lead to an extremely restrictive start, especially if Shuffle Levels is disabled.\nThis will also fail to generate if Shuffle Levels is off and this is a solo game.\nAs such, it is recommended to add a few starting items if this is disabled.", "randomizable": true, "visibility": 15, "type": "Toggle", "default": true}, {"name": "open_map", "display_name": "Open Map", "description": "All levels and worlds on the Map will be open immediately, with the exception of areas behind gates.", "randomizable": true, "visibility": 15, "type": "Toggle", "default": true}, {"name": "world_keys", "display_name": "World Keys", "description": "All subworlds (worlds on the Map, and \"ABC\" in ???) will require their respective Key item to access.", "randomizable": true, "visibility": 15, "type": "Toggle", "default": true}, {"name": "area_access", "display_name": "Accessible Areas", "description": "Determines which areas of the game will be accessible when the goal is set to \"end\", \"levels\", or \"blossoms\".\nAll other goal options will override this option.\nearly: The Map and its subworlds will be accessible, but the top gate will be blocked off, preventing access to Slideshow and beyond.\nmap: The Map and its subworlds will be fully accessible. ??? will be accessible, but not the levels within.\nflower: Map, ???, and their subworlds will be accessible. Depths will be accessible, but not the levels within.\ndepths: Map, ???, Depths, and their subworlds will be accessible. Meta will be accessible, but not the levels within. (UNIMPLEMENTED)\nmeta: All areas other than \"Center\" and its two levels will be accessible. (UNIMPLEMENTED)\nfull: All areas will be accessible. (UNIMPLEMENTED)", "randomizable": true, "visibility": 15, "type": "Choice", "default": 0, "choices": [{"name": "early", "display_name": "Early", "value": 0}, {"name": "map", "display_name": "Map", "value": 1}, {"name": "flower", "display_name": "Flower", "value": 2}, {"name": "depths", "display_name": "Depths", "value": 3}, {"name": "meta", "display_name": "Meta", "value": 4}, {"name": "full", "display_name": "Full", "value": 5}]}, {"name": "exclude_whoa", "display_name": "Exclude Whoa", "description": "Excludes the location of the level \"Whoa\" from logic.\nThe level itself may still appear if Level Shuffle if set to \"full\".\nOnly applies if Meta and its levels are accessible.", "randomizable": true, "visibility": 15, "type": "Toggle", "default": true}, {"name": "exclude_gallery", "display_name": "Exclude Gallery", "description": "Excludes the location of the level \"Gallery\" from logic.\nThe level itself may still appear if Level Shuffle if set to \"full\".\nWhen disabled, the 3 Bonus Orb items will become progression items.\nOnly applies if Center and its levels are accessible.", "randomizable": true, "visibility": 15, "type": "Toggle", "default": true}, {"name": "exclude_maze_transform", "display_name": "Exclude Ultimate Maze Transform", "description": "Excludes transformations for \"Ultimate Maze\" from logic.\nThis removes some locations if Transformsanity is enabled, and also allows it to be included in Level Shuffle.\nThis does NOT remove the 4 \"Write\" levels from logic, as those can be accessed regardless.", "randomizable": true, "visibility": 15, "type": "Toggle", "default": true}, {"name": "blossom_petals", "display_name": "Blossom Petals", "description": "Determines how many Blossom Petals are in the item pool.\nEach Blossom Petal is worth 1/8 of a Blossom.", "randomizable": true, "visibility": 15, "type": "Range", "default": 0, "min": 0, "max": 96}, {"name": "blossoms", "display_name": "Blossoms", "description": "Determines how many Blossoms are in the item pool.", "randomizable": true, "visibility": 15, "type": "Range", "default": 10, "min": 0, "max": 12}, {"name": "first_gate_blossoms", "display_name": "First Gate Blossoms", "description": "Determines how many Blossoms are needed to open the first gate on the map.\nThis gate blocks access to \"A Way Out?\".", "randomizable": true, "visibility": 15, "type": "Range", "default": 3, "min": 0, "max": 12}, {"name": "second_gate_blossoms", "display_name": "Second Gate Blossoms", "description": "Determines how many Blossoms are needed to open the second gate on the map.\nThis gate blocks access to \"Volcanic Cavern\" and \"Mountain\".", "randomizable": true, "visibility": 15, "type": "Range", "default": 5, "min": 0, "max": 12}, {"name": "third_gate_blossoms", "display_name": "Third Gate Blossoms", "description": "Determines how many Blossoms are needed to open the third gate on the map.\nThis gate blocks access to levels 8, 9, and 10 on the map, as well as \"???\" and beyond.\nNot applicable if area access is set to \"early\".", "randomizable": true, "visibility": 15, "type": "Range", "default": 7, "min": 0, "max": 12}, {"name": "force_clear_blossoms", "display_name": "Place Blossoms at World Clears", "description": "Forces Blossoms and Blossom Petals to be placed at World Clear locations, matching vanilla.\nAdditional items will be placed into the item pool as normal, and if there are less items than available clear locations, they will be shuffled randomly among those locations.\nBlossoms have priority over Blossom Petals when placing.\nNote that there 10 clear locations in Map, 1 in ABC if accessible, and 1 in Center if accessible.", "randomizable": true, "visibility": 15, "type": "Toggle", "default": false}, {"name": "complete_checks", "display_name": "Complete Checks", "description": "Adds checks for completing a world (completing all levels within that world)", "randomizable": true, "visibility": 15, "type": "Toggle", "default": false}, {"name": "transformsanity", "display_name": "Transformsanity", "description": "Adds checks for every possible individual transformation for a level.\nFor example, \"Fragile Existence\" would have 4 additional checks, for transforming into \"Baba\", \"Key\", \"Door\", or \"Wall\".\nNot applicable if area access is set to \"early\".", "randomizable": true, "visibility": 15, "type": "Toggle", "default": false}, {"name": "level_shuffle", "display_name": "Shuffle Levels", "description": "Swaps normal levels with other normal levels.\nLevels with transformations, as well as \"A Way Out?\", \"The Box\", and \"The End\" will never be shuffled.\ndisabled: Levels will not be shuffled (default).\nlimited: Only levels within accessible areas will be shuffled.\nfull: All levels will be shuffled, minus the exceptions listed above.", "randomizable": true, "visibility": 15, "type": "Choice", "default": 0, "choices": [{"name": "disabled", "display_name": "Disabled", "value": 0}, {"name": "limited", "display_name": "Limited", "value": 1}, {"name": "full", "display_name": "Full", "value": 2}]}], "collapsed": false}, {"name": "Item & Location Options", "options": [{"name": "local_items", "display_name": "Local Items", "description": "Forces these items to be in their native world.", "randomizable": false, "visibility": 15, "type": "OptionSet", "default": [], "options": ["Speck", "Blossom Petal", "Blossom", "Bonus Orb", "Lake Key", "Island Key", "Ruins Key", "Fall Key", "Forest Key", "Space Key", "Garden Key", "Chasm Key", "Cavern Key", "Mountain Key", "ABC Key", "Depths Key", "Meta Key", "Center Key", "Baba", "Is", "You", "Flag", "Win", "Wall", "Stop", "Rock", "Push", "Sink", "Skull", "Defeat", "Lava", "And", "Star", "Crab", "Keke", "Love", "Move", "Pillar", "Jelly", "Key", "Open", "Door", "Shut", "Belt", "Shift", "End", "Rose", "Red", "Violet", "Blue", "Water", "Float", "Text", "Robot", "Bolt", "Hot", "Cog", "Weak", "Has", "Box", "Melt", "Ghost", "Tele", "Pull", "Ice", "Leaf", "Fence", "Not", "Me", "Tree", "Up", "Right", "Bug", "Fungus", "Swap", "Empty", "Cloud", "Rocket", "UFO", "Moon", "Fall", "Dust", "On", "Grass", "Make", "Hand", "Fruit", "All", "More", "Word", "Sleep", "Bat", "Group", "Fire", "Facing", "Lonely", "Bird", "Sun", "Tile", "Level", "Orb", "Hide", "Bonus", "Write", "A", "AB", "B", "BA", "C", "E", "G", "H", "L", "M", "N", "O", "R", "S", "T", "V", "W", "Near", "Cursor", "I", "Cake", "Done", "Image", "Anni", "Best", "Down", "Left", "Hedge", "Cliff", "Line", "F", "U", "X", "Nouns", "Verbs", "Properties", "Conditions", "Special Nouns", "Letters", "Misc", "World Keys", "Everything"]}, {"name": "non_local_items", "display_name": "Non-local Items", "description": "Forces these items to be outside their native world.", "randomizable": false, "visibility": 
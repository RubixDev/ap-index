{"name": "mhw", "game": "Monster Hunter World", "version": "0.1.3", "hidden": false, "groups": [{"name": "Game Options", "options": [{"name": "progression_balancing", "display_name": "Progression Balancing", "description": "A system that can move progression earlier, to try and prevent the player from getting stuck and bored early.\n\nA lower setting means more getting stuck. A higher setting means less getting stuck.", "randomizable": true, "visibility": 15, "type": "NamedRange", "default": 50, "min": 0, "max": 99, "presets": {"disabled": 0, "normal": 50, "extreme": 99}}, {"name": "accessibility", "display_name": "Accessibility", "description": "Set rules for reachability of your items/locations.\n\n**Full:** ensure everything can be reached and acquired.\n\n**Minimal:** ensure what is needed to reach your goal can be acquired.", "randomizable": true, "visibility": 15, "type": "Choice", "default": 0, "choices": [{"name": "full", "display_name": "Full", "value": 0}, {"name": "minimal", "display_name": "Minimal", "value": 2}]}, {"name": "ending_rank", "display_name": "Completed Rank", "description": "Choose which rank you must reach the end of in order to complete.\nLow Rank: Finish \"A Colossal Task\"\nHigh Rank: Finish \"Land of Convergence\"\nMaster Rank: Finish \"Paean of Guidance\"", "randomizable": true, "visibility": 15, "type": "Choice", "default": 1, "choices": [{"name": "low_rank", "display_name": "Low Rank", "value": 0}, {"name": "high_rank", "display_name": "High Rank", "value": 1}, {"name": "master_rank", "display_name": "Master Rank", "value": 2}]}, {"name": "specialarena_quests", "display_name": "Special Arena Quests", "description": "Adds Special Arena Quests to the quest pool.\nNote: These are the quest that are unlocked when you capture a monster.", "randomizable": true, "visibility": 15, "type": "Toggle", "default": false}, {"name": "event_quests", "display_name": "Event Quests", "description": "Adds Event Quests to the quest pool.", "randomizable": true, "visibility": 15, "type": "Toggle", "default": false}, {"name": "special_quests", "display_name": "Special Quests", "description": "Adds Special Quests to the quest pool.\nNote: This does not add any Low Rank and one High Rank quest.", "randomizable": true, "visibility": 15, "type": "Toggle", "default": false}, {"name": "grindy_quests", "display_name": "Special Quests", "description": "Adds some quests and some dependent locations to the pool.\nNote: These quests require a significant amount of effort to unlock.", "randomizable": true, "visibility": 15, "type": "Toggle", "default": false}, {"name": "overpowered_equip", "display_name": "Overrank Weapons & Armor", "description": "Adds the next rank of progressive weapons and armor to the pool.\nNote: This does not have an effect if selecting Master Rank.", "randomizable": true, "visibility": 15, "type": "Toggle", "default": true}, {"name": "freearmor", "display_name": "Free Armor Crafting", "description": "Makes Armors cost no materials", "randomizable": true, "visibility": 15, "type": "Toggle", "default": true}, {"name": "freeweapon", "display_name": "Free Weapon Crafting", "description": "Makes Weapons cost no materials", "randomizable": true, "visibility": 15, "type": "Toggle", "default": true}, {"name": "seasonal", "display_name": "Seasonal Armor and Weapons", "description": "Makes it so seasonal armor and weapons are added to the pool for free weapons and armors.", "randomizable": true, "visibility": 15, "type": "Toggle", "default": false}, {"name": "endemiclife", "display_name": "Endemic Life", "description": "Adds catching basic endemic life to the location pool.", "randomizable": true, "visibility": 15, "type": "Toggle", "default": false}, {"name": "rareendemic", "display_name": "Rare Endemic Life", "description": "Adds catching rare endemic life to the location pool.\nThese are animals that will likely appear during the game but you may need to seek them out.", "randomizable": true, "visibility": 15, 
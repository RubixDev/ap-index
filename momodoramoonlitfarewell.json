{"name": "momodoramoonlitfarewell", "game": "Momodora Moonlit Farewell", "version": "0.0.0", "hidden": false, "groups": [{"name": "Game Options", "options": [{"name": "progression_balancing", "display_name": "Progression Balancing", "description": "A system that can move progression earlier, to try and prevent the player from getting stuck and bored early.\n\nA lower setting means more getting stuck. A higher setting means less getting stuck.", "randomizable": true, "visibility": 15, "type": "NamedRange", "default": 50, "min": 0, "max": 99, "presets": {"disabled": 0, "normal": 50, "extreme": 99}}, {"name": "accessibility", "display_name": "Accessibility", "description": "Set rules for reachability of your items/locations.\n\n**Full:** ensure everything can be reached and acquired.\n\n**Minimal:** ensure what is needed to reach your goal can be acquired.", "randomizable": true, "visibility": 15, "type": "Choice", "default": 0, "choices": [{"name": "full", "display_name": "Full", "value": 0}, {"name": "minimal", "display_name": "Minimal", "value": 2}]}, {"name": "open_springleaf_path", "display_name": "Open Springleaf Path", "description": "Remove Demon Strings and Wind Barriers in Springleaf Path to enable entering other areas before getting Awakened Sacred Leaf/Sacred Anemone.", "randomizable": true, "visibility": 15, "type": "Toggle", "default": true}, {"name": "deathlink", "display_name": "Deathlink", "description": "Link all player deaths together. If you die, all other players in the session (with deathlink enabled) also die. The same works the other way around.", "randomizable": true, "visibility": 15, "type": "Toggle", "default": true}, {"name": "bell_hover_generation", "display_name": "Bell Hover Generation", "description": "Consider Bell Hover as a possible strat for world generation. Bell Hover is used to access certain areas without having the correct skill (i.e. Demon Frontier without Wall Jump) \n# With this setting on, you might need to get creative to 
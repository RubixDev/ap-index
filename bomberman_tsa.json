{"name": "bomberman_tsa", "game": "Bomberman The Second Attack", "version": "0.0.0", "hidden": false, "groups": [{"name": "Game Options", "options": [{"name": "progression_balancing", "display_name": "Progression Balancing", "description": "A system that can move progression earlier, to try and prevent the player from getting stuck and bored early.\n\nA lower setting means more getting stuck. A higher setting means less getting stuck.", "randomizable": true, "visibility": 15, "type": "NamedRange", "default": 50, "min": 0, "max": 99, "presets": {"disabled": 0, "normal": 50, "extreme": 99}}, {"name": "accessibility", "display_name": "Accessibility", "description": "Set rules for reachability of your items/locations.\n\n**Full:** ensure everything can be reached and acquired.\n\n**Minimal:** ensure what is needed to reach your goal can be acquired.", "randomizable": true, "visibility": 15, "type": "Choice", "default": 0, "choices": [{"name": "full", "display_name": "Full", "value": 0}, {"name": "minimal", "display_name": "Minimal", "value": 2}]}], "collapsed": false}, {"name": "Goal Options", "options": [{"name": "game_goal", "display_name": "game_goal", "description": "Required Goal to complete the seed\nNoah - Clear the game by defeating the final boss, determined by the final boss option\nGenerators - Clear the game by clearing a certain number of planets\nStone Hunt - Clear the game by collecting all of the Elemental Stones.", "randomizable": true, "visibility": 15, "type": "Choice", "default": 0, "choices": [{"name": "noah", "display_name": "Noah", "value": 0}, {"name": "generators", "display_name": "Generators", "value": 1}, {"name": "stones", "display_name": "Stones", "value": 2}]}, {"name": "noah_open", "display_name": "noah_open", "description": "Requirement to access Warship Noah, the game's final dungeon\nGenerators - Open up Noah by clearing a certain number of planets\nWarship Keys - Open Noah by collecting 3 Warship Keys from the item pool\nCoordinates - 
{"name": "bomberman_hero", "game": "Bomberman Hero", "version": "0.2.3", "hidden": false, "groups": [{"name": "Game Options", "options": [{"name": "progression_balancing", "display_name": "Progression Balancing", "description": "A system that can move progression earlier, to try and prevent the player from getting stuck and bored early.\n\nA lower setting means more getting stuck. A higher setting means less getting stuck.", "randomizable": true, "visibility": 15, "type": "NamedRange", "default": 50, "min": 0, "max": 99, "presets": {"disabled": 0, "normal": 50, "extreme": 99}}, {"name": "accessibility", "display_name": "Accessibility", "description": "Set rules for reachability of your items/locations.\n\n**Full:** ensure everything can be reached and acquired.\n\n**Minimal:** ensure what is needed to reach your goal can be acquired.", "randomizable": true, "visibility": 15, "type": "Choice", "default": 0, "choices": [{"name": "full", "display_name": "Full", "value": 0}, {"name": "minimal", "display_name": "Minimal", "value": 2}]}], "collapsed": false}, {"name": "Goal Options", "options": [{"name": "adok_bombs", "display_name": "Required Adok Bombs", "description": "Number of Adok Bombs required to access Garaden\nIf Adok Bomb Goal is Selected then this determines the number of Cards \nNeeded to hit your goal", "randomizable": true, "visibility": 15, "type": "Range", "default": 24, "min": 10, "max": 64}, {"name": "game_goal", "display_name": "game_goal", "description": "Required Goal to complete the seed\nBagular - Clear the game by defeating the final boss, unlocked by collecting enough adok bombs\nAdok Bombs - Clear the game by getting enough Adok Bombs for shorter seeds\nClears - Clear the game by beating a certain number of stages", "randomizable": true, "visibility": 15, "type": "Choice", "default": 0, "choices": [{"name": "bagular", "display_name": "Bagular", "value": 0}, {"name": "adokbombs", "display_name": "Adokbombs", "value": 1}, {"name": "clears", "displ
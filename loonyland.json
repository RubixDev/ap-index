{"name": "loonyland", "game": "Loonyland", "version": "0.0.0", "hidden": false, "groups": [{"name": "Game Options", "options": [{"name": "progression_balancing", "display_name": "Progression Balancing", "description": "A system that can move progression earlier, to try and prevent the player from getting stuck and bored early.\n\nA lower setting means more getting stuck. A higher setting means less getting stuck.", "randomizable": true, "visibility": 15, "type": "NamedRange", "default": 50, "min": 0, "max": 99, "presets": {"disabled": 0, "normal": 50, "extreme": 99}}, {"name": "accessibility", "display_name": "Accessibility", "description": "Set rules for reachability of your items/locations.\n\n**Full:** ensure everything can be reached and acquired.\n\n**Minimal:** ensure what is needed to reach your goal can be acquired.", "randomizable": true, "visibility": 15, "type": "Choice", "default": 0, "choices": [{"name": "full", "display_name": "Full", "value": 0}, {"name": "minimal", "display_name": "Minimal", "value": 2}]}, {"name": "win_condition", "display_name": "Win Condition", "description": "Evilizer: Beat the final boss\n Badges: Get X merit badges earned\nNOT IMPLEMENTED: normal_remix: Beat the final boss in normal and remix", "randomizable": true, "visibility": 15, "type": "Choice", "default": 0, "choices": [{"name": "evilizer", "display_name": "Evilizer", "value": 0}, {"name": "badges", "display_name": "Badges", "value": 1}]}, {"name": "badges_required", "display_name": "Badges Required", "description": "For the Badges win con, how many badges are needed", "randomizable": true, "visibility": 15, "type": "Range", "default": 30, "min": 1, "max": 40}, {"name": "difficulty", "display_name": "Difficulty", "description": "Difficulty Setting", "randomizable": true, "visibility": 15, "type": "Choice", "default": 1, "choices": [{"name": "beginner", "display_name": "Beginner", "value": 0}, {"name": "normal", "display_name": "Normal", "value": 1}, {"name": "hard", "dis
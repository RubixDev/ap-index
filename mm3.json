{"name": "mm3", "game": "Mega Man 3", "version": "0.1.8", "hidden": false, "groups": [{"name": "Game Options", "options": [{"name": "progression_balancing", "display_name": "Progression Balancing", "description": "A system that can move progression earlier, to try and prevent the player from getting stuck and bored early.\n\nA lower setting means more getting stuck. A higher setting means less getting stuck.", "randomizable": true, "visibility": 15, "type": "NamedRange", "default": 50, "min": 0, "max": 99, "presets": {"disabled": 0, "normal": 50, "extreme": 99}}, {"name": "accessibility", "display_name": "Accessibility", "description": "Set rules for reachability of your items/locations.\n\n**Full:** ensure everything can be reached and acquired.\n\n**Minimal:** ensure what is needed to reach your goal can be acquired.", "randomizable": true, "visibility": 15, "type": "Choice", "default": 0, "choices": [{"name": "full", "display_name": "Full", "value": 0}, {"name": "minimal", "display_name": "Minimal", "value": 2}]}, {"name": "death_link", "display_name": "Death Link", "description": "When you die, everyone who enabled death link dies. Of course, the reverse is true too.", "randomizable": true, "visibility": 15, "type": "Toggle", "default": false}, {"name": "energy_link", "display_name": "EnergyLink", "description": "Enables EnergyLink support.\nWhen enabled, pickups dropped from enemies are sent to the EnergyLink pool, and healing/weapon energy/1-Ups can\nbe requested from the EnergyLink pool.\nSome of the energy sent to the pool will be lost on transfer.", "randomizable": true, "visibility": 15, "type": "Toggle", "default": false}, {"name": "starting_robot_master", "display_name": "Starting Robot Master", "description": "The initial stage unlocked at the start.", "randomizable": true, "visibility": 15, "type": "Choice", "default": "random", "choices": [{"name": "needle_man", "display_name": "Needle Man", "value": 0}, {"name": "magnet_man", "display_name": "Magnet 
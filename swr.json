{"name": "swr", "game": "Star Wars Episode I Racer", "version": "0.0.0", "hidden": false, "groups": [{"name": "Game Options", "options": [{"name": "progression_balancing", "display_name": "Progression Balancing", "description": "A system that can move progression earlier, to try and prevent the player from getting stuck and bored early.\n\nA lower setting means more getting stuck. A higher setting means less getting stuck.", "randomizable": true, "visibility": 15, "type": "NamedRange", "default": 50, "min": 0, "max": 99, "presets": {"disabled": 0, "normal": 50, "extreme": 99}}, {"name": "accessibility", "display_name": "Accessibility", "description": "Set rules for reachability of your items/locations.\n\n**Full:** ensure everything can be reached and acquired.\n\n**Minimal:** ensure what is needed to reach your goal can be acquired.", "randomizable": true, "visibility": 15, "type": "Choice", "default": 0, "choices": [{"name": "full", "display_name": "Full", "value": 0}, {"name": "minimal", "display_name": "Minimal", "value": 2}]}, {"name": "progressive_parts", "display_name": "Progressive Parts", "description": "Pod racer parts will always be the next level upgrade", "randomizable": true, "visibility": 15, "type": "Toggle", "default": false}, {"name": "no_traction_upgrades", "display_name": "No Traction Upgrades", "description": "Removes Traction parts from the item pool", "randomizable": true, "visibility": 15, "type": "Toggle", "default": false}, {"name": "course_unlock_mode", "display_name": "Course Unlock Mode", "description": "Sets how courses should unlock\nFull Shuffle: All course unlocks are fully shuffled. Recommended for moderate to longer games and asyncs.\nCircuits: Access to entire circuits is shuffled. Recommended for a shorter game.\nProgressive Circuits: Access to entire circuits is shuffled, and you will always unlock them in order. Recommended for a shorter game.", "randomizable": true, "visibility": 15, "type": "Choice", "default": 0, "choices": 
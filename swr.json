_multiplier", "display_name": "Shop Cost Multiplier", "description": "Additional multiplier for shop costs", "randomizable": true, "visibility": 15, "type": "Range", "default": 1, "min": 1, "max": 10}, {"name": "course_plando", "display_name": "Course Plando", "description": "Sets specific courses\nFor mirrored, append ' (Mirrored)' to any course name\nRepeated courses will cause errors", "randomizable": false, "visibility": 15, "type": "Unknown"}, {"name": "deathlink_amnesty", "display_name": "Death Link Amnesty", "description": "Amount of times you can crash your pod before sending a DeathLink to the server", "randomizable": true, "visibility": 15, "type": "Range", "default": 0, "min": 0, "max": 50}, {"name": "deathlink", "display_name": "Death Link", "description": "When you die, everyone who enabled death link dies. Of course, the reverse is true too.", "randomizable": true, "visibility": 15, "type": "Toggle", "default": false}], "collapsed": false}, {"name": "Item & Location Options", "options": [{"name": "local_items", "display_name": "Local Items", "description": "Forces these items to be in their native world.", "randomizable": false, "visibility": 15, "type": "OptionSet", "default": [], "options": ["Progressive Traction", "Progressive Turning", "Progressive Acceleration", "Progressive Top Speed", "Progressive Air Brake", "Progressive Cooling", "Progressive Repair", "R-60 Repulsorgrip", "R-80 Repulsorgrip", "R-100 Repulsorgrip", "R-300 Repulsorgrip", "R-600 Repulsorgrip", "Control Shift Plate", "Control Vectro Jet", "Control Coupling", "Control Nozzle", "Control Stabilizer", "44 PCX Injector", "Dual 32PCX Injector", "Quad 32PCX Injector", "Quad 44PCX Injector", "Mag-6 Injector", "Plug3 Thrust Coil", "Plug5 Thrust Coil", "Plug8 Thrust Coil", "Block5 Thrust Coil", "Block6 Thrust Coil", "Mark III Air Brake", "Mark IV Air Brake", "Mark V Air Brake", "Tri-Jet Air Brake", "Quadrijet Air Brake", "Stack-3 Radiator", "Stack-6 Radiator", "Rod Coolant Pump", "Dual Cool
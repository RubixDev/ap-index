{"name": "msr", "game": "Metroid: Samus Returns", "version": "0.2.1", "hidden": false, "groups": [{"name": "Game Options", "options": [{"name": "progression_balancing", "display_name": "Progression Balancing", "description": "A system that can move progression earlier, to try and prevent the player from getting stuck and bored early.\n\nA lower setting means more getting stuck. A higher setting means less getting stuck.", "randomizable": true, "visibility": 15, "type": "NamedRange", "default": 50, "min": 0, "max": 99, "presets": {"disabled": 0, "normal": 50, "extreme": 99}}, {"name": "accessibility", "display_name": "Accessibility", "description": "Set rules for reachability of your items/locations.\n\n**Full:** ensure everything can be reached and acquired.\n\n**Minimal:** ensure what is needed to reach your goal can be acquired.", "randomizable": true, "visibility": 15, "type": "Choice", "default": 0, "choices": [{"name": "full", "display_name": "Full", "value": 0}, {"name": "minimal", "display_name": "Minimal", "value": 2}]}, {"name": "dna_available", "display_name": "Metroid DNA Available", "description": "Amount of Metroid DNA in the item pool", "randomizable": true, "visibility": 15, "type": "Range", "default": 10, "min": 0, "max": 39}, {"name": "dna_required", "display_name": "Metroid DNA Required", "description": "Amount of Metroid DNA required to fight the final boss", "randomizable": true, "visibility": 15, "type": "Range", "default": 10, "min": 0, "max": 39}, {"name": "hints", "display_name": "hints", "description": "Makes DNA statues give hints about your items and locations", "randomizable": true, "visibility": 15, "type": "Toggle", "default": true}, {"name": "death_link", "display_name": "Death Link", "description": "When you die, everyone who enabled death link dies. Of course, the reverse is true too.", "randomizable": true, "visibility": 15, "type": "Toggle", "default": false}], "collapsed": false}, {"name": "Item Pool", "options": [{"name": "local_dna", "display_name": "Local Metroid DNA", "description": "Minimum percentage of Metroid DNA that will be in your game", "randomizable": true, "visibility": 15, "type": "Range", "default": 0, "min": 0, "max": 100}, {"name": "shuffle_reserve_tanks", "display_name": "Shuffle Reserve Tanks", "description": "Include the Energy, Missile, and Aeion Reserve Tanks in the item pool.", "randomizable": true, "visibility": 15, "type": "Toggle", "default": false}, {"name": "starting_scan_pulse", "display_name": "Starting Scan Pulse", "description": "Start with Scan Pulse.", "randomizable": true, "visibility": 15, "type": "Toggle", "default": true}], "collapsed": false}, {"name": "Logic", "options": [{"name": "knowledge", "display_name": "Knowledge", "description": "Tricks that require knowledge of how the game works or offscreen portions of the map.", "randomizable": true, "visibility": 15, "type": "Choice", "default": 0, "choices": [{"name": "disable", "display_name": "Disable", "value": 0}, {"name": "simple", "display_name": "Simple", "value": 1}]}, {"name": "wall_jump", "display_name": "Wall Jump", "description": "Jump off of walls in midair.\n\nDisable: Wall jumping will not be required by logic\nSimple: Logic can expect wall jumping to high ledges and up shafts\nIntermediate: Logic can expect wall jumping into tight spaces", "randomizable": true, "visibility": 15, "type": "Choice", "default": 0, "choices": [{"name": "disable", "display_name": "Disable", "value": 0}, {"name": "simple", "display_name": "Simple", "value": 1}, {"name": "intermediate", "display_name": "Intermediate", "value": 2}]}, {"name": "super_jump", "display_name": "Super Jump", "description": "Double tap B when jumping up from the ground to gain extra height.\n\nBeginner: Simple jumps to get more height jumping straight up\nEasy: Start to tilt the stick on the second B press for a higher spin jump\nMedium: Tighter jumps that may also require morph extends", "randomizable": true, "visibility": 15, "type": "Choice", "default": 0, "choices": [{"name": "disable", "display_name": "Disable", "value": 0}, {"name": "beginner", "display_name": "Beginner", "value": 1}, {"name": "easy", "display_name": "Easy", "value": 2}, {"name": "medium", "display_name": "Medium", "value": 3}]}, {"name": "infinite_bomb_jump", "display_name": "Infinite Bomb Jump", "description": "Fly by bomb jumping in midair.\n\nDisable: Bomb jumping in midair will not be required by logic\nDouble: Bomb jump in midair once, usually unmorphing in midair to grab ledges\nVertical: Infinite bomb jump straight up to gain great height\nDiagonal: IBJ off the sides of bombs to fly at angles", "randomizable": true, "visibility": 15, "type": "Choice", "default": 0, "choices": [{"name": "disable", "display_name": "Disable", "value": 0}, {"name": "double", "display_name": "Double", "value": 1}, {"name": "vertical", "display_name": "Vertical", "value": 2}, {"name": "diagonal", "display_name": "Diagonal", "value": 3}]}, {"name": "morph_extends", "display_name": "Morph Extend", "description": "Midair morph and unmorph to extend your Power Grip range.\n\nEasy: Grab ledges that are just out of reach with other movement options\nMedium: Tighter extends including ones chained out of things like super jumps", "randomizable": true, "visibility": 15, "type": "Choice", "default": 0, "choices": [{"name": "disable", "display_name": "Disable", "value": 0}, {"name": "easy", "display_name": "Easy", "value": 1}, {"name": "medium", "display_name": "Medium", "value": 2}]}, {"name": "damage_boost", "display_name": "Damage Boost", "description": "Taking damage and knockback to gain distance, or otherwise deliberately as part of navigation.\n\nStatic: Hitting spikes, or brief contact with thorns and purple liquid.", "randomizable": true, "visibility": 15, "type": "Choice", "default": 0, "choices": [{"name": "disable", "display_name": "Disable", "value": 0}, {"name": "static", "display_name": "Static", "value": 1}]}, {"name": "movement", "dis
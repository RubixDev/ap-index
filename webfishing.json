{"name": "webfishing", "game": "WEBFISHING", "version": "0.0.0", "hidden": false, "groups": [{"name": "Game Options", "options": [{"name": "progression_balancing", "display_name": "Progression Balancing", "description": "A system that can move progression earlier, to try and prevent the player from getting stuck and bored early.\n\nA lower setting means more getting stuck. A higher setting means less getting stuck.", "randomizable": true, "visibility": 15, "type": "NamedRange", "default": 50, "min": 0, "max": 99, "presets": {"disabled": 0, "normal": 50, "extreme": 99}}, {"name": "accessibility", "display_name": "Accessibility", "description": "Set rules for reachability of your items/locations.\n\n**Full:** ensure everything can be reached and acquired.\n\n**Minimal:** ensure what is needed to reach your goal can be acquired.", "randomizable": true, "visibility": 15, "type": "Choice", "default": 0, "choices": [{"name": "full", "display_name": "Full", "value": 0}, {"name": "minimal", "display_name": "Minimal", "value": 2}]}, {"name": "goal", "display_name": "Goal", "description": "Total Journal Completion: Reach a specific percentage threshold in total journal completion\n(i.e. all fish, all rarities).\n\nRank: Reach a specific rank.\n\nCamp: Unlock all camp tiers and purchase the final tier.", "randomizable": true, "visibility": 15, "type": "Choice", "default": 0, "choices": [{"name": "total_completion", "display_name": "Total Completion", "value": 0}, {"name": "rank", "display_name": "Rank", "value": 1}, {"name": "camp", "display_name": "Camp", "value": 2}]}, {"name": "total_completion", "display_name": "Required Journal Percentage", "description": "The required total journal completion percentage for the Total Completion goal.", "randomizable": true, "visibility": 15, "type": "Range", "default": 60, "min": 1, "max": 100}, {"name": "rank", "display_name": "Required Rank", "description": "The required rank for the Rank goal.", "randomizable": true, "visibility": 15,
{"name": "inscryption", "game": "Inscryption", "version": "0.0.0", "hidden": false, "groups": [{"name": "Game Options", "options": [{"name": "progression_balancing", "display_name": "Progression Balancing", "description": "A system that can move progression earlier, to try and prevent the player from getting stuck and bored early.\n\nA lower setting means more getting stuck. A higher setting means less getting stuck.", "randomizable": true, "visibility": 15, "type": "NamedRange", "default": 50, "min": 0, "max": 99, "presets": {"disabled": 0, "normal": 50, "extreme": 99}}, {"name": "accessibility", "display_name": "Accessibility", "description": "Set rules for reachability of your items/locations.\n\n**Full:** ensure everything can be reached and acquired.\n\n**Minimal:** ensure what is needed to reach your goal can be acquired.", "randomizable": true, "visibility": 15, "type": "Choice", "default": 0, "choices": [{"name": "full", "display_name": "Full", "value": 0}, {"name": "minimal", "display_name": "Minimal", "value": 2}]}, {"name": "death_link", "display_name": "Death Link", "description": "When you die, everyone who enabled death link dies. Of course, the reverse is true too.", "randomizable": true, "visibility": 15, "type": "Toggle", "default": false}, {"name": "act1_death_link_behaviour", "display_name": "Act 1 Death Link Behaviour", "description": "If DeathLink is enabled, determines what counts as a death in act 1. This affects deaths sent and received.\n\n- Sacrificed: Send a death when sacrificed by Leshy. Receiving a death will extinguish all candles.\n\n- Candle Extinguished: Send a death when a candle is extinguished. Receiving a death will extinguish a candle.", "randomizable": true, "visibility": 15, "type": "Choice", "default": 0, "choices": [{"name": "sacrificed", "display_name": "Sacrificed", "value": 0}, {"name": "candle_extinguished", "display_name": "Candle Extinguished", "value": 1}]}, {"name": "goal", "display_name": "Goal", "description": "Defines the goal to accomplish in order to complete the randomizer.\n\n- Full Story In Order: Complete each act in order. You can return to previously completed acts.\n\n- Full Story Any Order: Complete each act in any order. All acts are available from the start.\n\n- First Act: Complete Act 1 by finding the New Game button. Great for a smaller scale randomizer.", "randomizable": true, "visibility": 15, "type": "Choice", "default": 0, "choices": [{"name": "full_story_in_order", "display_name": "Full Story In Order", "value": 0}, {"name": "full_story_any_order", "display_name": "Full Story Any Order", "value": 1}, {"name": "first_act", "display_name": "First Act", "value": 2}]}, {"name": "randomize_codes", "display_name": "Randomize Codes", "description": "Randomize codes and passwords in the game (clocks, safes, etc.)", "randomizable": true, "visibility": 15, "type": "Toggle", "default": false}, {"name": "randomize_deck", "display_name": "Randomize Deck", "description": "Randomize cards in your deck into new cards.\nDisable: Disable the feature.\n\n- Every Encounter Within Same Type: Randomize cards within the same type every encounter (keep rarity/scrybe type).\n\n- Every Encounter Any Type: Randomize cards into any possible card every encounter.\n\n- Starting Only: Only randomize cards given at the beginning of runs and acts.", "randomizable": true, "visibility": 15, "type": "Choice", "default": 0, "choices": [{"name": "disable", "display_name": "Disable", "value": 0}, {"name": "every_encounter_within_same_type", "display_name": "Every Encounter Within Same Type", "value": 1}, {"name": "every_encounter_any_type", "display_name": "Every Encounter Any Type", "value": 2}, {"name": "starting_only", "display_name": "Starting Only", "value": 3}]}, {"name": "randomize_sigils", "display_name": "Randomize Abilities", "description": "Randomize sigils printed on the cards into new sigils every encounter.\n\n- Disable: Disable the feature.\n\n- Randomize Addons: Only randomize sigils added from sacrifices or other means.\n\n- Randomize All: Randomize all sigils.", "randomizable": true, "visibility": 15, "type": "Choice", "default": 0, "choices": [{"name": "disable", "display_name": "Disable", "value": 0}, {"name": "randomize_addons", "display_name": "Randomize Addons", "value": 1}, {"name": "randomize_all", "display_name": "Randomize All", "value": 2}]}, {"name": "optional_death_card", "display_name": "Optional Death Card", "description": "Add a moment after death in act 1 where you can decide to create a death card or not.\n\n- Disable: Disable the feature.\n\n- Always On: The choice is always offered after losing all candles.\n\n- DeathLink Only: The choice is only offered after receiving a DeathLink event.", "randomizable": true, "visibility": 15, "type": "Choice", "default": 2, "choices": [{"name": "disable", "display_name": "Disable", "value": 0}, {"name": "always_on", "display_name": "Always On", "value": 1}, {"name": "deathlink_only", "display_name": "Deathlink Only", "value": 2}]}, {"name": "skip_tutorial", "display_name": "Skip Tutorial", "description": "Skips the first few tutorial runs of act 1. Bones are available from the start.", "randomizable": true, "visibility": 15, "type": "Toggle", "default": true}, {"name": "skip_epilogue", "display_name": "Skip Epilogue", "description": "Completes the goal as soon as the required acts are completed without the need of completing the epilogue.", "randomizable": true, "visibility": 15, "type": "Toggle", "default": false}, {"name": "epitaph_pieces_randomization", "display_name": "Epitaph Pieces Randomization", "description": "Determines how epitaph pieces in act 2 are randomized. This can affect your chances of getting stuck.\n\n- All Pieces: Randomizes all nine pieces as their own item.\n\n- In Groups: Randomizes pieces in groups of three.\n\n- As One Item: Group all nine pieces as a single item.", "randomizable": true, "visibility": 15, "type": "Choice", "default": 0, "choices": [{"name": "all_pieces", "display_name": "All Pieces", "value": 0}, {"name": "in_groups", "display_name": "In Groups", "value": 1}, {"name": "as_one_item", "display_name": "As One Item", "value": 2}]}, {"name": "painting_checks_balancing", "display_name": "Painting Checks Balancing", "description": "Generation options for the second and third painting checks in act 1.\n\n- None: Adds no progression logic to these painting checks. They will all count as sphere 1 (early game checks).\n\n- Balanced: Adds rules to these painting checks. Early game items are less likely to appear into these paintings.\n\n- Force Filler: For when you dislike doing these last two paintings. Their checks will only contain filler items.", "randomizable": true, "visibility": 15, "type": "Choice", "default": 1, "choices": [{"name": "none", "display_name": "None", "value": 0}, {"name": "balanced", "display_name": "Balanced", "value": 1}, {"name": "force_filler", "display_name": "Force Filler", "value": 2}]}], "collapsed": false}, {"name": "Item & Location Options", "options": [{"name": "local_items", "display_name": "Local Items", "description": "Forces these items to be in their native world.", "randomizable": false, "visibility": 15, "type": "OptionSet", "default": [], "options": ["Stinkbug Card", "Stunted Wolf Card", "Wardrobe Key", "Skink Card", "Ant Cards", "Caged Wolf Card", "Squirrel Totem Head", "Dagger", "Film Roll", "Ring", "Magnificus Eye", "Oil Painting's Clover Plant", "Extra Candle", "Bee Figurine", "Greater Smoke", "Angler Hook", "Camera Replica", "Pile Of Meat", "Epitaph Piece", "Epitaph Pieces", "Monocle", "Bone Lord Femur", "Bone Lord Horn", "Bone Lord Holo Key", "Mycologists Holo Key", "Ancient Obol", "Great Kraken Card", "Drowned Soul Card", "Salmon Card", "Dock's Clover Plant", "Extra Battery", "Nano Armor Generator", "Mrs. Bomb's Remote", "Inspectometer Battery", "Gems Module", "Lonely Wizbot Card", "Fishbot Card", "Ourobot Card", "Holo Pelt", "Quill", "Currency", "Card Pack", "
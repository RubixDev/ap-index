{"name": "hacknet", "game": "Hacknet", "version": "0.0.0", "hidden": false, "groups": [{"name": "Game Options", "options": [{"name": "progression_balancing", "display_name": "Progression Balancing", "description": "A system that can move progression earlier, to try and prevent the player from getting stuck and bored early.\n\nA lower setting means more getting stuck. A higher setting means less getting stuck.", "randomizable": true, "visibility": 15, "type": "NamedRange", "default": 50, "min": 0, "max": 99, "presets": {"disabled": 0, "normal": 50, "extreme": 99}}, {"name": "accessibility", "display_name": "Accessibility", "description": "Set rules for reachability of your items/locations.\n\n**Full:** ensure everything can be reached and acquired.\n\n**Minimal:** ensure what is needed to reach your goal can be acquired.", "randomizable": true, "visibility": 15, "type": "Choice", "default": 0, "choices": [{"name": "full", "display_name": "Full", "value": 0}, {"name": "minimal", "display_name": "Minimal", "value": 2}]}, {"name": "player_goal", "display_name": "Player Goal", "description": "What the player should achieve to reach their goal.\nHeartstopper: Vanilla ending, fulfill Bit's final request\nAltitude Loss: Labyrinths ending, any\nVeteran: Break into a super secret node\nVIP: Complete every Entropy and CSEC mission\nCompletionist: All of the above. Recommended for asyncs", "randomizable": true, "visibility": 15, "type": "Choice", "default": 1, "choices": [{"name": "heartstopper", "display_name": "Heartstopper", "value": 1}, {"name": "altitude_loss", "display_name": "Altitude Loss", "value": 2}, {"name": "veteran", "display_name": "Veteran", "value": 3}, {"name": "vip", "display_name": "Vip", "value": 4}, {"name": "completionist", "display_name": "Completionist", "value": 5}]}, {"name": "exclude_junebug", "display_name": "Exclude Project Junebug", "description": "If enabled, Project Junebug will not be marked as a location.\nIf \"Admin Access as Checks\" is enabled, this will also not mark Project Junebug nodes.\nRecommended for those easily triggered by sensitive topics.\nIf enabled while Shuffle Executables is disabled, KBTPortTest can be found in finale nodes.", "randomizable": true, "visibility": 15, "type": "Toggle", "default": false}, {"name": "shuffle_labs", "display_name": "Shuffle Labyrinths", "description": "Whether or not to shuffle Labyrinths content (missions, executables, etc.)\nIf player goal is set to Altitude Loss, Veteran, or Completionist, generation will throw an error if this is disabled.", "randomizable": true, "visibility": 15, "type": "Toggle", "default": true}, {"name": "enable_limits", "display_name": "Shuffle Limits", "description": "Whether or not to set limits on in-game mechanics, shuffling progressive limits into the item pool.\nEnable All: Set limits for shells (defaults to 1) and RAM.\nShells: Restricts how many shells you can have open at once. (Defaults to 1)\nShells Zero: Same as shells, but defaults to 0 instead of 1 shell. (Meaning, you can't open ANY shells from the start)\nRAM: Restricts your RAM to 300mb from the get-go. Progressive RAM adds 50mb each time it's received.\nDisabled: (Default) Don't set any limits.", "randomizable": true, "visibility": 15, "type": "Choice", "default": 5, "choices": [{"name": "enable_all", "display_name": "Enable All", "value": 1}, {"name": "shells", "display_name": "Shells", "value": 2}, {"name": "shells_zero", "display_name": "Shells Zero", "value": 3}, {"name": "ram", "display_name": "Ram", "value": 4}, {"name": "disabled", "display_name": "Disabled", "value": 5}]}, {"name": "shuffle_nodes", "display_name": "Admin Access as Checks", "description": "Adds admin access for EVERY ACCESSIBLE NODE as a check. This adds a LOT of locations. (~140 with DLC enabled) Recommended for asyncs.\nRespects \"Shuffle Labyrinths\"\n\n(Not yet implemented.)", "randomizable": true, "visibility": 15, "type": "Toggle", "default": false}, {"name": "max_mission_skips", "display_name": "Max. Amount of Mission Skips", "description": "The maximum amount of mission skips that should be shuffled into the item pool.\nMission skips allow you to skip any current mission.\nMission skips cannot be used on transition missions.\nMission skips cannot be used on finale missions.\nIf set to 0, no mission skips will be shuffled into the item pool.", "randomizable": true, "visibility": 15, "type": "Range", "default": 0, "min": 0, "max": 5}, {"name": "max_forcehacks", "display_name": "Max. Amount of ForceHacks", "description": "The maximum amount of forcehacks that should be shuffled into the item pool.\nForceHacks allow you to instantly gain admin access to most nodes. (With a few exceptions...)\nIf set to 0, no forcehacks will be shuffled into the item pool.", "randomizable": true, "visibility": 15, "type": "Range", "default": 0, "min": 0, "max": 10}], "collapsed": false}, {"name": "Executable Options", "options": [{"name": "shuffle_execs", "display_name": "Shuffle Executables", "description": "Shuffles executables into the item pool. The player can't do ANYTHING without these, pretty much.\nAny executable not shuffled can be found and downloaded in its vanilla location.\n\nShuffle All: Shuffle EVERY executable. Even the useless ones.\nProgression And Useful: Only shuffle progression and useful executables. (e.g., OpShell, ThemeChanger)\nProgression Only: Only shuffle progression executables. (e.g., FTPBounce, WebServerWorm)\nDisabled: Don't shuffle executables.\n\nThe finale sequencer executable is never shuffled.", "randomizable": true, "visibility": 15, "type": "Choice", "default": 1, "choices": [{"name": "shuffle_all", "display_name": "Shuffle All", "value": 1}, {"name": "progression_and_useful", "display_name": "Progression And Useful", "value": 2}, {"name": "progression_only", "display_name": "Progression Only", "value": 3}, {"name": "disabled", "display_name": "Disabled", "value": 4}]}, {"name": "sprint_replaces_bounce", "display_name": "FTPSprint Replaces FTPBounce", "description": "Completely removes FTPBounce from the item pool, replacing it with FTPSprint.\nIf disabled, FTPBounce and FTPSprint will be two different items in the item pool.\nThis ignores Shuffle Labyrinths.\nIf Shuffle Executables is set to Disabled, this does nothing.", "randomizable": true, "visibility": 15, "type": "Toggle", "default": true}, {"name": "start_with_ftp_and_ssh", "display_name": "Start with FTP & SSH Crushers", "description": "When shuffling executables, add FTPBounce and SSHCrack to starting inventory automatically.", "randomizable": true, "visibility": 15, "type": "Toggle", "default": true}, {"name": "exec_grouping", "display_name": "Executable Grouping", "description": "When shuffling executables, how should they be grouped?\nIf set to a value other than Individually, all executables will be shuffled, regardless of classification.\n\nIndividually: (Default) Every executable is its own item.\nRegional: Executables are grouped by region. (e.g., \"Labyrinths Executables\" is TorrentStreamInjector, SSLTrojan, etc.)\nPracticality: Executables are grouped by what they're used for. (e.g., Portcrushers, Aesthetics, etc.) Good for quick syncs.", "randomizable": true, "visibility": 15, "type": "Choice", "default": 1, "choices": [{"name": "individually", "display_name": "Individually", "value": 1}, {"name": "regional", "display_name": "Regional", "value": 2}, {"name": "practicality", "display_name": "Practicality", "value": 3}]}], "collapsed": false}, {"name": "Optional Checks", "options": [{"name": "shuffle_achvs", "display_name": "Shuffle Steam Achievements", "description": "If enabled, actions that usually unlock Steam achievements will be added as location checks.\n(\"Rude\" is excluded, as the player is automatically put onto the /el Sec path after defeating Naix.)\n(If the player misses Quickdraw, they can get it again by starting a new save file.)", "randomizable": true, "visibility": 15, "type": "Toggle", "default": false}, {"name": "shuffle_ptc", "display_name": "Shuffle PointClicker Upgrades", "description": "Adds PointClicker upgrades as checks and items.\nPointClicker upgrades only send a check the first time they're bought.\nThis adds ~51 location checks.\n\nBlock Upgrades: Every PointClicker upgrade is a check, but won't do anything when the player buys it.\nThis forces the player to rely on PointClicker Passive items being sent to them.\nOnly Checks: Every PointClicker upgrade is a check, and will actually upgrade when the player buys it.\nDisabled: (Default) Don't shuffle PointClicker, at all.", "randomizable": true, "visibility": 15, "type": "Choice", "default": 3, "choices": [{"name": "block_upgrades", "display_name": "Block Upgrades", "value": 1}, {"name": "only_checks", "display_name": "Only Checks", "value": 2}, {"name": "disabled", "display_name": "Disabled", "value": 3}]}, {"name": "faction_access", "display_name": "Shuffle Faction Access", "description": "If enabled, the player must first receive the respective Access for the faction before they can do missions for it. (Entropy, CSEC, Kaguya Trials)\nGood for asyncs!\n\nStarting Hints: Automatically hints access for each faction from the start of the run.", "randomizable": true, "visibility": 15, "type": "Choice", "default": 3, "choices": [{"name": "enabled", "display_name": "Enabled", "value": 1}, {"name": "starting_hints", "display_name": "Starting Hints", "value": 2}, {"name": "disabled", "display_name": "Disabled", "value": 3}]}], "collapsed": false}, {"name": "Trap Options", "options": [{"name": "trap_percentage", "display_name": "Trap Percentage (%)", "description": "What percentage of filler items should be traps. If set to 0, no traps will be shuffled into the item pool.", "randomizable": true, "visibility": 15, "type": "Range", "default": 10, "min": 0, "max": 100}, {"name": "enable_etas_traps", "display_name": "Enable ETAS Traps", "description": "If traps are enabled, shuffle ETAS traps. Automatically causes an ETAS to trigger.\nThese can be REALLY annoying, so they're off by default. Enable them if you like a challenge!", "randomizable": true, "visibility": 15, "type": "Toggle", "default": false}], "collapsed": false}, {"name": "DeathLink Options", "options": [{"name": "deathlink", "display_name": "Enable DeathLink", "description": "If enabled: whenever you are traced back or your in-game computer crashes, a deathlink is sent.\nDeathLinks are not sent for the crash caused by Striker. (But they are for Naix)\n\nA DeathLink in Hacknet will crash the player's (in-game) computer. If an ETAS is currently active, then the DeathLink is discarded.", "randomizable": true, "visibility": 15, "type": "Toggle", "default": false}], "collapsed": false}, {"name": "Item & Location Options", "options": [{"name": "local_items", "display_name": "Local Items", "description": "Forces these items to be in their native world.", "randomizable": false, "visibility": 15, "type": "OptionSet", "default": [], "options": ["FTPBounce", "SSHCrack", "WebServerWorm", "SMTPOverflow", "SQL_MemCorrupt", "KBTPortTest", "DEC Suite", "eosDeviceScan", "OpShell", "Tracekill", "ThemeChanger", "ClockEXE", "HexClock", "HacknetEXE", "Progressive Faction Access", "TorrentStreamInjector", "SSLTrojan", "FTPSprint", "Mem Suite", "PacificPortcrusher", "SignalScramble", "ComShell", "NetmapOrganizer", "DNotes", "Tuneswap", "ClockV2", "Progressive Shell Limit", "Progressive RAM", "Mission Skip", "ForceHack", "l33t hax0r skillz", "Random IRC Log", "PointClicker +50pt.", "PointClicker +500pt.", "PointClicker +5000pt.", "PointClicker +100pt./s", "PointClicker +1000pt./s", "PointClicker Passive*10", "PointClicker Passive*100", "PointClicker Passive*1000", "ETAS Trap", "Fake Connection", "Reset PointClicker Points", "ForkBomb", "Intro Executable Pack", "Entropy Executable Pack", "CSEC Executable Pack", "Labyrinths Executable Pack", "Finale Executable Pack", "Portcrusher Pack", "Labyrinths Portcrusher Pack", "Clock Pack", "M
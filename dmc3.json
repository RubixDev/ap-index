{"name": "dmc3", "game": "Devil May Cry 3", "version": "0.5.1", "hidden": false, "groups": [{"name": "Game Options", "options": [{"name": "progression_balancing", "display_name": "Progression Balancing", "description": "A system that can move progression earlier, to try and prevent the player from getting stuck and bored early.\n\nA lower setting means more getting stuck. A higher setting means less getting stuck.", "randomizable": true, "visibility": 15, "type": "NamedRange", "default": 50, "min": 0, "max": 99, "presets": {"disabled": 0, "normal": 50, "extreme": 99}}, {"name": "accessibility", "display_name": "Accessibility", "description": "Set rules for reachability of your items/locations.\n\n**Full:** ensure everything can be reached and acquired.\n\n**Minimal:** ensure what is needed to reach your goal can be acquired.", "randomizable": true, "visibility": 15, "type": "Choice", "default": 0, "choices": [{"name": "full", "display_name": "Full", "value": 0}, {"name": "minimal", "display_name": "Minimal", "value": 2}]}, {"name": "random_adjudicators", "display_name": "Randomize Adjudicators", "description": "Randomizes Adjudicators in the game, changing their required weapon type", "randomizable": true, "visibility": 15, "type": "Toggle", "default": false}, {"name": "adjudicator_rankings", "display_name": "Max Rando. Adjudicator Rank (Inclusive)", "description": "Set the max style rank for randomized adjudicators.\n\nLeave at default to not change them (I can't recommend SS or SSS)", "randomizable": true, "visibility": 15, "type": "Choice", "default": 0, "choices": [{"name": "unchanged", "display_name": "Unchanged", "value": 0}, {"name": "c_rank", "display_name": "C Rank", "value": 2}, {"name": "b_rank", "display_name": "B Rank", "value": 3}, {"name": "a_rank", "display_name": "A Rank", "value": 4}, {"name": "s_rank", "display_name": "S Rank", "value": 5}, {"name": "ss_rank", "display_name": "SS Rank", "value": 6}, {"name": "sss_rank", "display_name": "SSS Rank", "value": 7}]}, {"name": "start_melee", "display_name": "Starting Melee", "description": "Set your starting melee weapon", "randomizable": true, "visibility": 15, "type": "Choice", "default": 0, "choices": [{"name": "rebellion", "display_name": "Rebellion", "value": 0}, {"name": "cerberus", "display_name": "Cerberus", "value": 1}, {"name": "agni_and_rudra", "display_name": "Agni And Rudra", "value": 2}, {"name": "nevan", "display_name": "Nevan", "value": 3}, {"name": "beowulf", "display_name": "Beowulf", "value": 4}]}, {"name": "start_second_melee", "display_name": "Starting Second Melee", "description": "Set your second starting melee weapon", "randomizable": true, "visibility": 15, "type": "Choice", "default": 255, "choices": [{"name": "rebellion", "display_name": "Rebellion", "value": 0}, {"name": "cerberus", "display_name": "Cerberus", "value": 1}, {"name": "agni_and_rudra", "display_name": "Agni And Rudra", "value": 2}, {"name": "nevan", "display_name": "Nevan", "value": 3}, {"name": "beowulf", "display_name": "Beowulf", "value": 4}, {"name": "none", "display_name": "None", "value": 255}]}, {"name": "start_gun", "display_name": "Starting Gun", "description": "Set your starting gun", "randomizable": true, "visibility": 15, "type": "Choice", "default": 5, "choices": [{"name": "ebony_and_ivory", "display_name": "Ebony And Ivory", "value": 5}, {"name": "shotgun", "display_name": "Shotgun", "value": 6}, {"name": "artemis", "display_name": "Artemis", "value": 7}, {"name": "spiral", "display_name": "Spiral", "value": 8}, {"name": "kalina_ann", "display_name": "Kalina Ann", "value": 9}]}, {"name": "start_second_gun", "display_name": "Starting Second Gun", "description": "Set your starting gun", "randomizable": true, "visibility": 15, "type": "Choice", "default": 255, "choices": [{"name": "ebony_and_ivory", "display_name": "Ebony And Ivory", "value": 5}, {"name": "shotgun", "display_name": "Shotgun", "value": 6}, {"name": "artemis", "display_name": "Artemis", "value": 7}, {"name": "spiral", "display_name": "Spiral", "value": 8}, {"name": "kalina_ann", "display_name": "Kalina Ann", "value": 9}, {"name": "none", "display_name": "None", "value": 255}]}, {"name": "randomize_skills", "display_name": "Randomize Skills", "description": "Should weapon skills be items?", "randomizable": true, "visibility": 15, "type": "Toggle", "default": false}, {"name": "randomize_gun_levels", "display_name": "Randomize Gun Levels", "description": "Should gun levels be items?", "randomizable": true, "visibility": 15, "type": "Toggle", "default": false}, {"name": "death_link", "display_name": "Death Link", "description": "**DeathLink**: Standard DeathLink behavior.\n\n**HurtLink**: Sends DeathLink messages out when you die. But any received DeathLink's will cause (Difficulty Dependent) damage rather than insta kill.\n\n**None**: No death link features will be enabled", "randomizable": true, "visibility": 15, "type": "Choice", "default": 0, "choices": [{"name": "none", "display_name": "None", "value": 0}, {"name": "deathlink", "display_name": "Deathlink", "value": 1}, {"name": "hurtlink", "display_name": "Hurtlink", "value": 2}]}, {"name": "randomize_styles", "display_name": "Randomize Styles", "description": "Add Dante's styles into the world as progressive upgrades. The starting style will be chosen at random unless one is specified via start inventory", "randomizable": true, "visibility": 15, "type": "Toggle", "default": false}, {"name": "purple_orb_mode", "display_name": "Purple Orb Mode", "description": "On: 10 Purple orbs will be added to the item pool (DT Item will be worth 0 runes if it is in the item pool)\n\nOff: 7 Purple orbs will be added to the item pool as well as the Devil Trigger Item (Worth 3 DT Runes)", "randomizable": true, "visibility": 15, "type": "Toggle", "default": false}, {"name": "devil_trigger_mode", "display_name": "Devil Trigger Mode", "description": "**On**: Devil Trigger item will be needed to access Devil Trigger (DT Item will be added to the item pool)\n\n**Off**: Devil Trigger will be accessible upon reaching 3 runes", "randomizable": true, "visibility": 15, "type": "Toggle", "default": false}, {"name": "initially_unlocked_difficulties", "display_name": "Initially Unlocked Difficulties", "description": "What difficulties are unlocked when starting a new game (Normal is unlocked by default)", "randomizable": false, "visibility": 15, "type": "OptionSet", "default": ["Dante Must Die", "Hard", "Very Hard", "Easy", "Heaven or Hell"], "options": ["Dante Must Die", "Easy", "Hard", "Heaven or Hell", "Very Hard"]}, {"name": "goal", "display_name": "Goal", "description": "Which goal setting to use:\n\n**Standard**: Beat M20 in linear order M1-M20\n\n**All**: Beat all missions, all are unlocked at start\n\n**Random Order**: Beat all missions in a random linear order", "randomizable": true, "visibility": 15, "type": "Choice", "default": 0, "choices": [{"name": "standard", "display_name": "Standard", "value": 0}, {"name": "all", "display_name": "All", "value": 1}, {"name": "random_order", "display_name": "Random Order", "value": 2}]}], "collapsed": false}, {"name": "Shop Options", "options": [{"name": "shop_orb_checks", "display_name": "Orb Checks", "description": "Add checks to the store.\n\nThis includes both Blue and Purple Orbs", "randomizable": true, "visibility": 15, "type": "Toggle", "default": false}, {"name": "shop_gun_checks", "display_name": "Gun Store Checks", "description": "Purchasing gun levels will send out checks\n\nYou will need the specific gun for the checks", "randomizable": true, "visibility": 15, "type": "Toggle", "default": false}, {"name": "auto_orb_hints", "display_name": "Auto Orb Hints", "description": "What types of hints should be automatically created\n\n* All will auto hint all orb purchases\n* None will result in no hints", "randomizable": true, "visibility": 15, "type": "Choice", "default": 0, "choices": [{"name": "all", "display_name": "All", "value": 0}, {"name": "none", "display_name": "None", "value": 3}]}, {"name": "auto_gun_hints", "display_name": "Auto Gun Hints", "description": "Gun Level Auto hinting behavior\n\n* All: All gun level checks will be auto-hinted\n* Obtained: Hint all levels when the gun is obtained\n* None: No automatic hinting", "randomizable": true, "visibility": 15, "type": "Choice", "default": 0, "choices": [{"name": "all", "display_name": "All", "value": 0}, {"name": "obtained", "display_name": "Obtained", "value": 2}, {"name": "none", "display_name": "None", "value": 3}]}], "collapsed": false}, {"name": "Mission Options", "options": [{"name": "mission_clear_rank", "display_name": "Minimum Mission Clear Rank", "description": "What minimum rank is needed to give a mission's completed check.\n\n**D** will be any and all ranks\n\n**C, B, A, S** are self-explanatory\n\n**SS** is a perfect S rank, all sub ranks must be S as well. (Only choose this if you are confident in your abilities)", "randomizable": true, "visibility": 15, "type": "Choice", "default": 0, "choices": [{"name": "d_rank", "display_name": "D Rank", "value": 0}, {"name": "c_rank", "display_name": "C Rank", "value": 1}, {"name": "b_rank", "display_name": "B Rank", "value": 2}, {"name": "a_rank", "display_name": "A Rank", "value": 3}, {"name": "s_rank", "display_name": "S Rank", "value": 4}, {"name": "ss_rank", "display_name": "SS Rank", "value": 5}]}, {"name": "mission_clear_difficulty", "display_name": "Minimum Required Mission Clear Difficulty", "description": "What minimum difficulty is needed to give a mission's completed check.", "randomizable": true, "visibility": 15, "type": "Choice", "default": 0, "choices": [{"name": "easy", "display_name": "Easy", "value": 0}, {"name": "normal", "display_name": "Normal", "value": 1}, {"name": "hard", "display_name": "Hard", "value": 2}, {"name": "very_hard", "display_name": "Very Hard", "value": 3}, {"name": "dante_must_die", "display_name": "Dante Must Die", "value": 4}, {"name": "heaven_or_hell", "display_name": "Heaven Or Hell", "value": 5}]}, {"name": "enabled_ss_rank", "display_name": "Enable SS Rank Checks", "description": "If the SS Rank checks are added to the multiworld", "randomizable": true, "visibility": 15, "type": "Toggle", "default": false}, {"name": "useful_ss_checks", "display_name": "Useful SS Rank Goodies", "description": "Allow excluded SS Rank Mission Clears to have useful items and not just filler", "randomizable": true, "visibility": 15, "type": "Toggle", "default": false}, {"name": "check_ss_difficulty", "display_name": "SS Ranks Check Minimum Difficulty", "description": "If SS Rank checks also check to see if you are on the minimum difficulty", "randomizable": true, "visibility": 15, "type": "Toggle", "default": false}, {"name": "mission_shuffle", "display_name": "Mission Order Setting", "description": "**Grouped**: All 20 missions are divided into blocks of N missions. The order of these blocks is then randomized\n\n**Pure RNG**: Leave it all up to chance. You may get Mission #1 as your first, or you may get Mission #20.\nNot recommended for Synchronous games.\n\n**Weighted**: Mission order is based on the provided weights", "randomizable": true, "visibility": 15, "type": "Choice", "default": 1, "choices": [{"name": "weighted", "display_name": "Weighted", "value": 0}, {"name": "grouped", "display_name": "Grouped", "value": 1}, {"name": "rng", "display_name": "RNG", "value": 2}]}, {"name": "mission_weights", "display_name": "Mission Order Weights", "description": "Mission weight setting for the weighted mission order option\n\nBigger number means it's more likely to be picked near the beginning. Smaller number means it has less of a chance of being picked.\n\n(If you don't know what to do, leave this alone)", "randomizable": false, "visibility": 15, "type": "OptionCounter", "default": {"Mission #1": 30, "Mission #2": 30, "Mission #3": 20, "Mission #4": 20, "Mission #5": 20, "Mission #6": 20, "Mission #7": 10, "Mission #8": 20, "M
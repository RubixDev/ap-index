{"name": "wlkrr", "game": "We Love Katamari Reroll", "version": "0.1.0", "hidden": false, "groups": [{"name": "Game Options", "options": [{"name": "progression_balancing", "display_name": "Progression Balancing", "description": "A system that can move progression earlier, to try and prevent the player from getting stuck and bored early.\n\nA lower setting means more getting stuck. A higher setting means less getting stuck.", "randomizable": true, "visibility": 15, "type": "NamedRange", "default": 50, "min": 0, "max": 99, "presets": {"disabled": 0, "normal": 50, "extreme": 99}}, {"name": "accessibility", "display_name": "Accessibility", "description": "Set rules for reachability of your items/locations.\n\n**Full:** ensure everything can be reached and acquired.\n\n**Minimal:** ensure what is needed to reach your goal can be acquired.", "randomizable": true, "visibility": 15, "type": "Choice", "default": 0, "choices": [{"name": "full", "display_name": "Full", "value": 0}, {"name": "minimal", "display_name": "Minimal", "value": 2}]}], "collapsed": false}, {"name": "Gameplay Options", "options": [{"name": "starting_level", "display_name": "Starting Level", "description": "What fan do you start the game with?", "randomizable": true, "visibility": 15, "type": "Choice", "default": 6, "choices": [{"name": "rainbow_girl", "display_name": "Rainbow Girl", "value": 0}, {"name": "lazybones", "display_name": "Lazybones", "value": 1}, {"name": "grandpa", "display_name": "Grandpa", "value": 2}, {"name": "grandma", "display_name": "Grandma", "value": 3}, {"name": "bird_and_elephant", "display_name": "Bird And Elephant", "value": 4}, {"name": "soccer_kid", "display_name": "Soccer Kid", "value": 6}, {"name": "ikebana_teacher", "display_name": "Ikebana Teacher", "value": 7}, {"name": "substitute_teacher", "display_name": "Substitute Teacher", "value": 8}, {"name": "f1_racer", "display_name": "F1 Racer", "value": 9}, {"name": "rain_coat_girl", "display_name": "Rain Coat Girl", "value": 10}, {"name": "dr_katamari", "display_name": "Dr Katamari", "value": 11}, {"name": "crane_hat_boy", "display_name": "Crane Hat Boy", "value": 12}, {"name": "just_right_girl", "display_name": "Just Right Girl", "value": 13}, {"name": "cowbear_farmer", "display_name": "Cowbear Farmer", "value": 14}, {"name": "excited_baby", "display_name": "Excited Baby", "value": 15}, {"name": "cleanly_mom", "display_name": "Cleanly Mom", "value": 16}, {"name": "fund_raiser", "display_name": "Fund Raiser", "value": 17}, {"name": "hansel_and_gretel", "display_name": "Hansel And Gretel", "value": 18}, {"name": "float_boy", "display_name": "Float Boy", "value": 19}, {"name": "camper_man", "display_name": "Camper Man", "value": 20}, {"name": "mini_sumo", "display_name": "Mini Sumo", "value": 21}, {"name": "snow_child", "display_name": "Snow Child", "value": 22}, {"name": "book_worm", "display_name": "Book Worm", "value": 23}, {"name": "tomio_hoshino", "display_name": "Tomio Hoshino", "value": 26}]}, {"name": "enable_shooting_stars", "display_name": "Enable Shooting Stars", "description": "Completing any of the main levels with exceptional speed causes a star to shoot down from the sky.\nWith this enabled, creating these shooting stars sends out checks.\n\nAdds 10 checks.", "randomizable": true, "visibility": 15, "type": "Toggle", "default": false}, {"name": "enable_super_clears", "display_name": "Enable Super Clears", "description": "Exceeding the fans expectations counts as a super clear!\nWith this enabled, receiving this praise from the King and the Fans sends out a check.\n\n'disabled' turns off super clears\n\n'base_level' enables the easier to complete base super clears in the game.\nThis includes size requirements, simple collection levels, and automatic successes. Adds 19 checks\n\n'challenging' enables base_level checks as well as more challenging super clears.\nThis includes speed requirements and more difficult and complex collection level requirements. Adds 32 checks\n\n'difficult' enables base_level checks, challenging checks, as well as the most difficult super clears, requiring the most dedication to complete.\nThis includes the Cowbear, Cranes, the Just-Right stages, and very hard speed challenges. Adds 40 Checks", "randomizable": true, "visibility": 15, "type": "Choice", "default": 0, "choices": [{"name": "disabled", "display_name": "Disabled", "value": 0}, {"name": "base_level", "display_name": "Base Level", "value": 1}, {"name": "challenging", "display_name": "Challenging", "value": 2}, {"name": "difficult", "display_name": "Difficult", "value": 3}]}, {"name": "enable_alternative_cousin_logic", "display_name": "Enable Alternative Cousin Logic", "description": "Some cousins, when collected, appear in other stages aside from the stage they were collected.\nLike Kinoko and Miso in the Sumo levels, or The Prince in As Large As Possible 1.\nEnabling this option allows for those cousins to be considered in logic, and opens them all up throughout the game!\n\nNOTE: Due to every cousin technically being collectible in ALAP5/AFAP5, the checks will be disabled within those levels specifically.", "randomizable": true, "visibility": 15, "type": "Toggle", "default": false}], "collapsed": false}, {"name": "Cosmetic Options", "options": [{"name": "cousin_amount", "display_name": "Cousin Amount", "description": "How many cousins should be randomized into the item pool?\n\nNOTE: Due to Ace being required to roll up Slip in the tutorial, Ace will always be included in this pool.", "randomizable": true, "visibility": 15, "type": "Range", "default": 15, "min": 1, "max": 39}, {"name": "present_amount", "display_name": "Present Amount", "description": "How many presents should be randomized into the item pool?", "randomizable": true, "visibility": 15, "type": "Range", "default": 10, "min": 1, "max": 32}], "collapsed": false}, {"name": "Item & Location Options", "options": [{"name": "local_items", "display_name": "Local Items", "description": "Forces 
{"name": "axiomverge", "game": "Axiom Verge", "version": "0.0.0", "hidden": false, "groups": [{"name": "Game Options", "options": [{"name": "progression_balancing", "display_name": "Progression Balancing", "description": "A system that can move progression earlier, to try and prevent the player from getting stuck and bored early.\n\nA lower setting means more getting stuck. A higher setting means less getting stuck.", "randomizable": true, "visibility": 15, "type": "NamedRange", "default": 50, "min": 0, "max": 99, "presets": {"disabled": 0, "normal": 50, "extreme": 99}}, {"name": "accessibility", "display_name": "Accessibility", "description": "Set rules for reachability of your items/locations.\n\n**Full:** ensure everything can be reached and acquired.\n\n**Minimal:** ensure what is needed to reach your goal can be acquired.", "randomizable": true, "visibility": 15, "type": "Choice", "default": 0, "choices": [{"name": "full", "display_name": "Full", "value": 0}, {"name": "minimal", "display_name": "Minimal", "value": 2}]}, {"name": "allow_displacement_warps", "display_name": "allow_displacement_warps", "description": "Allows for displacement warps to be considered in logic.", "randomizable": true, "visibility": 15, "type": "Toggle", "default": false}, {"name": "allow_flight", "display_name": "allow_flight", "description": "Allows for flying to be considered in logic.", "randomizable": true, "visibility": 15, "type": "Toggle", "default": false}, {"name": "allow_floor_grapple_clips", "display_name": "allow_floor_grapple_clips", "description": "Allows for grapple clips through floors to be considered in logic.", "randomizable": true, "visibility": 15, "type": "Toggle", "default": false}, {"name": "allow_roof_grapple_clips", "display_name": "allow_roof_grapple_clips", "description": "Allows for upwards coat dashes with grapple to be considered in logic.", "randomizable": true, "visibility": 15, "type": "Toggle", "default": false}, {"name": "allow_rocket_jumps", "display_name": "allow_rocket_jumps", "description": "Allows for rocket jumps to be considered in logic.", "randomizable": true, "visibility": 15, "type": "Choice", "default": 0, "choices": [{"name": "off", "display_name": "Off", "value": 0}, {"name": "brown", "display_name": "Brown", "value": 1}, {"name": "red", "display_name": "Red", "value": 2}, {"name": "both", "display_name": "Both", "value": 3}]}, {"name": "allow_wall_grapple_clips", "display_name": "allow_wall_grapple_clips", "description": "Allows for grapple clips through 1 width walls to be considered in logic.\n\nSwing: Include all 5 height walls (Extend grapple and swing to clip through wall)\nAll: Include walls of any height", "randomizable": true, "visibility": 15, "type": "Choice", "default": 0, "choices": [{"name": "off", "display_name": "Off", "value": 0}, {"name": "swing", "display_name": "Swing", "value": 1}, {"name": "all", "display_name": "All", "value": 2}]}, {"name": "allow_obscure_skips", "display_name": "allow_obscure_skips", "description": "Allow for unintended/difficult to find progression paths.\n\nFor example, using coats to pass bomb checks, or grappling along an uneven roof.", "randomizable": true, "visibility": 15, "type": "Toggle", "default": false}, {"name": "goal", "display_name": "Goal", "description": "Victory condition.", "randomizable": true, "visibility": 15, "type": "Choice", "default": 0, "choices": [{"name": "athetos", "display_name": "Athetos", "value": 0}, {"name": "boss_rush", "display_name": "Boss Rush", "value": 1}]}, {"name": "progressive_address_disruptor", "display_name": "progressive_address_disruptor", "description": "Combine Address Disruptors into a single progressive upgrade.", "randomizable": true, "visibility": 15, "type": "Toggle", "default": false}, {"name": "progressive_coat", "display_name": "Progressive Coat Upgrades", "description": "Combine Coat upgrades into a single progressive upgrade. Lab -> Trench -> Red.", "randomizable": true, "visibility": 15, "type"
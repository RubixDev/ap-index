{"name": "shorthike", "game": "A Short Hike", "version": "0.0.0", "hidden": false, "groups": [{"name": "Game Options", "options": [{"name": "progression_balancing", "display_name": "Progression Balancing", "description": "A system that can move progression earlier, to try and prevent the player from getting stuck and bored early.\n\nA lower setting means more getting stuck. A higher setting means less getting stuck.", "randomizable": true, "visibility": 15, "type": "NamedRange", "default": 50, "min": 0, "max": 99, "presets": {"disabled": 0, "normal": 50, "extreme": 99}}, {"name": "accessibility", "display_name": "Accessibility", "description": "Set rules for reachability of your items/locations.\n\n**Full:** ensure everything can be reached and acquired.\n\n**Minimal:** ensure what is needed to reach your goal can be acquired.", "randomizable": true, "visibility": 15, "type": "Choice", "default": 0, "choices": [{"name": "full", "display_name": "Full", "value": 0}, {"name": "minimal", "display_name": "Minimal", "value": 2}]}], "collapsed": false}, {"name": "General Options", "options": [{"name": "goal", "display_name": "Goal", "description": "Choose the end goal.\nNap: Complete the climb to the top of Hawk Peak and take a nap\nPhoto: Get your picture taken at the top of Hawk Peak\nRaces: Complete all three races with Avery\nHelp Everyone: Travel around Hawk Peak and help every character with their troubles\nFishmonger: Catch one of every fish from around Hawk Peak", "randomizable": true, "visibility": 15, "type": "Choice", "default": 3, "choices": [{"name": "nap", "display_name": "Nap", "value": 0}, {"name": "photo", "display_name": "Photo", "value": 1}, {"name": "races", "display_name": "Races", "value": 2}, {"name": "help_everyone", "display_name": "Help Everyone", "value": 3}, {"name": "fishmonger", "display_name": "Fishmonger", "value": 4}]}, {"name": "filler_coin_amount", "display_name": "Coins per Filler Item", "description": "The number of coins that will be in each filler coin item.", "randomizable": true, "visibility": 15, "type": "Choice", "default": 1, "choices": [{"name": "7_coins", "display_name": "7 Coins", "value": 0}, {"name": "13_coins", "display_name": "13 Coins", "value": 1}, {"name": "15_coins", "display_name": "15 Coins", "value": 2}, {"name": "18_coins", "display_name": "18 Coins", "value": 3}, {"name": "21_coins", "display_name": "21 Coins", "value": 4}, {"name": "25_coins", "display_name": "25 Coins", "value": 5}, {"name": "27_coins", "display_name": "27 Coins", "value": 6}, {"name": "32_coins", "display_name": "32 Coins", "value": 7}, {"name": "33_coins", "display_name": "33 Coins", "value": 8}, {"name": "50_coins", "display_name": "50 Coins", "value": 9}]}, {"name": "random_walkie_talkie", "display_name": "Randomize Walkie Talkie", "description": "When enabled, the Walkie Talkie item will be placed into the item pool. Otherwise, it will be placed in its vanilla location.\nThis item usually allows the player to locate Avery around the map or restart a race.", "randomizable": true, "visibility": 15, "type": "Toggle", "default": true}], "collapsed": false}, {"name": "Logic Options", "options": [{"name": "golden_feather_progression", "display_name": "Golden Feather Progression", "description": "Determines which locations are considered in logic based on the required amount of golden feathers to reach them.\nEasy: Locations will be considered inaccessible until the player has enough golden feathers to easily reach them. A minimum of 10 golden feathers is recommended for this setting.\nNormal: Locations will be considered inaccessible until the player has the minimum possible number of golden feathers to reach them. A minimum of 7 golden feathers is recommended for this setting.\nHard: Removes the requirement of golden feathers for progression entirely and glitches may need to be used to progress", "randomizable": true, "visibility": 15, "type": "Choice", "default": 1, "choices": [{"name": "easy", "display_name": "Easy", "value": 0}, {"name": "normal", "display_name": "Normal", "value": 1}, {"name": "hard", "display_name": "Hard", "value": 2}]}, {"name": "easier_races", "display_name": "Easier Races", "description": "When enabled, the Running Shoes will be added as a logical requirement for beating any of the races.", "randomizable": true, "visibility": 15, "type": "Toggle", "default": false}], "collapsed": false}, {"name": "Item Pool Options", "options": [{"name": "golden_feathers", "display_name": "Golden Feathers", "description": "Number of Golden Feathers in the item pool.\n(Note that for the Photo and Help Everyone goals, a minimum of 12 Golden Feathers is enforced)", "randomizable": true, "visibility": 15, "type": "Range", "default": 20, "min": 0, "max": 20}, {"name": "silver_feathers", "display_name": "Silver Feathers", "description": "Number of Silver Feathers in the item pool.", "randomizable": true, "visibility": 15, "type": "Range", "default": 2, "min": 0, "max": 20}, {"name": "buckets", "display_name": "Buckets", "description": "Number of Buckets in the item pool.", "randomizable": true, "visibility": 15, "type": "Range", "default": 2, "min": 0, "max": 2}, {"name": "sticks", "display_name": "Sticks", "description": "Number of Sticks in the item pool.", "randomizable": true, "visibility": 15, "type": "Range", "default": 8, "min": 1, "max": 8}, {"name": "toy_shovels", "display_name": "Toy Shovels", "description": "Number of Toy Shovels in the item pool.", "randomizable": true, "visibility": 15, "type": "Range", "default": 5, "min": 1, "max": 5}], "collapsed": false}, {"name": "Shop Options", "options": [{"name": "coins_in_shops", "display_name": "Coins in Purchaseable Locations", "description": "When enabled, the randomizer can place coins into locations that are purchased, such as shops.", "randomizable": true, "visibility": 15, "type": "Toggle", "default": false}, {"name": "cost_multiplier", "display_name": "Shop Cost Multiplier", "description": "The percen
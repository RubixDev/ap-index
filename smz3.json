{"name": "smz3", "game": "SMZ3", "version": "0.0.0", "hidden": false, "groups": [{"name": "Game Options", "options": [{"name": "progression_balancing", "display_name": "Progression Balancing", "description": "A system that can move progression earlier, to try and prevent the player from getting stuck and bored early.\n\nA lower setting means more getting stuck. A higher setting means less getting stuck.", "randomizable": true, "visibility": 15, "type": "NamedRange", "default": 50, "min": 0, "max": 99, "presets": {"disabled": 0, "normal": 50, "extreme": 99}}, {"name": "accessibility", "display_name": "Accessibility", "description": "Set rules for reachability of your items/locations.\n\n**Full:** ensure everything can be reached and acquired.\n\n**Minimal:** ensure what is needed to reach your goal can be acquired.\n\n**Items:** ensure all logically relevant items can be acquired. Some items, such as keys, may be self-locking, and\nsome locations may be inaccessible.", "randomizable": true, "visibility": 15, "type": "Choice", "default": 1, "choices": [{"name": "full", "display_name": "Full", "value": 0}, {"name": "minimal", "display_name": "Minimal", "value": 2}, {"name": "items", "display_name": "Items", "value": 1}]}, {"name": "sm_logic", "display_name": "SMLogic", "description": "This option selects what kind of logic to use for item placement inside\nSuper Metroid.\n\nNormal - Normal logic includes only what Super Metroid teaches players\nitself. Anything that's not demonstrated in-game or by the intro cutscenes\nwill not be required here.\n\nHard - Hard logic is based upon the \"no major glitches\" ruleset and\nincludes most tricks that are considered minor glitches, with some \nrestrictions. You'll want to be somewhat of a Super Metroid veteran for\nthis logic.\n\nSee https://samus.link/information for required moves.", "randomizable": true, "visibility": 15, "type": "Choice", "default": 0, "choices": [{"name": "normal", "display_name": "Normal", "value": 0}, {"name": "hard", "display_name": "Hard", "value": 1}]}, {"name": "sword_location", "display_name": "Sword Location", "description": "This option decides where the first sword will be placed.\nRandomized - The sword can be placed anywhere.\nEarly - The sword will be placed in a location accessible from the start of\nthe game.\nUncle - The sword will always be placed on Link's Uncle.", "randomizable": true, "visibility": 15, "type": "Choice", "default": 0, "choices": [{"name": "randomized", "display_name": "Randomized", "value": 0}, {"name": "early", "display_name": "Early", "value": 1}, {"name": "uncle", "display_name": "Uncle", "value": 2}]}, {"name": "morph_location", "display_name": "Morph Location", "description": "This option decides where the morph ball will be placed.\nRandomized - The morph ball can be placed anywhere.\nEarly - The morph ball will be placed in a location accessible from the \nstart of the game.\nOriginal location - The morph ball will always be placed at its original \nlocation.", "randomizable": true, "visibility": 15, "type": "Choice", "default": 0, "choices": [{"name": "randomized", "display_name": "Randomized", "value": 0}, {"name": "early", "display_name": "Early", "value": 1}, {"name": "original", "display_name": "Original", "value": 2}]}, {"name": "goal", "display_name": "Goal", "description": "This option decides what goal is required to finish the randomizer.\nDefeat Ganon and Mother Brain - Find the required crystals and boss tokens to kill both bosses.\nFast Ganon and Defeat Mother Brain - The hole to ganon is open without having to defeat Agahnim in \n                                     Ganon's Tower and Ganon can be defeat as soon you have the required \n                                     crystals to make Ganon vulnerable. For keysanity, this mode also removes \n                                     the Crateria Boss Key requirement from Tourian to allow faster access.\nAll Dungeons and Defeat Mother Brain -  Similar to \"Defeat Ganon and Mother Brain\", but also requires all dungeons \n                                        to be beaten including Castle Tower and Agahnim.", "randomizable": true, "visibility": 15, "type": "Choice", "default": 0, "choices": [{"name": "defeatboth", "display_name": "Defeatboth", "value": 0}, {"name": "fastganondefeatmotherbrain", "display_name": "Fastganondefeatmotherbrain", "value": 1}, {"name": "alldungeonsdefeatmotherbrain", "display_name": "Alldungeonsdefeatmotherbrain", "value": 2}]}, {"name": "key_shuffle", "display_name": "Key Shuffle", "description": "This option decides how dungeon items such as keys are shuffled.\nNone - A Link to the Past dungeon items can only be placed inside the \ndungeon they belong to, and there are no changes to Super Metroid.\nKeysanity - See https://samus.link/information", "randomizable": true, "visibility": 15, "type": "Choice", "default": 0, "choices": [{"name": "none", "display_name": "None", "value": 0}, {"name": "keysanity", "display_name": "Keysanity", "value": 1}]}, {"name": "open_tower", "display_name": "Open Tower", "description": "The amount of crystals required to be able to enter Ganon's Tower. \nIf this is set to Random, the amount can be found in-game on a sign next to Ganon's Tower.", "randomizable": true, "visibility": 15, "type": "Range", "default": 7, "min": 0, "max": 7}, {"name": "ganon_vulnerable", "display_name": "Ganon Vulnerable", "description": "The amount of crystals required to be able to harm Ganon. The amount can be found \nin-game on a sign near the top of the Pyramid.", "randomizable": true, "visibility": 15, "type": "Range", "default": 7, "min": 0, "max": 7}, {"name": "open_tourian", "display_name": "Open Tourian", "description": "The amount of boss tokens required to enter Tourian. The amount can be found in-game \non a sign above the door leading to the Tourian entrance.", "randomizable": true, "visibility": 15, "type": "Range", "default": 4, "min": 0, "max": 4}, {"name": "spin_jumps_animation", "display_name": "Spin Jumps Animation", "description": "Enable separate space/screw jump animations", "randomizable": true, "visibility": 15, "type": "Toggle", "default": false}, {"name": "heart_beep_speed", "display_name": "Heart Beep Speed", "description": "Sets the speed of the heart beep sound in A Link to the Past.", "randomizable": true, "visibility": 15, "type": "Choice", "default": 3, "choices": [{"name": "off", "display_name": "Off", "value": 0}, {"name": "quarter", "display_name": "Quarter", "value": 1}, {"name": "half", "display_name": "Half", "value": 2}, {"name": "normal", "display_name": "Normal", "value": 3}, {"name": "double", "display_name": "Double", "value": 4}]}, {"name": "heart_color", "display_name": "Heart Color", "description": "Changes the color of the hearts in the HUD for A Link to the Past.", "randomizable": true, "visibility": 15, "type": "Choice", "default": 0, "choices": [{"name": "red", "display_name": "Red", "value": 0}, {"name": "green", "display_name": "Green", "value": 1}, {"name": "blue", "display_name": "Blue", "value": 2}, {"name": "yellow", "display_name": "Yellow", "value": 3}]}, {"name": "quick_swap", "display_name": "Quick Swap", "description": "When enabled, lets you switch items in ALTTP with L/R", "randomizable": true, "visibility": 15, "type": "Toggle", "default": false}, {"name": "energy_beep", "display_name": "Energy Beep", "description": "Toggles the low health energy beep in Super Metroid.", "randomizable": true, "visibility": 15, "type": "Toggle", "default": true}], "collapsed": false}, {"name": "Item & Location Options", "options": [{"name": "local_items", "display_name": "Local Items", "description": "Forces these items to be in their native world.", "randomizable": false, "visibility": 15, "type": "OptionSet", "default": [], "options": ["Nothing", "MapHC", "MapEP", "MapDP", "MapTH", "MapPD", "MapSP", "MapSW", "MapTT", "MapIP", "MapMM", "MapTR", "MapGT", "CompassEP", "CompassDP", "CompassTH", "CompassPD", 
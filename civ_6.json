{"name": "civ_6", "game": "Civilization VI", "version": "0.0.0", "hidden": false, "groups": [{"name": "Game Options", "options": [{"name": "progression_balancing", "display_name": "Progression Balancing", "description": "A system that can move progression earlier, to try and prevent the player from getting stuck and bored early.\n\nA lower setting means more getting stuck. A higher setting means less getting stuck.", "randomizable": true, "visibility": 15, "type": "NamedRange", "default": 50, "min": 0, "max": 99, "presets": {"disabled": 0, "normal": 50, "extreme": 99}}, {"name": "accessibility", "display_name": "Accessibility", "description": "Set rules for reachability of your items/locations.\n\n**Full:** ensure everything can be reached and acquired.\n\n**Minimal:** ensure what is needed to reach your goal can be acquired.", "randomizable": true, "visibility": 15, "type": "Choice", "default": 0, "choices": [{"name": "full", "display_name": "Full", "value": 0}, {"name": "minimal", "display_name": "Minimal", "value": 2}]}, {"name": "progression_style", "display_name": "Progression Style", "description": "**Districts Only**: Each tech/civic that would normally unlock a district or building now has a logical progression.\nExample: TECH_BRONZE_WORKING is now PROGRESSIVE_ENCAMPMENT\n\n**Eras and Districts**: Players will be defeated if they play until the world era advances beyond the currently unlocked maximum era.\nUnlocked eras can be seen in both the tech and civic trees. Includes all progressive districts.\n\n**None**: No progressive items will be included. This means you can get district upgrades that won't be usable until the relevant district is unlocked.", "randomizable": true, "visibility": 15, "type": "Choice", "default": 0, "choices": [{"name": "districts_only", "display_name": "Districts Only", "value": 0}, {"name": "eras_and_districts", "display_name": "Eras And Districts", "value": 1}, {"name": "none", "display_name": "None", "value": 2}]}, {"name": "shuffle_goody_hut_rewards", "display_name": "Shuffle Goody Hut Rewards", "description": "Shuffles the goody hut rewards.\nGoody huts will only contain junk items and locations are checked sequentially (First goody hut gives GOODY_HUT_1, second gives GOODY_HUT_2, etc.).", "randomizable": true, "visibility": 15, "type": "Toggle", "default": true}, {"name": "boostsanity", "display_name": "Boostsanity", "description": "Boosts for Civics/Techs are location checks. Boosts can now be triggered even if the item has already been\nresearched.\n\n**Note**: If a boost is dependent upon a unit that is now obsolete, you can click to toggle on/off the relevant tech in\nthe tech tree.", "randomizable": true, "visibility": 15, "type": "Toggle", "default": false}, {"name": "research_cost_multiplier", "display_name": "Tech/Civic Cost Multiplier", "description": "Multiplier for research cost of techs and civics, higher values make research more expensive.", "randomizable": true, "visibility": 15, "type": "Range", "default": 100, "min": 50, "max": 150}, {"name": "pre_hint_items", "display_name": "Tech/Civic Tree pre-hinted Items", "description": "Controls what items from the tech/civics trees are pre-hinted for the multiworld.\n**Progression**: Include Progression items in hints\n**Useful**: Include Useful items in hints\n**Filler**: Include Filler items in hints", "randomizable": false, "visibility": 15, "type": "OptionSet", "default": [], "options": ["Filler", "Progression", "Useful"]}, {"name": "hide_item_names", "display_name": "Hide Item Names", "description": "Each Tech and Civic Location will have a title of 'Unrevealed' until its prereqs have been researched. Note that\nhints will still be precollected if that option is enabled.", "randomizable": true, "visibility": 15, "type": "Toggle", "default": false}, {"name": "advisor_show_progression_items", "display_name": "Advisor Indicates Progression Items", "description": "If enabled, an advisor icon will be added to any location that contains a progression item.", "randomizable": true, "visibility": 15, "type": "Toggle", "default": true}, {"name": "death_link", "display_name": "Death Link", "description": "If enabled, losing a unit will trigger a death link effect on other players in the multiworld. When a death link is received, the player will receive the effect specified in 'Death Link Effect'.", "randomizable": true, "visibility": 15, "type": "Toggle", "default": false}, {"name": "death_link_effect", "display_name": "Death Link Effect", "description": "What happens when a unit dies.\n\n**Unit Killed**: A random unit will be killed when a death link is received.\n\n**Faith**: Faith will be decreased by the amount specified in 'Death Link Effect Percent'.\n\n**Gold**: Gold will be decreased by the amount specified in 'Death Link Effect Percent'.\n\n**Era Score**: Era score is decreased by 1.", "randomizable": false, "visibility": 15, "type": "OptionSet", "default": ["Unit Killed"], "options": ["Era Score", "Faith", "Gold", "Unit Killed"]}, {"name": "death_link_effect_percent", "display_name": "Death Link Effect Percent", "description": "The percentage of the effect that will be applied. Only applicable for Gold and Faith effects.", "randomizable": true, "visibility": 15, "type": "Range", "default": 20, "min": 1, "max": 100}], "collapsed": false}, {"name": "Item & Location Options", "options": [{"name": "local_items", "display_name": "Local Items", "description": "Forces these items to be in their native world.", "randomizable": false, "visibility": 15, "type": "OptionSet", "default": [], "options": ["Pottery", "Animal Husbandry", "Mining", "Sailing", "Astrology", "Irrigation", "Archery", "Writing", "Masonry", "Bronze Working", "The Wheel", "Celestial Navigation", "Currency", "Horseback Riding", "Iron Working", "Shipbuilding", "Mathematics", "Construction", "Engineering", "Military Tactics", "Apprenticeship", "Machinery", "Education", "Stirrups", "Military Engineering", "Castles", "Cartography",
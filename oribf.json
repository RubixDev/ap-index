{"name": "oribf", "game": "Ori and the Blind Forest", "version": "0.0.0", "hidden": false, "groups": [{"name": "Game Options", "options": [{"name": "progression_balancing", "display_name": "Progression Balancing", "description": "A system that can move progression earlier, to try and prevent the player from getting stuck and bored early.\n\nA lower setting means more getting stuck. A higher setting means less getting stuck.", "randomizable": true, "visibility": 15, "type": "NamedRange", "default": 50, "min": 0, "max": 99, "presets": {"disabled": 0, "normal": 50, "extreme": 99}}, {"name": "accessibility", "display_name": "Accessibility", "description": "Set rules for reachability of your items/locations.\n\n**Full:** ensure everything can be reached and acquired.\n\n**Minimal:** ensure what is needed to reach your goal can be acquired.", "randomizable": true, "visibility": 15, "type": "Choice", "default": 0, "choices": [{"name": "full", "display_name": "Full", "value": 0}, {"name": "minimal", "display_name": "Minimal", "value": 2}]}, {"name": "goal", "display_name": "Goal", "description": "Choose the end goal. You may choose multiple\nAllSkillTrees: Find all 10 skill trees (including Kuro's feather)\nAllMaps: Place all 9 mapstones around the map\nWarmthFragments: Collect the required number of Warmth Fragments\nWorldTour: Collect the required number of Relics. Up to 11 areas (default 8) around Nibel will be chosen to contain a relic in a random location", "randomizable": false, "visibility": 15, "type": "OptionSet", "default": ["AllSkillTrees"], "options": ["AllMaps", "AllSkillTrees", "WarmthFragments", "WorldTour"]}, {"name": "require_final_escape", "display_name": "Require Final Escape", "description": "Whether or not the final escape in Mount Horu is required to goal\nIf true, the final escape will need to be completed. The door to the escape will only open once other all other goals are complete.\nIf false, the player only needs to reach the escape door once all other goals are complete", "randomizable": true, "visibility": 15, "type": "Toggle", "default": true}, {"name": "warmth_fragments_available", "display_name": "Warmth Fragments Available", "description": "The number of Warmth Fragments that exist", "randomizable": true, "visibility": 15, "type": "Range", "default": 30, "min": 1, "max": 50}, {"name": "warmth_fragments_required", "display_name": "Warmth Fragments Required", "description": "The number of Warmth Fragments needed for the goal", "randomizable": true, "visibility": 15, "type": "Range", "default": 20, "min": 1, "max": 50}, {"name": "relic_count", "display_name": "Relic Count", "description": "The number of areas chosen to contain Relics", "randomizable": true, "visibility": 15, "type": "Range", "default": 8, "min": 1, "max": 11}, {"name": "logic_difficulty", "display_name": "Difficulty", "description": "Sets the difficulty of the logic", "randomizable": true, "visibility": 15, "type": "Choice", "default": 0, "choices": [{"name": "casual", "display_name": "Casual", "value": 0}, {"name": "standard", "display_name": "Standard", "value": 1}, {"name": "expert", "display_name": "Expert", "value": 2}, {"name": "master", "display_name": "Master", "value": 3}]}, {"name": "keystone_logic", "display_name": "Keystone Logic", "description": "Choose how keystones can be used.\nAnywhere: All keystones can be used anywhere.\nArea Specific: Keystones are restricted to be used only in their given area.", "randomizable": true, "visibility": 15, "type": "Choice", "default": 0, "choices": [{"name": "anywhere", "display_name": "Anywhere", "value": 0}, {"name": "area_specific", "display_name": "Area Specific", "value": 1}]}, {"name": "mapstone_logic", "display_name": "Mapstone Logic", "description": "Choose how mapstones can be used.\nAnywhere: All mapstones can be used anywhere.\nArea Specific: Mapstones are restricted to be used only in their given area.\nProgressive: Similar to anywhere, but it doesn't matter where the mapstone is used.\n    The first mapstone used will always send ProgressiveMapstone1 and the last will send ProgressiveMapstone9", "randomizable": true, "visibility": 15, "type": "Choice", "default": 0, "choices": [{"name": "anywhere", "display_name": "Anywhere", "value": 0}, {"name": "area_specific", "display_name": "Area Specific", "value": 1}, {"name": "progressive", "display_name": "Progressive", "value": 2}]}, {"name": "include_teleporters", "display_name": "Include Teleporters", "description": "Whether or not teleporters are included in the item pool", "randomizable": true, "visibility": 15, "type": "Toggle", "default": true}, {"name": "extra_keystones", "display_name": "Extra Keystones", "description": "Adds extra keystones to the pool to make them easier to get. Affects anywhere and area specific logic\nDue to differences between anywhere and area specific counts, this acts as a percentage to add to the base.\nEx. at 50%, 40 keystones (anywhere logic) becomes 60 keystones \n    and 8 Ginso keystones (area specific logic) becomes 12 Ginso keystones", "randomizable": true, "visibility": 15, "type": "Range", "default": 0, "min": 0, "max": 100}, {"name": "extra_mapstones", "display_name": "Extra Mapstones", "description": "Adds extra mapstones to the pool to make it easier to get the 9 required. Affects anywhere and progressive mapstone logic", "randomizable": true, "visibility": 15, "type": "Range", "default": 0, "min": 0, "max": 9}, {"name": "extra_skills", "display_name": "Extra Skills", "description": "Adds an extra copy of each of the skills. Also adds an extra copy of Clean Water and Wind", "randomizable": true, "visibility": 15, "type": "Toggle", "default": false}, {"name": "deathlink_logic", "display_name": "Death Link", "description": "Enable Death Link\nDisabled: Death Link is disabled\nPartial: Death Link is enabled, but will not send a death for any instant kill deaths.\nFull: Death Link is enabled, and will send for every death", "randomizable": true, "visibility": 15, "type": "Choice", "default": 0, "choices": [{"name": "disabled", "display_name": "Disabled", "value": 0}, {"name": "partial", "display_name": "Partial", "value": 1}, {"name": "full", "display_name": "Full", "value": 2}]}, {"name": "deathlink_count", "display_name": "Death Link Count", "description": "How many deaths are allowed before sending a death link\nHas no effect if death link is disabled", "randomizable": true, "visibility": 15, "type": "Range", "default": 1, "min": 1, "max": 30}, {"name": "sein_logic", "display_name": "Sein Logic", "description": "How to place Sein in the multiworld\nVanilla: Sein is placed at the normal location\nStart: Adds Sein to the starting inventory", "randomizable": true, "visibility": 15, "type": "Choice", "default": 0, "choices": [{"name": "vanilla", "display_name": "Vanilla", "value": 0}, {"name": "start", "display_name": "Start", "value": 1}]}, {"name": "logic_modifiers", "display_name": "Logic Modifiers", "description": "Additional modifiers to add to the base logic difficulty. Some options only affect higher difficulties.\nThe default is all modifiers are enabled except for Glitches.\n\n- Lure: Allows luring enemies to be considered for logic. \nAffects standard and above, but higher difficulties may require more difficult lures.\n\n- DamageBoost: Allows taking damage to be considered for logic. \nAffects all difficulties, but higher difficulties may require more damage. Use of Ultra Defense ability limited to master. \nAt least 12 ability cells will be in logic before needing to use this ability.\n\n- DoubleBash: Allows double bash technique to be considered for logic. Affects expert and above.\n\n- GrenadeJump: Allows grenade jump technique to be considered for logic. Affects master.\n\n- AirDash: Allows air dash ability to be considered for logic. Affects standard and above. \nAt least 3 ability cells will be in logic before needing to use this ability.\n\n- ChargeDash: Allows charge dash ability to be considered for logic. Affects expert and above. \nAt least 6 ability cells will be in logic before needing to use this ability.\n\n- TripleJump: Allows triple jump ability to be considered for logic. Only affects master. \nAt least 12 ability cells will be in logic before needing to use this ability.\n\n- ChargeFlameBurn: Allows charge flame burn ability to be considered for logic. Only affects master. \nAt least 3 ability cells will be in logic before needing to use this ability.\n\n- Rekindle: Allows rekindle ability to be considered for logic. Only affects standard, expert, and master\nfor specifically the Ghost Lever trick in Blackroot Burrows\n\n- Glitches: Allows glitches to be considered for logic. Affects all logic difficulties", "randomizable": false, "visibility": 15, "type": "OptionSet", "default": ["DoubleBash", "Lure", "ChargeDash", "TripleJump", "AirDash", "DamageBoost", "Rekindle", "ChargeFlameBurn", "GrenadeJump"], "options": ["AirDash", "ChargeDash", "ChargeFlameBurn", "DamageBoost", "DoubleBash", "Glitches", "GrenadeJump", "Lure", "Rekindle", "TripleJump"]}, {"name": "restrict_dungeon_keys", "display_name": "Restrict Dungeon Keys", "description": "Due to teleporters, it is possible for dungeon keys (ex. GinsoKey) to end up placed inside \ntheir dungeon. This option prevents those keys from being placed there", "randomizable": true, "visibility": 15, "type": "Toggle", "default": false}], "collapsed": false}, {"name": "Item & Location Options", "options": [{"name": "local_items", "display_name": "Local Items", "description": "Forces these items to be in their native world.", "randomizable": false, "visibility": 15, "type": "OptionSet", "default": [], "options": ["AbilityCell", "HealthCell", "EnergyCell", "SpiritFlame", "GinsoKey", "ForlornKey", "HoruKey", "CleanWater", "Wind", "WallJump", "ChargeFlame", "DoubleJump", "Bash", "Stomp", "Glide", "Climb", "ChargeJump", "Dash", "Grenade", "TPGlades", "TPGrove", "TPSwamp", "TPGrotto", "TPGinso", "TPValley", "TPFor
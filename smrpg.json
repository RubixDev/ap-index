{"name": "smrpg", "game": "Super Mario RPG Legend of the Seven Stars", "version": "0.0.0", "hidden": false, "groups": [{"name": "Game Options", "options": [{"name": "progression_balancing", "display_name": "Progression Balancing", "description": "A system that can move progression earlier, to try and prevent the player from getting stuck and bored early.\n\nA lower setting means more getting stuck. A higher setting means less getting stuck.", "randomizable": true, "visibility": 15, "type": "NamedRange", "default": 50, "min": 0, "max": 99, "presets": {"disabled": 0, "normal": 50, "extreme": 99}}, {"name": "accessibility", "display_name": "Accessibility", "description": "Set rules for reachability of your items/locations.\n\n**Full:** ensure everything can be reached and acquired.\n\n**Minimal:** ensure what is needed to reach your goal can be acquired.", "randomizable": true, "visibility": 15, "type": "Choice", "default": 0, "choices": [{"name": "full", "display_name": "Full", "value": 0}, {"name": "minimal", "display_name": "Minimal", "value": 2}]}, {"name": "StarPieceGoal", "display_name": "Star Piece Goal", "description": "Six or seven Star Pieces to fight Smithy.", "randomizable": true, "visibility": 15, "type": "Choice", "default": 0, "choices": [{"name": "six", "display_name": "Six", "value": 0}, {"name": "seven", "display_name": "Seven", "value": 1}]}, {"name": "StarPiecesInBowsersKeep", "display_name": "Star Pieces in Bowser's Keep", "description": "Star Pieces can be located on the Bowser's Keep boss slots: Magikoopa, Boomer, and Exor.\nIf toggled off, Bowser's Keep will be unavailable until the requisite number of Star Pieces have been\nobtained and will be your route to the Factory. If toggled on, the Factory is opened as soon as the requisite\nnumber of Star Pieces have been obtained.", "randomizable": true, "visibility": 15, "type": "Toggle", "default": true}, {"name": "BowsersKeepDoors", "display_name": "Bowser's Keep Doors", "description": "How many doors required to clear the middle of Bowser's Keep.", "randomizable": true, "visibility": 15, "type": "Range", "default": 2, "min": 1, "max": 6}, {"name": "ShuffleBowsersKeepDoors", "display_name": "Shuffle Bowser's Keep Doors", "description": "If toggled on, each door could contain any three rooms from the six doors. If toggled off, behaves like vanilla:\ntwo action doors, two battle doors, two puzzle doors.", "randomizable": true, "visibility": 15, "type": "Toggle", "default": true}, {"name": "IncludeCulex", "display_name": "Include Culex", "description": "A Star Piece might be located on the boss in Culex's Lair, and Culex's reward (normally the Quartz Charm)\nmight be required. Shuffles Culex into the boss pool.", "randomizable": true, "visibility": 15, "type": "Toggle", "default": true}, {"name": "ExperienceMultiplier", "display_name": "Experience Multiplier", "description": "Multiplies the amount of experience points gained from battling enemies.", "randomizable": true, "visibility": 15, "type": "Choice", "default": 1, "choices": [{"name": "single", "display_name": "Single", "value": 0}, {"name": "double", "display_name": "Double", "value": 1}, {"name": "triple", "display_name": "Triple", "value": 2}]}, {"name": "RandomizeEnemies", "display_name": "Randomize Enemies", "description": "Randomize all enemies. Mild randomizes their drops and formations. Moderate includes enemy stats and attack\nstats and effects. Severe includes their spell lists. Extreme is Severe, but with no safety checks -- have fun!", "randomizable": true, "visibility": 15, "type": "Choice", "default": 1, "choices": [{"name": "none", "display_name": "None", "value": 0}, {"name": "mild", "display_name": "Mild", "value": 1}, {"name": "moderate", "display_name": "Moderate", "value": 2}, {"name": "severe", "display_name": "Severe", "value": 3}, {"name": "extreme", "display_name": "Extreme", "value": 4}]}, {"name": "RandomizeBosses", "display_name": "Randomize Bosses", "description": "Randomize boss locations. Bosses will have their stats scaled to their location. This doesn't include spell stats:\nBreaker Beam will still hurt coming from Croco's slot.", "randomizable": true, "visibility": 15, "type": "Toggle", "default": true}, {"name": "RandomizeCharacterStats", "display_name": "Randomize Character Stats", "description": "Stats for each character will be randomized.", "randomizable": true, "visibility": 15, "type": "Toggle", "default": true}, {"name": "RandomizeCharacterSpells", "display_name": "Randomize Character Spells", "description": "Randomize character learned spells and their spell powers", "randomizable": true, "visibility": 15, "type": "Toggle", "default": true}, {"name": "StartingCharacterCount", "display_name": "Starting Character Count", "description": "Start with one or three characters. Clearing Forest Maze or Marrymore will recruit a new character. If starting\nwith one character, clearing Mushroom Way or Moleville will recruit a new character as well.", "randomizable": true, "visibility": 15, "type": "Choice", "default": 1, "choices": [{"name": "one", "display_name": "One", "value": 0}, {"name": "three", "display_name": "Three", "value": 1}]}, {"name": "StartingCharacter", "display_name": "Starting Character", "description": "Choose which character you start with. If starting with three characters, this chooses the first one.", "randomizable": true, "visibility": 15, "type": "Choice", "default": "random", "choices": [{"name": "mario", "display_name": "Mario", "value": 0}, {"name": "mallow", "display_name": "Mallow", "value": 1}, {"name": "geno", "display_name": "Geno", "value": 2}, {"name": "bowser", "display_name": "Bowser", "value": 3}, {"name": "toadstool", "display_name": "Toadstool", "value": 4}]}, {"name": "RandomizeCharacterPalettes", "display_name": "Randomize Character Palettes", "description": "Randomize character palettes. Some come with fun names!", "randomizable": true, "visibility": 15, "type": "Toggle", "default": true}, {"name": "RandomizeEquipment", "display_name": "Randomize Equipment", "description": "Randomize equipment. Mild randomizes who can equip each piece of gear. Moderate randomizes stats and buffs. Severe\nremoves safety checks for the status protection pins guarding against their status and a minimum number of instant\nKO protection items.", "randomizable": true, "visibility": 15, "type": "Choice", "default": 1, "choices": [{"name": "none", "display_name": "None", "value": 0}, {"name": "mild", "display_name": "Mild", "value": 1}, {"name": "moderate", "display_name": "Moderate", "value": 2}, {"name": "severe", "display_name": "Severe", "value": 3}]}, {"name": "ItemPool", "display_name": "Item Pool", "description": "Adjusts the items available. Vanilla shuffles the vanilla item rewards around. Shuffled types will randomize\nitems to be the same type of item (consumbles -> consumables, weapons -> weapons). Shuffled inventories randomizes\nitems within their general category (items -> items, gear -> gear). Chaotic will fully randomize each item.", "randomizable": true, "visibility": 15, "type": "Choice", "default": 0, "choices": [{"name": "vanilla", "display_name": "Vanilla", "value": 0}, {"name": "shuffled_types", "display_name": "Shuffled Types", "value": 1}, {"name": "shuffled_inventories", "display_name": "Shuffled Inventories", "value": 2}, {"name": "chaotic", "display_name": "Chaotic", "value": 3}]}, {"name": "SuperJumpsInLogic", "display_name": "Super Jumps In Logic", "description": "Toggled on, this allows progression items to be at the rewards for thirty and one hundred Super Jumps.\nToggled off, those locations will never be required (but could hold something useful)", "randomizable": true, "visibility": 15, "type": "Toggle", "default": false}, {"name": "FreeShops", "display_name": "Free Shops", "description": "Toggled on, this gives you 9999 Coins, 99 Frog Coins, and makes shop prices all be one Coin/Frog Coin.\nToggled off, shops will charge normal prices and you'l
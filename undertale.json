do_item_button", "display_name": "Randomize Item Button", "description": "Turns the ITEM button in battle into an item you have to receive.", "randomizable": true, "visibility": 15, "type": "Toggle", "default": false}], "collapsed": false}, {"name": "Item & Location Options", "options": [{"name": "local_items", "display_name": "Local Items", "description": "Forces these items to be in their native world.", "randomizable": false, "visibility": 15, "type": "OptionSet", "default": [], "options": ["Progressive Plot", "Progressive Weapons", "Progressive Armor", "Monster Candy", "Croquet Roll", "Stick", "Bandage", "Rock Candy", "Pumpkin Rings", "Spider Donut", "Stoic Onion", "Ghost Fruit", "Spider Cider", "Butterscotch Pie", "Faded Ribbon", "Toy Knife", "Tough Glove", "Manly Bandanna", "Snowman Piece", "Nice Cream", "Puppydough Icecream", "Bisicle", "Unisicle", "Cinnamon Bun", "Temmie Flakes", "Abandoned Quiche", "Old Tutu", "Ballet Shoes", "Punch Card", "Annoying Dog", "Dog Salad", "Dog Residue", "Astronaut Food", "Instant Noodles", "Crab Apple", "Hot Dog...?", "Hot Cat", "Glamburger", "Sea Tea", "Starfait", "Legendary Hero", "Cloudy Glasses", "Torn Notebook", "Stained Apron", "Burnt Pan", "Cowboy Hat", "Empty Gun", "Heart Locket", "Worn Dagger", "Real Knife", "The Locket", "Bad Memory", "Dream", "Undyne's Letter", "Undyne Letter EX", "Popato Chisps", "Junk Food", "Mystery Key", "Face Steak", "Hush Puppy", "Snail Pie", "temy armor", "Complete Skeleton", "Fish", "DT Extractor", "Mettaton Plush", "Left Home Key", "LOVE", "Right Home Key", "Key Piece", "100G", "500G", "1000G", "ATK Up", "DEF Up", "HP Up", "FIGHT", "ACT", "ITEM", "MERCY", "Ruins Key", "Snowdin Key", "Waterfall Key", "Hotland Key", "Core Key", "Everything"]}, {"name": "non_local_items", "display_name": "Non-local Items", "description": "Forces these items to be outside their native world.", "randomizable": false, "visibility": 15, "type": "OptionSet", "default": [], "options": ["Progressive Plot", "Progressiv
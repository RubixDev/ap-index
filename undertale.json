{"name": "undertale", "game": "Undertale", "version": "0.0.0", "hidden": false, "groups": [{"name": "Game Options", "options": [{"name": "progression_balancing", "display_name": "Progression Balancing", "description": "A system that can move progression earlier, to try and prevent the player from getting stuck and bored early.\n\nA lower setting means more getting stuck. A higher setting means less getting stuck.", "randomizable": true, "visibility": 15, "type": "NamedRange", "default": 50, "min": 0, "max": 99, "presets": {"disabled": 0, "normal": 50, "extreme": 99}}, {"name": "accessibility", "display_name": "Accessibility", "description": "Set rules for reachability of your items/locations.\n\n**Full:** ensure everything can be reached and acquired.\n\n**Minimal:** ensure what is needed to reach your goal can be acquired.", "randomizable": true, "visibility": 15, "type": "Choice", "default": 0, "choices": [{"name": "full", "display_name": "Full", "value": 0}, {"name": "minimal", "display_name": "Minimal", "value": 2}]}, {"name": "route_required", "display_name": "Required Route", "description": "Main route of the game required to win.", "randomizable": true, "visibility": 15, "type": "Choice", "default": 0, "choices": [{"name": "neutral", "display_name": "Neutral", "value": 0}, {"name": "pacifist", "display_name": "Pacifist", "value": 1}, {"name": "genocide", "display_name": "Genocide", "value": 2}, {"name": "all_routes", "display_name": "All Routes", "value": 3}]}, {"name": "starting_area", "display_name": "Starting Area", "description": "Which area to start with access to.", "randomizable": true, "visibility": 15, "type": "Choice", "default": 0, "choices": [{"name": "ruins", "display_name": "Ruins", "value": 0}, {"name": "snowdin", "display_name": "Snowdin", "value": 1}, {"name": "waterfall", "display_name": "Waterfall", "value": 2}, {"name": "hotland", "display_name": "Hotland", "value": 3}, {"name": "core", "display_name": "Core", "value": 4}]}, {"name": "key_
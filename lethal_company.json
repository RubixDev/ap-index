{"name": "lethal_company", "game": "Lethal Company", "version": "0.8.0", "hidden": false, "groups": [{"name": "Game Options", "options": [{"name": "progression_balancing", "display_name": "Progression Balancing", "description": "A system that can move progression earlier, to try and prevent the player from getting stuck and bored early.\n\nA lower setting means more getting stuck. A higher setting means less getting stuck.", "randomizable": true, "visibility": 15, "type": "NamedRange", "default": 50, "min": 0, "max": 99, "presets": {"disabled": 0, "normal": 50, "extreme": 99}}, {"name": "accessibility", "display_name": "Accessibility", "description": "Set rules for reachability of your items/locations.\n\n**Full:** ensure everything can be reached and acquired.\n\n**Minimal:** ensure what is needed to reach your goal can be acquired.", "randomizable": true, "visibility": 15, "type": "Choice", "default": 0, "choices": [{"name": "full", "display_name": "Full", "value": 0}, {"name": "minimal", "display_name": "Minimal", "value": 2}]}, {"name": "death_link", "display_name": "Death Link", "description": "When you die, everyone who enabled death link dies. Of course, the reverse is true too.", "randomizable": true, "visibility": 15, "type": "Toggle", "default": false}], "collapsed": false}, {"name": "Goal", "options": [{"name": "game_mode", "display_name": "Game Mode", "description": "Trophy Mode: Each moon has a rare trophy scrap, the goal is to get all of them (11 with no custom moons)\n\nCollectathon: A new rare scrap is added, you need to collect at least ten of it to win\n\nCredit Hunt: You must receive a number of company credit items as specified by the yaml to win. This can lead to\nvery short or very long games depending on your settings", "randomizable": true, "visibility": 15, "type": "Choice", "default": 0, "choices": [{"name": "trophy", "display_name": "Trophy", "value": 0}, {"name": "collectathon", "display_name": "Collectathon", "value": 1}, {"name": "credit_hunt", "display_name": "Credit Hunt", "value": 2}]}, {"name": "collectathon_scrap_goal", "display_name": "Collectathon Scrap Goal", "description": "The number of collectathon scrap you need to complete the collectathon goal", "randomizable": true, "visibility": 15, "type": "Range", "default": 10, "min": 3, "max": 99}, {"name": "credit_replacement", "display_name": "Credit Replacement", "description": "Credit Hunt mode:\nReplaces the specified percent of filler items with company credits", "randomizable": true, "visibility": 15, "type": "Range", "default": 50, "min": 5, "max": 80}, {"name": "required_credits", "display_name": "Required Credits", "description": "Credit Hunt mode:\nThe percent of company credits in the pool that are required to beat the game. If there are 20 credits in the pool\nand you set this to 75, then once 75% of the 20 credits, or 15 credits, are collected, you will win", "randomizable": true, "visibility": 15, "type": "Range", "default": 75, "min": 10, "max": 100}], "collapsed": false}, {"name": "Checks", "options": [{"name": "checks_per_moon", "display_name": "Checks Per Moon", "description": "The total number of checks you can get at one moon", "randomizable": true, "visibility": 15, "type": "Range", "default": 3, "min": 1, "max": 10}, {"name": "money_per_quota_check", "display_name": "Money Per Quota Check", "description": "The total amount of quota you have to acheive to meet each quota check\nFor example, if money per quota check is 1000, you need to reach 1000 total quota for each quota check", "randomizable": true, "visibility": 15, "type": "Range", "default": 500, "min": 100, "max": 10000}, {"name": "num_quotas", "display_name": "Num Quotas", "description": "Will not give checks for quotas past this number. For example, if maximum quotas is 10, the 11th quota check will\nnot count as a check", "randomizable": true, "visibility": 15, "type": "Range", "default": 20, "min": 10, "max": 50}, {"name": "randomize_scanner", "display_name": "Randomize Scanner", "description": "Allows you to randomize your scanner, rendering you unable to scan until you receive the check", "randomizable": true, "visibility": 15, "type": "Toggle", "default": false}, {"name": "randomize_terminal", "display_name": "Randomize Terminal", "description": "Adds the terminal to the item pool", "randomizable": true, "visibility": 15, "type": "Toggle", "default": false}, {"name": "randomize_company_building", "display_name": "Randomize Company Building", "description": "Adds the company building to the item pool", "randomizable": true, "visibility": 15, "type": "Toggle", "default": false}, {"name": "scrapsanity", "display_name": "Scrapsanity", "description": "Enables scrapsanity, where the first time each item is recovered from a moon is a check,\nadds >50 checks to the randomizer", "randomizable": true, "visibility": 15, "type": "Toggle", "default": false}], "collapsed": true}, {"name": "Starting Info", "options": [{"name": "starting_inventory_slots", "display_name": "Starting Inventory Slots", "description": "The number of inventory slots you start the game with", "randomizable": true, "visibility": 15, "type": "Range", "default": 4, "min": 1, "max": 4}, {"name": "starting_stamina_bars", "display_name": "Starting Stamina Bars", "description": "The number of stamina bars you start the game with", "randomizable": true, "visibility": 15, "type": "Range", "default": 4, "min": 0, "max": 4}, {"name": "starting_moon", "display_name": "Starting Moon", "description": "The moon you start on", "randomizable": false, "visibility": 15, "type": "FreeText", "default": "randomize"}], "collapsed": true}, {"name": "Logic Config", "options": [{"name": "min_monster_chance", "display_name": "Minimum Monster Spawn Chance", "description": "Monsters will be in logic if their spawn chance on an in-logic moon is greater than or equal to this percentage. A\nvalue of less than 3% can significantly slow down your game.", "randomizable": true, "visibility": 15, "type": "Range", "default": 5, "min": 0, "max": 20}, {"name": "min_scrap_chance", "display_name": "Minimum Scrap Spawn Chance", "description": "Scrap will be in logic if their spawn chance on an in-logic moon is greater than or equal to this percentage. A\nvalue of less than 3% can significantly slow down your game.", "randomizable": true, "visibility": 15, "type": "Range", "default": 3, "min": 0, "max": 20}, {"name": "exclude_killing", "display_name": "Exclude Killing", "description": "Makes it so there is guaranteed to be a filler item or trap in every check that can only be obtained through killing", "randomizable": true, "visibility": 15, "type": "Toggle", "default": false}, {"name": "exclude_hive", "display_name": "Exclude Hive", "description": "Makes it so there is guaranteed to be a filler item or trap in the hive scrapsanity check", "randomizable": true, "visibility": 15, "type": "Toggle", "default": false}, {"name": "exclude_egg", "display_name": "Exclude Egg", "description": "Makes it so there is guaranteed to be a filler item or trap in the sapsucker egg scrapsanity check", "randomizable": true, "visibility": 15, "type": "Toggle", "default": false}, {"name": "modify_scrap_spawns", "display_name": "Modify Scrap Spawns", "description": "Modifies the spawn rates and availability of scrap on every moon to make sure that you are never stuck for a long\ntime trying to find that one specific scrap to unlock your terminal.", "randomizable": true, "visibility": 15, "type": "Toggle", "default": false}, {"name": "min_money", "display_name": "Min Money Check Amount", "description": "The minimum amount of money that a money check can give you", "randomizable": true, "visibility": 15, "type": "Range", "default": 100, "min": 0, "max": 5000}, {"name": "max_money", "display_name": "Max Money Check Amount", "description": "The maximum amount of money that a money check can give you", "randomizable": true, "visibility": 15, "type": "Range", "default": 1000, "min": 0, "max": 10000}, {"name": "split_moon_grades", "display_name": "Split Moon Grades", "description": "Enables customizing the required grade for easy, medium, and hard moons separately.", "randomizable": true, "visibility": 15, "type": "Toggle", "default": false}, {"name": "moon_grade", "display_name": "Moon Check Grade", "description": "The grade you need to get to get a check on a moon", "randomizable": true, "visibility": 15, "type": "Choice", "default": 2, "choices": [{"name": "s", "display_name": "S", "value": 0}, {"name": "a", "display_name": "A", "value": 1}, {"name": "b", "display_name": "B", "value": 2}, {"name": "c", "display_name": "C", "value": 3}, {"name": "d", "display_name": "D", "value": 4}, {"name": "f", "display_name": "F", "value": 5}]}, {"name": "low_moon_grade", "display_name": "Easy Moon Check Grade", "description": "The grade you need to get to get a check on an easy moon", "randomizable": true, "visibility": 15, "type": "Choice", "default": 2, "choices": [{"name": "s", "display_name": "S", "value": 0}, {"name": "a", "display_name": "A", "value": 1}, {"name": "b", "display_name": "B", "value": 2}, {"name": "c", "display_name": "C", "value": 3}, {"name": "d", "display_name": "D", "value": 4}, {"name": "f", "display_name": "F", "value": 5}]}, {"name": "medium_moon_grade", "display_name": "Medium Moon Check Grade", "description": "The grade you need to get to get a check on a medium difficulty moon", "randomizable": true, "visibility": 15, "type": "Choice", "default": 2, "choices": [{"name": "s", "display_name": "S", "value": 0}, {"name": "a", "display_name": "A", "value": 1}, {"name": "b", "display_name": "B", "value": 2}, {"name": "c", "display_name": "C", "value": 3}, {"name": "d", "display_name": "D", "value": 4}, {"name": "f", "display_name": "F", "value": 5}]}, {"name": "high_moon_grade", "display_name": "Hard Moon Check Grade", "description": "The grade you need to get to get a check on a hard moon", "randomizable": true, "visibility": 15, "type":
{"name": "holo8", "game": "holo8", "version": "0.3.0", "hidden": false, "groups": [{"name": "Game Options", "options": [{"name": "progression_balancing", "display_name": "Progression Balancing", "description": "A system that can move progression earlier, to try and prevent the player from getting stuck and bored early.\n\nA lower setting means more getting stuck. A higher setting means less getting stuck.", "randomizable": true, "visibility": 15, "type": "NamedRange", "default": 50, "min": 0, "max": 99, "presets": {"disabled": 0, "normal": 50, "extreme": 99}}, {"name": "accessibility", "display_name": "Accessibility", "description": "Set rules for reachability of your items/locations.\n\n**Full:** ensure everything can be reached and acquired.\n\n**Minimal:** ensure what is needed to reach your goal can be acquired.", "randomizable": true, "visibility": 15, "type": "Choice", "default": 0, "choices": [{"name": "full", "display_name": "Full", "value": 0}, {"name": "minimal", "display_name": "Minimal", "value": 2}]}, {"name": "anomaly_types", "display_name": "Anomaly Types", "description": "You can choose which type of anomalies you would like to see, including from the base game, Everyday mode, or both.", "randomizable": true, "visibility": 15, "type": "Choice", "default": 0, "choices": [{"name": "normal", "display_name": "Normal", "value": 0}, {"name": "everyday", "display_name": "Everyday", "value": 1}, {"name": "both", "display_name": "Both", "value": 2}]}, {"name": "enable_interactive_anomalies", "display_name": "Enable Interactive Anomalies", "description": "If enabled, this will add checks tied to interacting with certain special anomalies such as Menya Botan and AZKi's Ice Cream Bar.", "randomizable": true, "visibility": 15, "type": "Toggle", "default": false}, {"name": "talentsanity", "display_name": "Talentsanity", "description": "You can choose whether to group anomalies by Hololive gen, or by individual talent.\nGeneration provides more fluid logic, but introduces a lot of filler.\nTalent has less filler, but has very one-to-one logic.", "randomizable": true, "visibility": 15, "type": "Choice", "default": 1, "choices": [{"name": "generation", "display_name": "Generation", "value": 0}, {"name": "talent", "display_name": "Talent", "value": 1}]}, {"name": "no_anomaly_percentage", "display_name": "No Anomaly Percentage", "description": "Percentage chance to land on a floor with no anomaly.\nThis does not affect the 2-floor anomaly failsafe.\nIt is recommended to keep this value low for syncs, and midrange for asyncs.", "randomizable": true, "visibility": 15, "type": "Range", "default": 20, "min": 0, "max": 100}, {"name": "reused_anomaly_percentage", "display_name": "Reused Anomaly Percentage", "description": "Percentage chance during floor shuffle to include floors with anomalies that you have already seen.", "randomizable": true, "visibility": 15, "type": "Range", "default": 0, "min": 0, "max": 100}, {"name": "hard_anomalies", "display_name": "Hard Anomalies", "description": "Enable anomalies that are difficult to spot.\nIt is recommended to keep this option turned off for syncs.", "randomizable": true, "visibility": 15, "type": "Toggle", "default": false}, {"name": "talentsanity_filler", "display_name": "Talentsanity Filler", "description": "When playing on Talentsanity, determine whether or not to first fill the multiworld with talents not in holo8, space permitting.\nnone: No talents not in holo8 will be added to the item pool.\nterminated: Adds terminated female talents.\nholostars: Adds active and alumni Holostars talents.\neveryone: Adds all historical Hololive talents.", "randomizable": true, "visibility": 15, "type": "Choice", "default": 0, "choices": [{"name": "none", "display_name": "None", "value": 0}, {"name": "terminated", "display_name": "Terminated", "value": 1}, {"name": "holostars", "display_name": "Holostars", "value": 2}, {"name": "everyone", "display_name": "Everyone", "value": 3}]}, {"name": "death_link", "display_name": "Death Link", "description": "When you die, everyone dies. The reverse is also true (you will immediately be sent back to Floor 8).", "randomizable": true, "visibility": 15, "type": "Toggle", "default": false}, {"name": "deathlink_on_wrong_elevator", "display_name": "DeathLink On Wrong Elevator", "description": "If enabled, will also send a DeathLink if you board the wrong elevator.\nWill have no effect if DeathLink is disabled.", "randomizable": true, "visibility": 15, "type": "Toggle", "default": false}], "collapsed": false}, {"name": "Item & Location Options", "options": [{"name": "local_items", "display_name": "Local Items", "description": "Forces these items to be in their native world.", "randomizable": false, "visibility": 15, "type": "OptionSet", "default": [], "options": ["Hololive Generation 0", "Hololive Generation 1", "Hololive Generation 2", "Hololive GAMERS", "Hololive Fantasy", "HoloForce", "NePoLaBo", "HoloX Secret Society", "ReGLOSS", "FLOW GLOW", "Area 15", "Holoro", "Holoh3ro", "Hololive Myth", "Hololive CouncilRyS", "Hololive Advent", "Hololive Justice", "Tokino Sora", "Roboco", "Sakura Miko", "Hoshimachi Suisei", "AZKi", "Aki Rosenthal", "Akai Haato", "Shirakami Fubuki", "Natsuiro Matsuri", "Minato Aqua", "Murasaki Shion", "Nakiri Ayame", "Yuzuki Choco", "Oozora Subaru", "Ookami Mio", "Nekomata Okayu", "Inugami Korone", "Usada Pekora", "Shiranui Flare", "Shirogane Noel", "Houshou Marine", "Amane Kanata", "Tsunomaki Watame", "Kiryu Coco", "Tokoyami Towa", "Himemori Luna", "Yukihana Lamy", "Momosuzu Nene", "Shishiro Botan", "Omaru Polka", "Laplus Darknesss", "Takane Lui", "Hakui Koyori", "Sakamata Chloe", "Kazama Iroha", "Hiodoshi Ao", "Otonose Kanade", "Ichijou Ririka", "Juufuutei Raden", "Todoroki Hajime", "Isaki Riona", "Koganei Niko", "Mizumiya Su", "Rindo Chihaya", "Kikirara Vivi", "Ayunda Risu", "Moona Hoshinova", "Airani Iofifteen", "Kureiji Ollie", "Anya Melfissa", "Pavolia Reine", "Vestia Zeta", "Kaela Kovalskia", "K
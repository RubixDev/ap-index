{"name": "yooka_laylee", "game": "Yooka-Laylee", "version": "0.0.0", "hidden": false, "groups": [{"name": "Game Options", "options": [{"name": "progression_balancing", "display_name": "Progression Balancing", "description": "A system that can move progression earlier, to try and prevent the player from getting stuck and bored early.\n\nA lower setting means more getting stuck. A higher setting means less getting stuck.", "randomizable": true, "visibility": 15, "type": "NamedRange", "default": 50, "min": 0, "max": 99, "presets": {"disabled": 0, "normal": 50, "extreme": 99}}, {"name": "accessibility", "display_name": "Accessibility", "description": "Set rules for reachability of your items/locations.\n\n**Full:** ensure everything can be reached and acquired.\n\n**Minimal:** ensure what is needed to reach your goal can be acquired.", "randomizable": true, "visibility": 15, "type": "Choice", "default": 0, "choices": [{"name": "full", "display_name": "Full", "value": 0}, {"name": "minimal", "display_name": "Minimal", "value": 2}]}, {"name": "force_local_first_item", "display_name": "Force local first abilitiy", "description": "If enabled, forces an ability that can deal damage into your world as the first location you can check (where Trowzer teaches you Tail Twirl). Otherwise, it will be filled into any location that is reachable from the beginning of any game.", "randomizable": true, "visibility": 15, "type": "Toggle", "default": false}, {"name": "prevent_tropics_bk", "display_name": "Prevent Tropics BK", "description": "If enabled, forces either Reptile Roll or Flappy Flight into your world in a location accessible before Tribalstack Tropics. If disabled, these abilities may be placed anywhere.", "randomizable": true, "visibility": 15, "type": "Toggle", "default": true}, {"name": "flappy_flight_location", "display_name": "Flappy Flight Location", "description": "Choose where Flappy Flight is put. Flappy Flight opens up many checks and effectively invalidates some abilities like Lizard Leap. \"Early\" refers to one of the earlygame checks before entering Tribalstack Tropics.", "randomizable": true, "visibility": 15, "type": "Choice", "default": 2, "choices": [{"name": "force_early", "display_name": "Force Early", "value": 1}, {"name": "allow_early", "display_name": "Allow Early", "value": 2}, {"name": "vanilla", "display_name": "Vanilla", "value": 3}, {"name": "anywhere", "display_name": "Anywhere", "value": 4}]}, {"name": "capital_b_pagie_count", "display_name": "Pagies Required for Capital B", "description": "The amount of pagies required to face Capital B. Note that this does NOT guarantee you will be able to access Capital B's office at a particular time, as there are still ability requirements to progress up to Capital B's office in the first place. There are a total of 145 pagies in the game.", "randomizable": true, "visibility": 15, "type": "Range", "default": 100, "min": 0, "max": 145}, {"name": "randomize_grand_tomes", "display_name": "Randomize Grand Tome World Order", "description": "If enabled, randomizes the order of the Grand Tome worlds. This does not change the location of the Grand Tomes within Hivory Towers or the cost of the Grand Tomes, only the world you go to when entering a Grand Tome. Galleon Galaxy will never be randomized in place of Tribalstack Tropics.", "randomizable": true, "visibility": 15, "type": "Toggle", "default": false}, {"name": "disable_quizzes", "display_name": "Disable Quizzes", "description": "If enabled, causes the quizzes to be completely skipped.", "randomizable": true, "visibility": 15, "type": "Toggle", "default": false}, {"name": "death_link", "display_name": "Death Link", "description": "When you die, everyone who enabled death link dies. Of course, the reverse is true too.", "randomizable": true, "visibility": 15, "type": "Toggle", "default": false}], "collapsed": false}, {"name": "Item & Location Options", "options": [{"name": "local_items", "display_name": "Local Items", "descr
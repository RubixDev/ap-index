{"name": "smsa2", "game": "Super Mario Sunshine Arcade 2", "version": "0.0.0", "hidden": false, "groups": [{"name": "Game Options", "options": [{"name": "progression_balancing", "display_name": "Progression Balancing", "description": "A system that can move progression earlier, to try and prevent the player from getting stuck and bored early.\n\nA lower setting means more getting stuck. A higher setting means less getting stuck.", "randomizable": true, "visibility": 15, "type": "NamedRange", "default": 50, "min": 0, "max": 99, "presets": {"disabled": 0, "normal": 50, "extreme": 99}}, {"name": "accessibility", "display_name": "Accessibility", "description": "Set rules for reachability of your items/locations.\n\n**Full:** ensure everything can be reached and acquired.\n\n**Minimal:** ensure what is needed to reach your goal can be acquired.", "randomizable": true, "visibility": 15, "type": "Choice", "default": 0, "choices": [{"name": "full", "display_name": "Full", "value": 0}, {"name": "minimal", "display_name": "Minimal", "value": 2}]}, {"name": "difficulty", "display_name": "Difficulty", "description": "The difficulty of the randomizer's logic.\nStandard: Logic only requires tricks at a similar level of difficulty to the base game\nHard: Logic requires some advanced tech and more difficult execution compared to the base game\nExpert: Logic requires glitches and extremely difficult execution", "randomizable": true, "visibility": 15, "type": "Choice", "default": 0, "choices": [{"name": "standard", "display_name": "Standard", "value": 0}, {"name": "hard", "display_name": "Hard", "value": 1}, {"name": "expert", "display_name": "Expert", "value": 2}]}, {"name": "shine_count", "display_name": "Shine Count", "description": "How many Shine Sprite items appear in the item pool\nIf this number of shines is less than the availiable locations, it will be adjusted to the number of availible locations", "randomizable": true, "visibility": 15, "type": "Range", "default": 75, "min": 1, "max": 171}, {"name": "goal_level_shines", "display_name": "Goal Level Shines", "description": "How many Shine Sprites are required to access level 12-8.\nIf less than this number of Shines exist in the pool, it will be adjusted to the total Shine count.", "randomizable": true, "visibility": 15, "type": "Range", "default": 40, "min": 0, "max": 170}, {"name": "shine_sanity", "display_name": "Shine Sanity", "description": "Enables Shine Sprites in the location pool. \nNote that if Blue Coin Sanity is also disabled, this will be forcefully enabled", "randomizable": true, "visibility": 15, "type": "Toggle", "default": true}, {"name": "blue_coin_sanity", "display_name": "Blue Coin Sanity", "description": "Enables Blue Coins in the location pool. \nNote that if this is the only location option selected, you may find yourself saving and qutting the game regularly to exit levels", "randomizable": true, "visibility": 15, "type": "Toggle", "default": false}, {"name": "shuffle_bubble_nozzle", "display_name": "Shuffle Bubble Nozzle", "description": "Includes the Underwater Hover Nozzle from Noki Bay (called the Bubble Nozzle for brevity) in the item pool.\nWhen obtained, you can switch to it with D-Pad Up.", "randomizable": true, "visibility": 15, "type": "Toggle", "default": false}, {"name": "shuffle_long_jump", "display_name": "Shuffle Long Jump", "description": "Includes the Long Jump move in the item pool.\nUse it by holding Z and pressing A while moving.", "randomizable": true, "visibility": 15, "type": "Toggle", "default": false}, {"name": "shuffle_fruit_gummies", "display_name": "shuffle_fruit_gummies", "description": "Includes the Fruit Gummies in the item pool.\nFruit Gummies allow Yoshi eggs to be hatched without bringing them fruit.\nHowever, Yoshi will not be able to spray juice without eating an actual fruit.", "randomizable": true, "visibility": 15, "type": "Toggle", "default": false}, {"name": "shuffle_dive_helmet", "display_name": "Shuffle Dive Helmet", "
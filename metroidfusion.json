{"name": "metroidfusion", "game": "Metroid Fusion", "version": "0.0.0", "hidden": false, "groups": [{"name": "Game Options", "options": [{"name": "progression_balancing", "display_name": "Progression Balancing", "description": "A system that can move progression earlier, to try and prevent the player from getting stuck and bored early.\n\nA lower setting means more getting stuck. A higher setting means less getting stuck.", "randomizable": true, "visibility": 15, "type": "NamedRange", "default": 50, "min": 0, "max": 99, "presets": {"disabled": 0, "normal": 50, "extreme": 99}}, {"name": "accessibility", "display_name": "Accessibility", "description": "Set rules for reachability of your items/locations.\n\n**Full:** ensure everything can be reached and acquired.\n\n**Minimal:** ensure what is needed to reach your goal can be acquired.", "randomizable": true, "visibility": 15, "type": "Choice", "default": 0, "choices": [{"name": "full", "display_name": "Full", "value": 0}, {"name": "minimal", "display_name": "Minimal", "value": 2}]}, {"name": "TrickyShinesparksInRegionLogic", "display_name": "Tricky Shinesparks in Region Logic", "description": "DEPRECATED OPTION. WILL BE REMOVED IN A FUTURE VERSION.\nUse ShinesparkTrickDifficulty instead.", "randomizable": false, "visibility": 0, "type": "FreeText", "default": ""}, {"name": "SimpleWallJumpsInRegionLogic", "display_name": "Simple Wall Jumps in Region Logic", "description": "DEPRECATED OPTION. WILL BE REMOVED IN A FUTURE VERSION.\nUse WallJumpTrickDifficulty instead.", "randomizable": false, "visibility": 0, "type": "FreeText", "default": ""}, {"name": "death_link", "display_name": "Death Link", "description": "When you die, everyone who enabled death link dies. Of course, the reverse is true too.", "randomizable": true, "visibility": 15, "type": "Toggle", "default": false}], "collapsed": false}, {"name": "Main Options", "options": [{"name": "GameMode", "display_name": "Game Mode", "description": "Determines starting location and accessibility.\nVanilla starts you in the Docking Bay with no items.\nOpen Sector Hub starts you in the Sector Hub with one E-Tank and one random item. All sector elevators will be open.\nCustom will apply the settings in the Custom Game Mode section.", "randomizable": true, "visibility": 15, "type": "Choice", "default": 0, "choices": [{"name": "vanilla", "display_name": "Vanilla", "value": 0}, {"name": "open_sector_hub", "display_name": "Open Sector Hub", "value": 1}, {"name": "custom", "display_name": "Custom", "value": 2}]}, {"name": "InfantMetroidsInPool", "display_name": "Infant Metroids in Pool", "description": "How many Infant Metroids will be in the item pool.", "randomizable": true, "visibility": 15, "type": "Range", "default": 5, "min": 1, "max": 20}, {"name": "InfantMetroidsRequired", "display_name": "Infant Metroids Required", "description": "How many Infant Metroids will be required to beat the game.\nIf set to more than the number in the pool, will instead become however many are present.", "randomizable": true, "visibility": 15, "type": "Range", "default": 5, "min": 1, "max": 20}, {"name": "InfantMetroidLocations", "display_name": "Infant Metroid Locations", "description": "Where Infant Metroids can be located.\nAnywhere allows them to be anywhere in the multiworld.\nBosses Encouraged increases the chances of them being located on local boss locations.\nOnly Bosses means Infant Metroids can only be on your boss locations. Will limit the number of Infant Metroids\nin the pool. if greater than the number of bosses.", "randomizable": true, "visibility": 15, "type": "Choice", "default": 0, "choices": [{"name": "anywhere", "display_name": "Anywhere", "value": 0}, {"name": "bosses_encouraged", "display_name": "Bosses Encouraged", "value": 1}, {"name": "only_bosses", "display_name": "Only Bosses", "value": 2}]}], "collapsed": false}, {"name": "Logic Options", "options": [{"name": "EarlyProgression", "display_name": "Early Progression", "description": "Determines if an early progression item guaranteed in one of your first locations.\nNormal restricts the starting item pool to Morph Ball and Missiles.\nAdvanced expands the pool to Screw Attack.\nIf Shinespark Tricks are set to Advanced, adds Speed Booster as well\nOption is in testing and may increase generation failures.", "randomizable": true, "visibility": 15, "type": "Choice", "default": 1, "choices": [{"name": "none", "display_name": "None", "value": 0}, {"name": "normal", "display_name": "Normal", "value": 1}, {"name": "advanced", "display_name": "Advanced", "value": 2}]}, {"name": "SectorTubeShuffle", "display_name": "Sector Tube Shuffle", "description": "If enabled, shuffles the tube connections between sectors.\nDoes not affect the non-glass tube connections.", "randomizable": true, "visibility": 15, "type": "Toggle", "default": false}, {"name": "ElevatorShuffle", "display_name": "Elevator Shuffle", "description": "If enabled, shuffles the various elevator connections.\nSectors will shuffle the six sector elevators in the Sector Hub.\nAll will include all elevator connections in the game.\nNote that if enabled, logical energy tank requirements will be relaxed.", "randomizable": true, "visibility": 15, "type": "Choice", "default": 0, "choices": [{"name": "none", "display_name": "None", "value": 0}, {"name": "sectors", "display_name": "Sectors", "value": 1}, {"name": "all", "display_name": "All", "value": 2}]}, {"name": "PointOfNoReturnsInLogic", "display_name": "Point of No Returns in Logic", "description": "Should Point of No Return locations be in logic.\nIf disabled, you will never be required to enter an area without the items to exit out.", "randomizable": true, "visibility": 15, "type": "Toggle", "default": true}], "collapsed": false}, {"name": "Trick Options", "options": [{"name": "ShinesparkTrickDifficulty", "display_name": "Shinespark Trick Difficulty", "description": "What level of shinespark trick difficulty may be required to navigate around.\nNote that this does not exclude items that require shinesparking in vanilla to obtain.\nUse the ShinesparkLocations location group for that.", "randomizable": true, "visibility": 15, "type": "Choice", "default": 0, "choices": [{"name": "none", "display_name": "None", "value": 0}, {"name": "beginner", "display_name": "Beginner", "value": 1}, {"name": "advanced", "display_name": "Advanced", "value": 2}]}, {"name": "WallJumpTrickDifficulty", "display_name": "Wall Jump Trick Difficulty", "description": "What level of wall jump trick difficulty may be required to navigate around.", "randomizable": true, "visibility": 15, "type": "Choice", "default": 0, "choices": [{"name": "none", "display_name": "None", "value": 0}, {"name": "beginner", "display_name": "Beginner", "value": 1}, {"name": "advanced", "display_name": "Advanced", "value": 2}]}, {"name": "CombatDifficulty", "display_name": "Combat Difficulty", "description": "What level of combat tools are logically expected for later game bosses.", "randomizable": true, "visibility": 15, "type": "Choice", "default": 0, "choices": [{"name": "beginner", "display_name": "Beginner", "value": 0}, {"name": "advanced", "display_name": "Advanced", "value": 1}, {"name": "expert", "display_name": "Expert", "value": 2}]}], "collapsed": false}, {"name": "Custom Game Mode Options", "options": [{"name": "StartingLocation", "display_name": "Starting Location", "description": "Your starting location.\nThis is a Custom Game Mode option and will only be applied if GameMode is set to Custom.", "randomizable": true, "visibility": 15, "type": "Choice", "default": 0, "choices": [{"name": "docking_bay", "display_name": "Docking Bay", "value": 0}, {"name": "operations_deck", "display_name": "Operations Deck", "value": 1}, {"name": "sector_hub", "display_name": "Sector Hub", "value": 2}, {"name": "concourse_save_station", "display_name": "Concourse Save Station", "value": 3}]}, {"name": "StartingMajorUpgrades", "display_name": "Starting Major Upgrades", "description": "How many major upgrades you begin with.\nNote that depending on your StartingLocation and EarlyProgression settings, you may receive more than specified here\nin order to successfully generate the game. Upgrades are taken from the general item pool and will be replaced\nby a random filler item.\nThese will be applied in addition to your start_inventory and start_inventory_from_pool items.\nThese will be sent by the client once you're connected.\nThis is a Custom Game Mode option and will only be applied if GameMode is set to Custom.", "randomizable": true, "visibility": 15, "type": "Range", "default": 0, "min": 0, "max": 22}, {"name": "StartingEnergyTanks", "display_name": "Starting Energy Tanks", "description": "How many Energy Tanks you begin with.\nThis will be overridden by the number specified in start_inventory and start_inventory_from_pool, if applicable.\nEnergy tanks are taken from the general item pool and will be replaced by a random filler item.\nThese will be sent by the client once you're connected.\nThis is a Custom Game Mode option and will only be applied if GameMode is set to Custom.", "randomizable": true, "visibility": 15, "type": "Range", "default": 0, "min": 0, "max": 20}, {"name": "FillerItems", "display_name": "Filler Items", "description": "Which Items are used as filler when Items are removed from the pool\nWhenever an item is removed from the pool by start_inventory_from_pool, StartingMajorUpgrades, StartingEnergyTanks,\nor for other reasons, it will be replaced with a random item from this list.\nThis is a Custom Game Mode option and will only be applied if GameMode is set to Custom.", "randomizable": false, "visibility": 15, "type": "OptionSet", "default": ["Missile Tank", "Power Bomb Tank"], "options": ["Level 0 Keycard", "Missile Data", "Morph Ball", "Charge Beam", "Level 1 Keycard", "Bomb Data", "Hi-Jump", "Speed Booster", "Level 2 Keycard", "Super Missile", "Varia Suit", "Level 3 Keycard", "Ice Missile", "Wide Beam", "Power Bomb Data", "Space Jump", "Plasma Beam", "Gravity Suit", "Level 4 Keycard", "Diffusion Missile", "Wave Beam", "Screw Attack", "Ice Beam", "Missile Tank", "Energy Tank", "Power Bomb Tank", "Ice Trap", "Infant Metroid", "Nothing", "MajorUpgrades", "Everything"]}, {"name": "OpenSectorElevators", "display_name": "Open Sector Elevators", "description": "Determines if the sector elevators in the Sector Hub are locked by their vanilla keycard requirements.\nThis is a Custom Game Mode option and will only be applied if GameMode is set to Custom.", "randomizable": true, "visibility": 15, "type": "Toggle", "default": false}, {"name": "SectorNavigationRoomHintLocks", "display_name": "Sector Navigation Room Hint Locks", "description": "Determines if the Navigation Rooms at the start of each sector have their hints locked by keycard requirements.\nIf set, the keycard required for the hint will be one level higher than the level needed to access the sector\nin vanilla. Has no effect if EnableHints is disabled.\nThis is a Custom Game Mode option and will only be applied if GameMode is set to Custom.", "randomizable": true, "visibility": 15, "type": "Toggle", "default": false}], "collapsed": false}, {"name": "Minor Options", "options": [{"name": "PaletteRandomization", "display_name": "Palette Randomization", "description": "Randomize the ingame palettes.", "randomizable": true, "visibility": 15, "type": "Toggle", "default": false}, {"name": "EnableHints", "display_name": "Enable Hints", "description": "Enable ingame hints at Navigation Stations.", "randomizable": true, "visibility": 15, "type": "Toggle", "default": true}, {"name": "NerfGeronWeaknesses", "display_name": "Nerf Geron Weaknesses", "description": "Makes Gerons only weak to their 'intended' values.", "randomizable": true, "visibility": 15, "type": "Toggle", "default": false}, {"name": "RevealHiddenBlocks", "display_name": "Reveal Hidden Blocks", "description": "Enables whether destructible blocks are revealed from the start.", "randomizable": true, "visibility": 15, "type": "Toggle", "default": true}, {"name": "FastDoorTransitions", "display_name": "Fast Door Transitions", "description": "Enables fast door transitions between rooms.", "randomizable": true, "visibility": 15, "type": "Toggle", "default": true}, {"name": "MissileDataAmmo", "display_name": "Missile Data Ammo", "description": "The amount of missiles provided by a Missile Data item.", "randomizable": true, "visibility": 15, "type": "Range", "default": 10, "min": 5, "max": 100}, {"name": "MissileTankAmmo", "display_name": "Missile Tank Ammo", "description": "The amount of missiles provided by a Missile Tank item.", "randomizable": true, "visibility": 15, "type": "Range", "default": 5, "min": 0, "max": 100}, {"name": "PowerBombDataAmmo", "display_name": "Power Bomb Data Ammo", "description": "The amount of power bombs provided by a Power Bomb Data item.", "randomizable": true, "visibility": 15, "type": "Range", "default": 10, "min": 5, "max": 100}, {"name": "PowerBombTankAmmo", "display_name": "Power Bomb Tank Ammo", "description": "The amount of power bombs provided by a Power Bomb Tank item.", "randomizable": true, "visibility": 15, "type": "Range", "default": 2, "min": 0, "max": 100}], "collapsed": false}, {"name": "Item & Location Options", "options": [{"name": "local_items", "display_name": "Local Items", "description": "Forces these items to be in their native world.", "randomizable": false, "visibility": 15, "type": "OptionSet", "default": [], "options": ["Level 0 Keycard", "Missile Data", "Morph Ball", "Charge Beam", "Level 1 Keycard", "Bomb Data", "Hi-Jump", "Speed Booster", "Level 2 Keycard", "Super Missile", "Varia Suit", "Level 3 Keycard", "Ice Missile", "Wide Beam", "Power Bomb Data", "Space Jump", "Plasma Beam", "Gravity Suit", "Level 4 Keycard", "Diffusion Missile", "Wave Beam", "Screw Attack", "Ice Beam", "Missile Tank", "Energy Tank", "Power Bomb Tank", "Ice Trap", "Infant Metroid", "Nothi
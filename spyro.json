{"name": "spyro", "game": "Spyro the Dragon", "version": "0.0.0", "hidden": false, "groups": [{"name": "Game Options", "options": [{"name": "progression_balancing", "display_name": "Progression Balancing", "description": "A system that can move progression earlier, to try and prevent the player from getting stuck and bored early.\n\nA lower setting means more getting stuck. A higher setting means less getting stuck.", "randomizable": true, "visibility": 15, "type": "NamedRange", "default": 50, "min": 0, "max": 99, "presets": {"disabled": 0, "normal": 50, "extreme": 99}}, {"name": "accessibility", "display_name": "Accessibility", "description": "Set rules for reachability of your items/locations.\n\n**Full:** ensure everything can be reached and acquired.\n\n**Minimal:** ensure what is needed to reach your goal can be acquired.", "randomizable": true, "visibility": 15, "type": "Choice", "default": 0, "choices": [{"name": "full", "display_name": "Full", "value": 0}, {"name": "minimal", "display_name": "Minimal", "value": 2}]}, {"name": "goal", "display_name": "Goal", "description": "Choose the victory condition for this world.\n\ngnasty: Defeat Gnasty Gnorc\nloot: Reach the vortex at the end of Gnasty's Loot", "randomizable": true, "visibility": 15, "type": "Choice", "default": 0, "choices": [{"name": "gnasty", "display_name": "Gnasty", "value": 0}, {"name": "loot", "display_name": "Loot", "value": 1}]}, {"name": "starting_world", "display_name": "Starting Homeworld", "description": "Choose which homeworld to start in.\n\nOptions are:\nartisans\npeace_keepers\nmagic_crafters\nbeast_makers\ndream_weavers", "randomizable": true, "visibility": 15, "type": "Choice", "default": 0, "choices": [{"name": "artisans", "display_name": "Artisans", "value": 0}, {"name": "peace_keepers", "display_name": "Peace Keepers", "value": 1}, {"name": "magic_crafters", "display_name": "Magic Crafters", "value": 2}, {"name": "beast_makers", "display_name": "Beast Makers", "value": 3}, {"name"
fault": 0, "min": 0, "max": 15}, {"name": "extra_cubes", "display_name": "Extra Golden Cubes", "description": "Adds extra golden cubes to allow for easier goal completion.\n\nWill only place up to the number of available locations.", "randomizable": true, "visibility": 15, "type": "Range", "default": 0, "min": 0, "max": 32}, {"name": "shuffle_clock_antis", "display_name": "Shuffle Clock Antis", "description": "Whether to add the anti-cubes from the clock tower to the location pool ('true' means you'll likely need to change system time or wait upto a month).", "randomizable": true, "visibility": 15, "type": "Toggle", "default": false}, {"name": "knowledge_logic", "display_name": "Knowledge Logic", "description": "Whether to have knowledge sources required for logic (e.g. Counting Cube needed before Bell Tower Anti-Cube)", "randomizable": true, "visibility": 15, "type": "Toggle", "default": false}], "collapsed": false}, {"name": "Filler Items", "options": [{"name": "trap_percentage", "display_name": "Trap Percentage", "description": "Replaces filler items with traps, at the specified rate.", "randomizable": true, "visibility": 15, "type": "Range", "default": 50, "min": 0, "max": 100}, {"name": "trap_weights", "display_name": "Trap Weights", "description": "Specify the weights determining how many of each trap item will be in your itempool.\n\nIf you don't want a specific type of trap, you can set the weight for it to 0.", "randomizable": false, "visibility": 15, "type": "OptionCounter", "default": {"Rotation Trap": 1}, "min": 0, "max": null, "options": ["Rotation Trap"]}], "collapsed": false}, {"name": "Misc", "options": [{"name": "disable_visual_pain", "display_name": "Disable Visual Pain", "description": "Disables effects that are make eyes not happy like (quantum room and lightning)\n\nNOTE: For the lightning levels, the invisible triles remain invisible due to a bug that crashes the game if rendering them.\n      Hopefully this will be fixed for a future release."
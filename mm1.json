{"name": "mm1", "game": "Mega Man", "version": "0.1.1", "hidden": false, "groups": [{"name": "Game Options", "options": [{"name": "death_link", "display_name": "Death Link", "description": "When you die, everyone who enabled death link dies. Of course, the reverse is true too.", "randomizable": true, "visibility": 15, "type": "Toggle", "default": false}, {"name": "progression_balancing", "display_name": "Progression Balancing", "description": "A system that can move progression earlier, to try and prevent the player from getting stuck and bored early.\n\nA lower setting means more getting stuck. A higher setting means less getting stuck.", "randomizable": true, "visibility": 15, "type": "NamedRange", "default": 50, "min": 0, "max": 99, "presets": {"disabled": 0, "normal": 50, "extreme": 99}}, {"name": "accessibility", "display_name": "Accessibility", "description": "Set rules for reachability of your items/locations.\n\n**Full:** ensure everything can be reached and acquired.\n\n**Minimal:** ensure what is needed to reach your goal can be acquired.", "randomizable": true, "visibility": 15, "type": "Choice", "default": 0, "choices": [{"name": "full", "display_name": "Full", "value": 0}, {"name": "minimal", "display_name": "Minimal", "value": 2}]}, {"name": "starting_robot_master", "display_name": "Starting Robot Master", "description": "The initial stage unlocked at the start.", "randomizable": true, "visibility": 15, "type": "Choice", "default": "random", "choices": [{"name": "cut_man", "display_name": "Cut Man", "value": 0}, {"name": "ice_man", "display_name": "Ice Man", "value": 1}, {"name": "bomb_man", "display_name": "Bomb Man", "value": 2}, {"name": "fire_man", "display_name": "Fire Man", "value": 3}, {"name": "elec_man", "display_name": "Elec Man", "value": 4}, {"name": "guts_man", "display_name": "Guts Man", "value": 5}]}, {"name": "required_weapons", "display_name": "Required Weapon Count", "description": "Number of weapons required to be received in order to unlock Wily's Castle.\nNote that at least one of the Super Arm or Elec Beam will always be required, alongside the Magnet Beam.", "randomizable": true, "visibility": 15, "type": "Range", "default": 3, "min": 1, "max": 6}, {"name": "strict_weakness", "display_name": "Strict Boss Weaknesses", "description": "Only your starting Robot Master will take damage from the Mega Buster, the rest must be defeated with weapons.\nWeapons that only do 1-3 damage to bosses no longer deal damage (aside from Alien).", "randomizable": true, "visibility": 15, "type": "Toggle", "default": false}, {"name": "random_weakness", "display_name": "Random Boss Weaknesses", "description": "None: Bosses will have their regular weaknesses.\nShuffled: Weapon damage will be shuffled amongst the weapons, so Elec Beam may do Rolling Cutter damage.\nSuper Arm will do a random amount of damage to susceptible bosses.\nRandomized: Weapon damage will be fully randomized.", "randomizable": true, "visibility": 15, "type": "Choice", "default": 0, "choices": [{"name": "none", "display_name": "None", "value": 0}, {"name": "shuffled", "display_name": "Shuffled", "value": 1}, {"name": "randomized", "display_name": "Randomized", "value": 2}]}, {"name": "plando_weakness", "display_name": "Plando Weaknesses", "description": "Specify specific damage numbers for enemy/boss damage. Can be used even without strict/random/enemy weaknesses.\nplando_weakness:\n    Robot Master:\n        Weapon: Damage", "randomizable": false, "visibility": 15, "type": "Unknown"}, {"name": "enemy_weakness", "display_name": "Random Enemy Weaknesses", "description": "Randomizes the damage dealt to enemies by weapons.", "randomizable": true, "visibility": 15, "type": "Toggle", "default": false}, {"name": "consumables", "display_name": "Consumables", "description": "Whether in-stage consumable pickups should be randomized. This includes the Yashichi.", "randomizable": true, "visibility": 15, "type": "Toggle", "default": false}, {"name": "energy_link", "display_name": "EnergyLink", "description": "Enables EnergyLink support.\nWhen enabled, pickups dropped from enemies are sent to the EnergyLink pool, and healing/weapon energy/1-Ups can\nbe requested from the EnergyLink pool.\nSome of the energy sent to the pool will be lost on transfer.", "randomizable": true, "visibility": 0, "type": "Toggle", "default": false}, {"name": "palette_shuffle", "display_name": "Palette Shuffle", "description": "Change the color of Mega Man and the Robot Masters.\nNone: The palettes are unchanged.\nShuffled: Palette colors are shuffled amongst the robot masters.\nRandomized: Random (usually good) palettes are generated for each robot master.\nSingularity: one palette is generated and used for all robot masters.\nSupports custom palettes using HTML named colors in the\nfollowing format: Mega Buster-Lavender|Violet;randomized\nThe first value is the character whose palette you'd like to define, then separated by - is a set of 2 colors for\nthat character. separate every color with a pipe, and separate every character as well as the remaining shuffle with\na semicolon.", "randomizable": true, "visibility": 15, "type": "TextChoice", "default": 0, "choices": [{"name": "none", "display_name": "None", "value": 0}, {"name": "shuffled", "display_name": "Shuffled", "value": 1}, {"name": "randomized", "display_name": "Randomized", "value": 2}, {"name": "singularity", "display_name": "Singularity", "value": 3}]}, {"name": "random_music", "display_name": "Random Music", "description": "Vanilla: music is unchanged\nShuffled: stage and certain menu music is shuffled.\nRandomized: stage and certain menu music is randomly selected\nNone: no music will play", "randomizable": true, "visibility": 15, "type": "Choice", "default": 0, "choices": [{"name": "vanilla", "display_name": "Vanilla", "value": 0}, {"name": "shuffled", "display_name": "Shuffled", "value": 1}, {"name": "randomized", "display_name": "Randomized", "value": 2}, {"name": "none", 
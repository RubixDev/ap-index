{"name": "messenger", "game": "The Messenger", "version": "0.0.0", "hidden": false, "groups": [{"name": "Game Options", "options": [{"name": "progression_balancing", "display_name": "Progression Balancing", "description": "A system that can move progression earlier, to try and prevent the player from getting stuck and bored early.\n\nA lower setting means more getting stuck. A higher setting means less getting stuck.", "randomizable": true, "visibility": 15, "type": "NamedRange", "default": 50, "min": 0, "max": 99, "presets": {"disabled": 0, "normal": 50, "extreme": 99}}, {"name": "accessibility", "display_name": "Accessibility", "description": "Set rules for reachability of your items/locations.\n\n**Full:** ensure everything can be reached and acquired.\n\n**Minimal:** ensure what is needed to reach your goal can be acquired.\n\n**Items:** ensure all logically relevant items can be acquired. Some items, such as keys, may be self-locking, and\nsome locations may be inaccessible.", "randomizable": true, "visibility": 15, "type": "Choice", "default": 0, "choices": [{"name": "full", "display_name": "Full", "value": 0}, {"name": "minimal", "display_name": "Minimal", "value": 2}, {"name": "items", "display_name": "Items", "value": 1}]}, {"name": "death_link", "display_name": "Death Link", "description": "When you die, everyone who enabled death link dies. Of course, the reverse is true too.", "randomizable": true, "visibility": 15, "type": "Toggle", "default": false}, {"name": "shuffle_shards", "display_name": "Shuffle Mega Time Shards", "description": "Whether mega shards should be item locations.", "randomizable": true, "visibility": 15, "type": "Toggle", "default": false}, {"name": "traps", "display_name": "Include Traps", "description": "Whether traps should be included in the itempool.", "randomizable": true, "visibility": 15, "type": "Toggle", "default": false}, {"name": "shop_price", "display_name": "Shop Prices Modifier", "description": "Percentage modifier for shuffled item prices in shops", "randomizable": true, "visibility": 15, "type": "Range", "default": 100, "min": 25, "max": 400}, {"name": "shop_price_plan", "display_name": "Shop Price Plando", "description": "Plan specific prices on shop slots. Supports weighting", "randomizable": false, "visibility": 15, "type": "Unknown"}], "collapsed": false}, {"name": "Difficulty", "options": [{"name": "logic_level", "display_name": "Logic Level", "description": "The level of logic to use when determining what locations in your world are accessible.\n\n**Normal:** Can require damage boosts, but otherwise approachable for someone who has beaten the game.\n\n**Hard:** Expects more knowledge and tighter execution.\nHas leashing, normal clips and much tighter d-boosting in logic.", "randomizable": true, "visibility": 15, "type": "Choice", "default": 0, "choices": [{"name": "normal", "display_name": "Normal", "value": 0}, {"name": "hard", "display_name": "Hard", "value": 1}]}, {"name": "limited_movement", "display_name": "Limited Movement", "description": "Removes either rope dart or wingsuit from the itempool. Forces logic to at least hard and accessibility to minimal.", "randomizable": true, "visibility": 15, "type": "Toggle", "default": false}, {"name": "early_meditation", "display_name": "Early Meditation", "description": "Guarantees meditation will be found early", "randomizable": true, "visibility": 15, "type": "Toggle", "default": false}], "collapsed": false}, {"name": "Goal", "options": [{"name": "goal", "display_name": "Goal", "description": "Requirement to finish the game.\nTo win with the power seal hunt goal, you must enter the Music Box through the shop chest.", "randomizable": true, "visibility": 15, "type": "Choice", "default": 0, "choices": [{"name": "open_music_box", "display_name": "Open Music Box", "value": 0}, {"name": "power_seal_hunt", "display_name": "Power Seal Hunt", "value": 1}]}, {"name": "music_box", "display_name": "Music Box Gauntlet", "description": "Whether the music box gauntlet needs to be done.", "randomizable": true, "visibility": 15, "type": "Toggle", "default": true}, {"name": "notes_needed", "display_name": "Notes Needed", "description": "How many notes need to be found in order to access the Music Box.\n6 are always needed to enter, so this places the others in your start inventory.", "randomizable": true, "visibility": 15, "type": "Range", "default": 6, "min": 1, "max": 6}, {"name": "total_seals", "display_name": "Total Power Seals", "description": "Number of power seals that exist in the item pool when power seal hunt is the goal.", "randomizable": true, "visibility": 15, "type": "Range", "default": 45, "min": 1, "max": 85}, {"name": "percent_seals_required", "display_name": "Percent Seals Required", "description": "Percentage of total seals required to open the shop chest.", "randomizable": true, "visibility": 15, "type": "Range", "default": 100, "min": 10, "max": 100}], "collapsed": false}, {"name": "Entrances", "options": [{"name": "available_portals", "display_name": "Available Starting Portals", "description": "Number of portals that are available from the start. Autumn Hills, Howling Grotto, and Glacial Peak are always\navailable. If portal outputs are not randomized, Searing Crags will also be available.", "randomizable": true, "visibility": 15, "type": "Range", "default": 6, "min": 3, "max": 6}, {"name": "shuffle_portals", "display_name": "Shuffle Portal Outputs", "description": "Whether the portals lead to random places.\nEntering a portal from its vanilla area will always lead to HQ, and will unlock it if relevant.\nSupports plando.\n\n**None:** Portals will take you where they're supposed to.\n\n**Shops:** Portals can lead to any area except Music Box and Elemental Skylands, with each portal output guaranteed\nto not overlap with another portal's. Will only put you at a portal or a shop.\n\n**Checkpoints:** Like Shops except checkpoints without shops are also valid drop points.\n\n**Anywhere:** Like Checkpoints except it's possible for multiple portals to output to the same map.", "randomizable": true, "visibility": 15, "type": "Choice", "default": 0, "choices": [{"name": "none", "display_name": "None", "value": 0}, {"name": "shops", "display_name": "Shops", "value": 1}, {"name": "checkpoints", "display_name": "Checkpoints", "value": 2}, {"name": "anywhere", "display_name": "Anywhere", "value": 3}]}, {"name": "shuffle_transitions", "display_name": "Shuffle Level Transitions", "description": "Whether the transitions between the levels should be randomized.\nSupports plando.\n\n**None:** Level transitions lead where they should.\n\n**Coupled:** Returning through a transition will take you from whence you came.\n\n**Decoupled:** Any level transition can take you to any other level transition.", "randomizable": true, "visibility": 15, "type": "Choice", "default": 0, "choices": [{"name": "none", "display_name": "None", "value": 0}, {"name": "coupled", "display_name": "Coupled", "value": 1}, {"name": "decoupled", "display_name": "Decoupled", "value": 2}]}, {"name": "portal_plando", "display_name": "Portal Plando Connections", "description": "Plando connections to be used with portal shuffle.\nDocumentation on using this can be found in The Messenger plando guide.", "randomizable": false, "visibility": 13, "type": "Unknown"}, {"name": "plando_connections", "display_name": "Transition Plando Connections", "description": "Plando connections to be used with transition shuffle.\nDocumentation on using this can be found in The Messenger plando guide.", "randomizable": false, "visibility": 13, "type": "Unknown"}], "collapsed": false}, {"name": "Item & Location Options", "options": [{"name": "local_items", "display_name": "Local Items", "description": "Forces these items to be in their native world.", "randomizable": false, "visibility": 15, "type": "OptionSet", "default": [], "options": ["Key of Hope", "Key of Chaos", "Key of Courage", "Key of Love", "Key of Streng
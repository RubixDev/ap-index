{"name": "guardianlegend", "game": "The Guardian Legend", "version": "0.7.0", "hidden": false, "groups": [{"name": "Game Options", "options": [{"name": "progression_balancing", "display_name": "Progression Balancing", "description": "A system that can move progression earlier, to try and prevent the player from getting stuck and bored early.\n\nA lower setting means more getting stuck. A higher setting means less getting stuck.", "randomizable": true, "visibility": 15, "type": "NamedRange", "default": 50, "min": 0, "max": 99, "presets": {"disabled": 0, "normal": 50, "extreme": 99}}, {"name": "accessibility", "display_name": "Accessibility", "description": "Set rules for reachability of your items/locations.\n\n**Full:** ensure everything can be reached and acquired.\n\n**Minimal:** ensure what is needed to reach your goal can be acquired.", "randomizable": true, "visibility": 15, "type": "Choice", "default": 0, "choices": [{"name": "full", "display_name": "Full", "value": 0}, {"name": "minimal", "display_name": "Minimal", "value": 2}]}, {"name": "balanced_rapid_fire", "display_name": "Balanced Rapid Fire", "description": "Makes the upgrade power of Rapid Fire more evenly distributed, and gives a slightly faster starting speed.\n\nTrue: 10/8/6/4/2/1 frames per shot.\nFalse: 12/5/4/3/2/1 frames per shot (vanilla behavior).", "randomizable": true, "visibility": 15, "type": "Toggle", "default": true}, {"name": "item_distribution", "display_name": "Item Distribution", "description": "Determines how many copies of items and upgrades exist in the item pool. \nNote that vanilla maximums still apply, the extra copies only make it more likely to max out earlier.\nFiller items (EEs and Energy Packs) are distributed based on intended relative difficulty.\n\nVanilla: Uses the vanilla item distribution, where possible. Some items have extra copies, some don't.\nExact: Only the exact number of items needed to max out stats and subweapons is provided.\nReduced: Reduced maximum for stats and subweapons. This will make the game much harder!\nExtra: Some extra copies of all items are added to the pool. This will make the game slightly easier.\n\n(Developer note: Extra is recommended for Sync games, Exact for Async. Reduced may result in brutal difficulty!)", "randomizable": true, "visibility": 15, "type": "Choice", "default": 3, "choices": [{"name": "vanilla", "display_name": "Vanilla", "value": 0}, {"name": "exact", "display_name": "Exact", "value": 1}, {"name": "reduced", "display_name": "Reduced", "value": 2}, {"name": "extra", "display_name": "Extra", "value": 3}]}, {"name": "item_gating", "display_name": "Area Gating Strength", "description": "Determines how much offensive and defensive power is needed before putting each Area in logic. \nHigher settings will be easier but more likely to follow the vanilla game Area order.\n\nTotals required for Area 10 - \nLow: 7 Defense, 9 Offense\nNormal: 9 Defense, 12 Offense\nHigh: 12 Defense, 16 Offense\n\n(Developer notes: In the Offense totals, Attack Up counts as double.\nHigh is recommended for most players, as lower gating can result in having to do late-game areas \n while severely underpowered.)", "randomizable": true, "visibility": 15, "type": "Choice", "default": 2, "choices": [{"name": "low", "display_name": "Low", "value": 0}, {"name": "normal", "display_name": "Normal", "value": 1}, {"name": "high", "display_name": "High", "value": 2}]}, {"name": "corridor_hints", "display_name": "Corridor 11-20 Hints", "description": "The rooms that normally explain how to open Corridor 1-10 will instead have hints for\nthe classification of items in Corridor 11-20. Choose how many Corridors receive hints.\n(If less than 10 is chosen, hinted corridors will be randomly selected.)", "randomizable": true, "visibility": 15, "type": "NamedRange", "default": 0, "min": 0, "max": 10, "presets": {"none": 0, "all": 10, "half": 5}}, {"name": "randomize_map", "display_name": "Enable Map Randomization", "description":
{"name": "paint", "game": "Paint", "version": "0.5.2", "hidden": false, "groups": [{"name": "Game Options", "options": [{"name": "progression_balancing", "display_name": "Progression Balancing", "description": "A system that can move progression earlier, to try and prevent the player from getting stuck and bored early.\n\nA lower setting means more getting stuck. A higher setting means less getting stuck.", "randomizable": true, "visibility": 15, "type": "NamedRange", "default": 50, "min": 0, "max": 99, "presets": {"disabled": 0, "normal": 50, "extreme": 99}}, {"name": "accessibility", "display_name": "Accessibility", "description": "Set rules for reachability of your items/locations.\n\n**Full:** ensure everything can be reached and acquired.\n\n**Minimal:** ensure what is needed to reach your goal can be acquired.", "randomizable": true, "visibility": 15, "type": "Choice", "default": 0, "choices": [{"name": "full", "display_name": "Full", "value": 0}, {"name": "minimal", "display_name": "Minimal", "value": 2}]}, {"name": "logic_percent", "display_name": "Logic Percent", "description": "Sets the maximum percent similarity required for a check to be in logic.\nHigher values are more difficult and items/locations will not be generated beyond this number.", "randomizable": true, "visibility": 15, "type": "Range", "default": 80, "min": 50, "max": 95}, {"name": "goal_percent", "display_name": "Goal Percent", "description": "Sets the percent similarity required to achieve your goal.\nIf this number is higher than the value for logic percent,\nreaching goal will be in logic upon obtaining all progression items.", "randomizable": true, "visibility": 15, "type": "Range", "default": 80, "min": 50, "max": 95}, {"name": "half_percent_checks", "display_name": "Half Percent Checks", "description": "Sets the lowest percent at which locations will be created for each 0.5% of similarity.\nBelow this number, there will be a check every 1%.\nAbove this number, there will be a check e
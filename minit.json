{"name": "minit", "game": "Minit", "version": "0.6.11", "hidden": false, "groups": [{"name": "Game Options", "options": [{"name": "progression_balancing", "display_name": "Progression Balancing", "description": "A system that can move progression earlier, to try and prevent the player from getting stuck and bored early.\n\nA lower setting means more getting stuck. A higher setting means less getting stuck.", "randomizable": true, "visibility": 15, "type": "NamedRange", "default": 50, "min": 0, "max": 99, "presets": {"disabled": 0, "normal": 50, "extreme": 99}}, {"name": "accessibility", "display_name": "Accessibility", "description": "Set rules for reachability of your items/locations.\n\n**Full:** ensure everything can be reached and acquired.\n\n**Minimal:** ensure what is needed to reach your goal can be acquired.", "randomizable": true, "visibility": 15, "type": "Choice", "default": 0, "choices": [{"name": "full", "display_name": "Full", "value": 0}, {"name": "minimal", "display_name": "Minimal", "value": 2}]}, {"name": "starting_sword", "display_name": "Early Sword", "description": "Start With a Sword in vanilla Sword Location.\nor with Entrance Rando on puts one accessible from spawn", "randomizable": true, "visibility": 15, "type": "Toggle", "default": false}, {"name": "darkrooms", "display_name": "Darkrooms", "description": "Puts Darkroom navigation without FlashLight in logic.\noff: makes any darkness out of logic without flashlight\nminor: only regions where the majority of travel is lit are in logic\non: common darkrooms that require precise movement or specific map knowledge will be in logic\ninsane: darkness will never be considered out of logic", "randomizable": true, "visibility": 15, "type": "Choice", "default": 1, "choices": [{"name": "off", "display_name": "Off", "value": 0}, {"name": "minor", "display_name": "Minor", "value": 1}, {"name": "on", "display_name": "On", "value": 2}, {"name": "insane", "display_name": "Insane", "value": 3}]}, {"name": 
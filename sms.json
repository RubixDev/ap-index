{"name": "sms", "game": "Super Mario Sunshine", "version": "0.6.2", "hidden": false, "groups": [{"name": "Game Options", "options": [{"name": "progression_balancing", "display_name": "Progression Balancing", "description": "A system that can move progression earlier, to try and prevent the player from getting stuck and bored early.\n\nA lower setting means more getting stuck. A higher setting means less getting stuck.", "randomizable": true, "visibility": 15, "type": "NamedRange", "default": 50, "min": 0, "max": 99, "presets": {"disabled": 0, "normal": 50, "extreme": 99}}, {"name": "accessibility", "display_name": "Accessibility", "description": "Set rules for reachability of your items/locations.\n\n**Full:** ensure everything can be reached and acquired.\n\n**Minimal:** ensure what is needed to reach your goal can be acquired.", "randomizable": true, "visibility": 15, "type": "Choice", "default": 0, "choices": [{"name": "full", "display_name": "Full", "value": 0}, {"name": "minimal", "display_name": "Minimal", "value": 2}]}, {"name": "extra_shines", "display_name": "Extra Shines", "description": "How many extra shine sprites you want added to the pool. This is a percentage so it ranges from 0 to 90\nIf more shines would be added than locations possible it will add as many as it can", "randomizable": true, "visibility": 15, "type": "Range", "default": 15, "min": 0, "max": 90}, {"name": "death_link", "display_name": "Death Link", "description": "When you die, everyone who enabled death link dies. Of course, the reverse is true too.", "randomizable": true, "visibility": 15, "type": "Toggle", "default": false}], "collapsed": false}, {"name": "SMS Basic", "options": [{"name": "level_access", "display_name": "Level Access", "description": "If on \"vanilla\", the main levels are accessed in the way they are in the base game (e.g. Ricco Harbor is accessible after collecting 3 Shine Sprites).\nIf on \"tickets\", each level has a ticket item that must be acquired to access the level.\nTo reduce generation failures in testing, you'll automatically receive one free ticket at the start.", "randomizable": true, "visibility": 15, "type": "Choice", "default": 0, "choices": [{"name": "vanilla", "display_name": "Vanilla", "value": 0}, {"name": "tickets", "display_name": "Tickets", "value": 1}]}, {"name": "enable_coin_shines", "display_name": "Enable 100 Coin Shines", "description": "Turn off to ignore the 100 coin Shine Sprites, which removes 8 Shine Sprites from the pool.\nYou can still collect them, but they don't do anything.", "randomizable": true, "visibility": 15, "type": "Toggle", "default": false}, {"name": "corona_mountain_shines", "display_name": "Corona Mountain Shines", "description": "How many Shine Sprites are required to access Corona Mountain and the Delfino Airstrip revisit.\nIf this is more than the locations available, This will be automatically adjusted to 90-80% of locations available\nafter all other progression items are created / accounted for.", "randomizable": true, "visibility": 15, "type": "Range", "default": 50, "min": 0, "max": 345}, {"name": "nozzle_boxes", "display_name": "Enable Nozzle Boxes", "description": "Enables Nozzle Boxes as a location.", "randomizable": true, "visibility": 15, "type": "Toggle", "default": false}, {"name": "all_shines_selectable", "display_name": "All Shines Selectable", "description": "Enables you to select every shine without having to complete each in order.\nYou will still need access to each hub (Gelato Beach, Noki Bay, Pinna Park, etc.)", "randomizable": true, "visibility": 15, "type": "Toggle", "default": false}, {"name": "blue_coin_sanity", "display_name": "Blue Coinsanity", "description": "Full shuffle: adds Blue Coins to the pool and makes Blue Coins locations.\nTrade Shines Only: Adds the trade shines from the boathouse. Will NOT add the blue coin locations though.", "randomizable": true, "visibility": 15, "type": "Choice", "default": 0, "choices": [{"name": "no_blue_coins", "display_name": "No Blue Coins", "value": 0}, {"name": "full_shuffle", "display_name": "Full Shuffle", "value": 1}, {"name": "trade_shines_only", "display_name": "Trade Shines Only", "value": 2}]}, {"name": "blue_coin_maximum", "display_name": "Blue Coin Maximum", "description": "How many Blue Coins to include in the pool if Blue Coinsanity is on.\nDoes nothing if Blue Coinsanity full_shuffle is off.\nCorresponding trade shines will be removed from locations.\nRemoved Blue Coins will be replaced by other items in the pool, such as filler, to fill the\n    remaining Blue Coin locations.\nExample: You only want 220 of the 240 possible blue coins, the other 20 spots will be filled by other items.", "randomizable": true, "visibility": 15, "type": "Range", "default": 240, "min": 0, "max": 240}, {"name": "trade_shine_maximum", "display_name": "Trade Shine Maximum", "description": "The number of Shines from the boathouse trades that will be shuffled. If the Blue Coin Maximum is not enough\nto obtain this amount, it will decrease automatically.\nKeep in mind that if this value is too high, there is a chance you will have to nearly 100% the game.", "randomizable": true, "visibility": 15, "type": "Range", "default": 12, "min": 0, "max": 24}, {"name": "starting_nozzle", "display_name": "Starting Nozzle", "description": "If on, you will start with no Spray Nozzle, and in fact, no FLUDD at all. (Still in non-enforce mode)\nYou will skip directly to Delfino Plaza, and the first Airstrip mission will be removed from locations.\nIn this early version of this setting, you are expected to spray unusual things with Hover.", "randomizable": true, "visibility": 15, "type": "Choice", "default": 0, "choices": [{"name": "spray", "display_name": "Spray", "value": 0}, {"name": "hover", "display_name": "Hover", "value": 1}, {"name": "fluddless", "display_name": "Fluddless", "value": 2}]}, {"name": "difficulty", "display_name": "Difficulty", "description": "This enables difficulty settings. Higher difficulty settings will include checks in logic that normally\nare not possible without doing difficult or unintended things. This includes spraying things with different\nnozzles, doing difficult platforming, and executing glitches.", "randomizable": true, "visibility": 15, "type": "Choice", "default": 0, "choices": [{"name": "normal", "display_name": "Normal", "value": 0}, {"name": "hard", "display_name": "Hard", "value": 1}, {"name": "advanced", "display_name": "Advanced", "value": 2}, {"name": "salty_tears", "display_name": "Salty Tears", "value": 3}]}], "collapsed": false}, {"name": "Item & Location Options", "options": [{"name": "local_items", "display_name": "Local Items", "description": "Forces these items to be in their native world.", "randomizable": false, "visibility": 15, "type": "OptionSet", "default": [], "options": ["Shine Sprite", "Blue Coin", "Spray Nozzle", "Hover Nozzle", "Rocket Nozzle", "Turbo Nozzle", "Yoshi", "Bianco Hills Ticket", "Ricco Harbor Ticket", "Gelato Beach Ticket", "Pinna Park Ticket", "Noki Bay Ticket", "Sirena Beach Ticket", "Pianta Village Ticket", "1-UP", "Everything"]}, {"name": "non_local_items", "display_name": "Non-local Items", "description": "Forces these items to be outside their native world.", "randomizable": false, "visibility": 15, "type": "OptionSet", "default": [], "options": ["Shine Sprite", "Blue Coin", "Spray Nozzle", "Hover Nozzle", "Rocket Nozzle", "Turbo Nozzle", "Yoshi", "Bianco Hills Ticket", "Ricco Harbor Ticket", "Gelato Beach Ticket", "Pinna Park Ticket", "Noki Bay Ticket", "Sirena Beach Ticket", "Pianta Village Ticket", "1-UP", "Everything"]}, {"name": "start_inventory", "display_name": "Start Inventory", "description": "Start with the specified amount of these items. Example: \"Bomb: 1\"", "randomizable": false, "visibility": 15, "type": "OptionCounter", "default": {}, "min": 0, "max": 10000, "options": ["Shine Sprite", "Blue Coin", "Spray Nozzle", "Hover Nozzle", "Rocket Nozzle", "Turbo Nozzle
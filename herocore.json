{"name": "herocore", "game": "Hero Core", "version": "0.0.0", "hidden": false, "groups": [{"name": "Game Options", "options": [{"name": "progression_balancing", "display_name": "Progression Balancing", "description": "A system that can move progression earlier, to try and prevent the player from getting stuck and bored early.\n\nA lower setting means more getting stuck. A higher setting means less getting stuck.", "randomizable": true, "visibility": 15, "type": "NamedRange", "default": 50, "min": 0, "max": 99, "presets": {"disabled": 0, "normal": 50, "extreme": 99}}, {"name": "accessibility", "display_name": "Accessibility", "description": "Set rules for reachability of your items/locations.\n\n**Full:** ensure everything can be reached and acquired.\n\n**Minimal:** ensure what is needed to reach your goal can be acquired.", "randomizable": true, "visibility": 15, "type": "Choice", "default": 0, "choices": [{"name": "full", "display_name": "Full", "value": 0}, {"name": "minimal", "display_name": "Minimal", "value": 2}]}], "collapsed": false}, {"name": "Goal Options", "options": [{"name": "difficulty", "display_name": "Difficulty", "description": "What game difficulty your world will be played on.", "randomizable": true, "visibility": 15, "type": "Choice", "default": 1, "choices": [{"name": "normal", "display_name": "Normal", "value": 1}, {"name": "hard", "display_name": "Hard", "value": 2}, {"name": "annihilation", "display_name": "Annihilation", "value": 3}]}, {"name": "goal_computers", "display_name": "Goal Computers", "description": "How many computers are required for you to enter the Final Boss room and complete the game.", "randomizable": true, "visibility": 15, "type": "Range", "default": 0, "min": 0, "max": 10}], "collapsed": false}, {"name": "Shuffle Options", "options": [{"name": "powerups", "display_name": "powerups", "description": "If enabled, the Powerups obtained from defeating bosses will contain random items,\nand the Blade, Suit, Blaster, and Pattern Scanner Power Ups can appear anywhere in the multiworld.\nOtherwise, they will be locked behind bosses at their vanilla locations.\nIf your chosen difficulty is Annihilation, this option does nothing.", "randomizable": true, "visibility": 15, "type": "Toggle", "default": true}, {"name": "level_ups", "display_name": "Shuffle Level Ups", "description": "If enabled, the Levelups obtained from defeating bosses will contain random items, \nand your Levelups can appear anywhere in the multiworld.\nOtherwise they will be locked to their vanilla locations.\nIf your chosen difficulty is Annihilation, this option does nothing.", "randomizable": true, "visibility": 15, "type": "Toggle", "default": false}, {"name": "computers", "display_name": "Shuffle Computers", "description": "If enabled, Computers will contain random items, and your Computer items can appear anywhere in the multiworld.\nOtherwise, the computers will be locked to their vanilla locations.", "randomizable": true, "visibility": 15, "type": "Toggle", "default": true}, {"name": "generators", "display_name": "generators", "description": "If enabled, destroying a generator will send a random item, \nand items that remove barriers around a generator can appear anywhere in the multiworld.", "randomizable": true, "visibility": 15, "type": "Toggle", "default": true}, {"name": "save_points", "display_name": "Shuffle Saves", "description": "If enabled, each Save Point in the game will contain a random item,\nand items containing a warp to each Save Point can appear anywhere in the multiworld.\nYou can still warp to Save Points that you reach, even if you don't have the respective item.\nYou may also additionally choose to remove the Pattern Scanner from your world.", "randomizable": true, "visibility": 15, "type": "Choice", "default": 0, "choices": [{"name": "off", "display_name": "Off", "value": 0}, {"name": "shuffle_saves", "display_name": "Shuffle Saves", "value": 1}, {"name": "shuffle_saves_no_scanner", "display_name": "Shuffle Saves No Scanner", "value": 2}]}, {"name": "doors", "display_name": "Shuffle Doors", "description": "If enabled, defeating all enemies in a room containing a locked door will send a random item,\nand items that open doors in a given room can appear anywhere in the multiworld.", "randomizable": true, "visibility": 15, "type": "Toggle", "default": false}], "collapsed": false}, {"name": "Miscellaneous", "options": [{"name": "miscellaneous_locations", "display_name": "Miscellaneous Locations", "description": "If enabled, a variety of miscellaneous locations will contain random items.\nThis includes the Ship Scan and the Shapeshift Computer in all difficulties,\nZero, the Expel Computer, and the Speedrun Times Computer in Normal and Hard,\na hidden Flower in Hard, and a Gravestone in Annihilation", "randomizable": true, "visibility": 15, "type": "Toggle", "default": false}, {"name": "expel_skips", "display_name": "Expel Skips", "description": "Whether or not the logic should expect the player to use Expel to kill otherwise out-of-reach enemies.\nIn Normal and Hard, this will allow you to enter a few areas without the Suit upgrades.\nIn Annihilation, this option does nothing.", "randomizable": true, "visibility": 15, "type": "Toggle", "default": false}, {"name": "deathlink", "display_name": "Death Link", "description": "When you die, everyone who enabled death link dies. Of course, the reverse is true too.", "randomizable": true, "visibility": 15, "type": "Toggle", "default": false}], "collapsed": false}, {"name": "Item & Location Options", "options": [{"name": "local_items", "display_name": "Local Items", "description": "Forces these items to be in their native world.", "randomizable": false, "visibility": 15, "type": "OptionSet", "default": [], "options": ["Victory!", "Level Up", "Blade Upgrade", "Suit Upgrade", "Blaster Upgrade", "Pattern Scanner", "Computer", "Health Restore", "Barrier Removal - (A,9)", "Barrier Removal - (B,9)", "Barrier Removal - (B,1
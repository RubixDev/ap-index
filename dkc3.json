{"name": "dkc3", "game": "Donkey Kong Country 3", "version": "1.1.0", "hidden": false, "groups": [{"name": "Game Options", "options": [{"name": "progression_balancing", "display_name": "Progression Balancing", "description": "A system that can move progression earlier, to try and prevent the player from getting stuck and bored early.\n\nA lower setting means more getting stuck. A higher setting means less getting stuck.", "randomizable": true, "visibility": 15, "type": "NamedRange", "default": 50, "min": 0, "max": 99, "presets": {"disabled": 0, "normal": 50, "extreme": 99}}, {"name": "accessibility", "display_name": "Accessibility", "description": "Set rules for reachability of your items/locations.\n\n**Full:** ensure everything can be reached and acquired.\n\n**Minimal:** ensure what is needed to reach your goal can be acquired.", "randomizable": true, "visibility": 15, "type": "Choice", "default": 0, "choices": [{"name": "full", "display_name": "Full", "value": 0}, {"name": "minimal", "display_name": "Minimal", "value": 2}]}, {"name": "dk_coins_for_gyrocopter", "display_name": "DK Coins for Gyrocopter", "description": "How many DK Coins are needed to unlock the Gyrocopter\n\nNote: Achieving this number before unlocking the Turbo Ski will cause the game to grant you a\none-time upgrade to the next non-unlocked boat, until you return to Funky. Logic does not assume\nthat you will use this.", "randomizable": true, "visibility": 15, "type": "Range", "default": 30, "min": 10, "max": 41}, {"name": "kongsanity", "display_name": "KONGsanity", "description": "Whether collecting all four KONG letters in each level grants a check", "randomizable": true, "visibility": 15, "type": "Toggle", "default": false}, {"name": "level_shuffle", "display_name": "Level Shuffle", "description": "Whether levels are shuffled", "randomizable": true, "visibility": 15, "type": "Toggle", "default": false}, {"name": "difficulty", "display_name": "Difficulty", "description": "Which Difficulty Lev
{"name": "mm2", "game": "Mega Man 2", "version": "0.3.3", "hidden": false, "groups": [{"name": "Game Options", "options": [{"name": "progression_balancing", "display_name": "Progression Balancing", "description": "A system that can move progression earlier, to try and prevent the player from getting stuck and bored early.\n\nA lower setting means more getting stuck. A higher setting means less getting stuck.", "randomizable": true, "visibility": 15, "type": "NamedRange", "default": 50, "min": 0, "max": 99, "presets": {"disabled": 0, "normal": 50, "extreme": 99}}, {"name": "accessibility", "display_name": "Accessibility", "description": "Set rules for reachability of your items/locations.\n\n**Full:** ensure everything can be reached and acquired.\n\n**Minimal:** ensure what is needed to reach your goal can be acquired.", "randomizable": true, "visibility": 15, "type": "Choice", "default": 0, "choices": [{"name": "full", "display_name": "Full", "value": 0}, {"name": "minimal", "display_name": "Minimal", "value": 2}]}, {"name": "death_link", "display_name": "Death Link", "description": "When you die, everyone who enabled death link dies. Of course, the reverse is true too.", "randomizable": true, "visibility": 15, "type": "Toggle", "default": false}, {"name": "energy_link", "display_name": "EnergyLink", "description": "Enables EnergyLink support.\nWhen enabled, pickups dropped from enemies are sent to the EnergyLink pool, and healing/weapon energy/1-Ups can\nbe requested from the EnergyLink pool.\nSome of the energy sent to the pool will be lost on transfer.", "randomizable": true, "visibility": 15, "type": "Toggle", "default": false}, {"name": "starting_robot_master", "display_name": "Starting Robot Master", "description": "The initial stage unlocked at the start.", "randomizable": true, "visibility": 15, "type": "Choice", "default": "random", "choices": [{"name": "heat_man", "display_name": "Heat Man", "value": 0}, {"name": "air_man", "display_name": "Air Man", "value": 1}, {"name": "wood_man", "display_name": "Wood Man", "value": 2}, {"name": "bubble_man", "display_name": "Bubble Man", "value": 3}, {"name": "quick_man", "display_name": "Quick Man", "value": 4}, {"name": "flash_man", "display_name": "Flash Man", "value": 5}, {"name": "metal_man", "display_name": "Metal Man", "value": 6}, {"name": "crash_man", "display_name": "Crash Man", "value": 7}]}, {"name": "consumables", "display_name": "Consumables", "description": "When enabled, e-tanks/1-ups/health/weapon energy will be added to the pool of items and included as checks.\nE-Tanks and 1-Ups add 20 checks to the pool.\nWeapon/Health Energy add 27 checks to the pool.", "randomizable": true, "visibility": 15, "type": "Choice", "default": 1, "choices": [{"name": "none", "display_name": "None", "value": 0}, {"name": "1up_etank", "display_name": "1-Ups/E-Tanks", "value": 1}, {"name": "weapon_health", "display_name": "Weapon/Health Energy", "value": 2}, {"name": "all", "display_name": "All", "value": 3}]}, {"name": "yoku_jumps", "display_name": "Yoku Block Jumps", "description": "When enabled, the player is expected to be able to perform the yoku block sequence in Heat Man's\nstage without Item 2.", "randomizable": true, "visibility": 15, "type": "Toggle", "default": false}, {"name": "enable_lasers", "display_name": "Enable Lasers", "description": "When enabled, the player is expected to complete (and acquire items within) the laser sections of Quick Man's\nstage without the Time Stopper.", "randomizable": true, "visibility": 15, "type": "Toggle", "default": false}, {"name": "enemy_weakness", "display_name": "Random Enemy Weaknesses", "description": "Randomizes the damage dealt to enemies by weapons. Friender will always take damage from the buster.", "randomizable": true, "visibility": 15, "type": "Toggle", "default": false}, {"name": "strict_weakness", "display_name": "Strict Boss Weaknesses", "description": "Only your starting Robot Master will take damage from the Mega Buster, the rest must be defeated with weapons.\nWeapons that only do 1-3 damage to bosses no longer deal damage (aside from Alien).", "randomizable": true, "visibility": 15, "type": "Toggle", "default": false}, {"name": "random_weakness", "display_name": "Random Boss Weaknesses", "description": "None: Bosses will have their regular weaknesses.\nShuffled: Weapon damage will be shuffled amongst the weapons, so Metal Blade may do Bubble Lead damage.\nTime Stopper will deplete half of a random Robot Master's HP.\nRandomized: Weapon damage will be fully randomized.", "randomizable": true, "visibility": 15, "type": "Choice", "default": 0, "choices": [{"name": "none", "display_name": "None", "value": 0}, {"name": "shuffled", "display_name": "Shuffled", "value": 1}, {"name": "randomized", "display_name": "Randomized", "value": 2}]}, {"name": "wily_5_requirement", "display_name": "Wily 5 Requirement", "description": "Change the number of Robot Masters that are required to be defeated for\nthe teleporter to the Wily Machine to appear.", "randomizable": true, "visibility": 15, "type": "Range", "default": 8, "min": 1, "max": 8}, {"name": "plando_weakness", "display_name": "Plando Weaknesses", "description": "Specify specific damage numbers for boss damage. Can be used even without strict/random weaknesses.\nplando_weakness:\n    Robot Master:\n        Weapon: Damage", "randomizable": false, "visibility": 13, "type": "Unknown"}, {"name": "palette_shuffle", "display_name": "Palette Shuffle", "description": "Change the color of Mega Man and the Robot Masters.\nNone: The palettes are unchanged.\nShuffled: Palette colors are shuffled amongst the robot masters.\nRandomized: Random (usually good) palettes are generated for each robot master.\nSingularity: one palette is generated and used for all robot masters.\nSupports custom palettes using HTML named colors in the\nfollowing format: Mega Buster-Lavender|Violet;randomized\nThe first value is the character whose palette you'd like to define, then separated by - is a set of 2 colors for\nthat character. separate every color with a pipe, and separate every character as well as the remaining shuffle with\na semicolon.", "randomizable": true, "visibility": 15, "type": "TextChoice", "default": 0, "choices": [{"name": "none", "display_name": "None", "value": 0}, {"name": "shuffled", "display_name": "Shuffled", "value": 1}, {"name": "randomized", "display_name": "Randomized", "value": 2}, {"name": "singularity", "display_name": "Singularity", "value": 3}]}, {"name": "quickswap", "display_name": "Quickswap", "description": "When enabled, the player can quickswap through all received weapons by pressing Select.", "randomizable": true, "visibility": 15, "type": "Toggle", "default": true}, {"name": "reduce_flashing", "display_name": "Reduce Flashing", "description": "Reduce flashing seen in gameplay, such as the stage select and when defeating a Wily boss.\nVirtual Console: increases length of most flashes, changes some flashes from white to a dark gray.\nMinor: VC changes + decreasing the speed of Bubble/Metal Man stage animations.\nFull: VC changes + further decreasing the brightness of most flashes and\ndisables stage animations for Metal/Bubble Man stages.", "randomizable": true, "visibility": 15, "type": "Choice", "default": 1, "choices": [{"name": "none", "display_name": "None", "value": 0}, {"name": "virtual_console", "display_name": "Virtual Console", "value": 1}, {"name": "minor", "display_name": "Minor", "value": 2}, {"name": "full", "display_name": "Full", "value": 3}]}, {"name": "random_music", "display_name": "Random Music", "description": "Vanilla: music is unchanged\nShuffled: stage and certain menu music is shuffled.\nRandomized: stage and certain menu music is randomly selected\nNone: no music will play", "randomizable": true, "visibility": 15, "type": "Choice", "default": 0, "choices": [{"name": "vanilla", "display_name": "Vanilla", "value": 0}, {"name": "shuffled", "display_name": "Shuffle
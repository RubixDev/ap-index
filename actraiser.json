{"name": "actraiser", "game": "Actraiser", "version": "1.3.4", "hidden": false, "groups": [{"name": "Game Options", "options": [{"name": "progression_balancing", "display_name": "Progression Balancing", "description": "A system that can move progression earlier, to try and prevent the player from getting stuck and bored early.\n\nA lower setting means more getting stuck. A higher setting means less getting stuck.", "randomizable": true, "visibility": 15, "type": "NamedRange", "default": 50, "min": 0, "max": 99, "presets": {"disabled": 0, "normal": 50, "extreme": 99}}, {"name": "accessibility", "display_name": "Accessibility", "description": "Set rules for reachability of your items/locations.\n\n**Full:** ensure everything can be reached and acquired.\n\n**Minimal:** ensure what is needed to reach your goal can be acquired.", "randomizable": true, "visibility": 15, "type": "Choice", "default": 0, "choices": [{"name": "full", "display_name": "Full", "value": 0}, {"name": "minimal", "display_name": "Minimal", "value": 2}]}, {"name": "crystal_count", "display_name": "Crystal Count", "description": "Number of Dheim Crystals required to access Death Heim, \nif Pool Crystal is disabled this value should not exceed 6", "randomizable": true, "visibility": 15, "type": "Range", "default": 6, "min": 6, "max": 40}, {"name": "level_count", "display_name": "Level Count", "description": "Amount of Level Up items added into the pool. \nThis is seperate from the Level Up locations that are checks.\na lower number may result in a slower and harder run", "randomizable": true, "visibility": 15, "type": "Range", "default": 16, "min": 9, "max": 16}, {"name": "random_level", "display_name": "Random Level Requirement", "description": "Randomizes the level requirement to enter each first act of an action stage.", "randomizable": true, "visibility": 15, "type": "Toggle", "default": false}], "collapsed": false}, {"name": "Goal Options", "options": [{"name": "population_goal", "display_name": 
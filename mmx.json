{"name": "mmx", "game": "Mega Man X", "version": "1.6.2", "hidden": false, "groups": [{"name": "Game Options", "options": [{"name": "progression_balancing", "display_name": "Progression Balancing", "description": "A system that can move progression earlier, to try and prevent the player from getting stuck and bored early.\n\nA lower setting means more getting stuck. A higher setting means less getting stuck.", "randomizable": true, "visibility": 15, "type": "NamedRange", "default": 50, "min": 0, "max": 99, "presets": {"disabled": 0, "normal": 50, "extreme": 99}}, {"name": "accessibility", "display_name": "Accessibility", "description": "Set rules for reachability of your items/locations.\n\n**Full:** ensure everything can be reached and acquired.\n\n**Minimal:** ensure what is needed to reach your goal can be acquired.", "randomizable": true, "visibility": 15, "type": "Choice", "default": 0, "choices": [{"name": "full", "display_name": "Full", "value": 0}, {"name": "minimal", "display_name": "Minimal", "value": 2}]}, {"name": "death_link", "display_name": "Death Link", "description": "When you die, everyone who enabled death link dies. Of course, the reverse is true too.", "randomizable": true, "visibility": 15, "type": "Toggle", "default": false}, {"name": "damage_link", "display_name": "Damage Link", "description": "Damage is shared across slots", "randomizable": true, "visibility": 15, "type": "Toggle", "default": false}, {"name": "energy_link", "display_name": "Energy Link", "description": "Enable EnergyLink support.\n\nEnergyLink in MMX2 works as a big HP and Weapon Energy pool that the players can use to request HP\nor Weapon Energy whenever they need to.\n\nYou make use of this feature by typing /heal <amount> or /refill <amount> in the client.", "randomizable": true, "visibility": 15, "type": "Toggle", "default": true}, {"name": "button_configuration", "display_name": "Button Configuration", "description": "Default buttons for every action.", "randomizable": false, "visibility": 15, "type": "Unknown"}, {"name": "pickupsanity", "display_name": "Pickupsanity", "description": "Whether collecting freestanding 1ups, HP and Weapon Energy capsules will grant a check.", "randomizable": true, "visibility": 15, "type": "Toggle", "default": false}, {"name": "early_legs", "display_name": "Early Legs", "description": "Places the Legs Upgrade item in sphere 1.", "randomizable": true, "visibility": 15, "type": "Toggle", "default": false}], "collapsed": false}, {"name": "Gameplay Options", "options": [{"name": "starting_life_count", "display_name": "Starting Life Count", "description": "How many lives to start the game with. \nNote: This number becomes the new default life count, meaning that it will persist after a game over.", "randomizable": true, "visibility": 15, "type": "Range", "default": 2, "min": 0, "max": 99}, {"name": "starting_hp", "display_name": "Starting HP", "description": "How much HP X will have at the start of the game.\nNote: Going over 32 HP may cause visual bugs in either gameplay or the pause menu.\n      The max HP is capped at 56.", "randomizable": true, "visibility": 15, "type": "Range", "default": 16, "min": 1, "max": 32}, {"name": "heart_tank_effectiveness", "display_name": "Heart Tank Effectiveness", "description": "How many units of HP each Heart tank will provide to the user.\nNote: Going over 32 HP may cause visual bugs in either gameplay or the pause menu.\n      The max HP is capped at 56.", "randomizable": true, "visibility": 15, "type": "Range", "default": 2, "min": 1, "max": 8}, {"name": "jammed_buster", "display_name": "Jammed Buster", "description": "Jams X's buster making it only able to shoot lemons.\nNote: This adds another Arms Upgrade into the item pool.", "randomizable": true, "visibility": 15, "type": "Toggle", "default": false}, {"name": "better_walljump", "display_name": "Better Wall Jump", "description": "Enables performing a dash wall jump by holding down the button instead of pressing it every time.", "randomizable": true, "visibility": 15, "type": "Toggle", "default": false}, {"name": "air_dash", "display_name": "Air Dash", "description": "Adds another Legs Upgrade that allows X to perform an Air Dash.", "randomizable": true, "visibility": 15, "type": "Toggle", "default": false}, {"name": "long_jumps", "display_name": "Long Jumps", "description": "Allows X to perform longer jumps when holding down the Dash button. Only works after getting a Legs Upgrade.", "randomizable": true, "visibility": 15, "type": "Toggle", "default": false}, {"name": "hadouken_in_pool", "display_name": "Hadouken In Pool", "description": "Adds Hadouken to the item pool.\nHadouken will deal the current HP as damage and half the current HP on strict weakness settings.", "randomizable": true, "visibility": 15, "type": "Toggle", "default": true}, {"name": "quick_charge_in_pool", "display_name": "Quick Charge In Pool", "description": "Adds Quick Charge Chip from Mega Man X5 into the item pool.\n\nHalves charge time for X-Buster and Special Weapon shots.", "randomizable": true, "visibility": 15, "type": "Toggle", "default": true}, {"name": "speedster_in_pool", "display_name": "Speedster In Pool", "description": "Adds Speedster Chip from Mega Man X5 into the item pool.\n\nIncreases walking speed by 50%", "randomizable": true, "visibility": 15, "type": "Toggle", "default": true}, {"name": "super_recover_in_pool", "display_name": "Super Recover In Pool", "description": "Adds Super Recover Chip from Mega Man X5 into the item pool.\n\nIncreases recovery from items by 25%. Also affects EnergyLink deposit rate. Doesn't affect Sub Tanks.", "randomizable": true, "visibility": 15, "type": "Toggle", "default": true}, {"name": "rapid_five_in_pool", "display_name": "Rapid Five In Pool", "description": "Adds Rapid Five Chip from Mega Man X5 into the item pool.\n\nIncreases the amount of buster shots on screen to 5.", "randomizable": true, "visibility": 15, "type": "Toggle", "default": true}, {"name": "speed_shot_in_pool", "display_name": "Speed Shot In Pool", "description": "Adds Speed Shot Chip from Mega Man X5 into the item pool.\n\nIncreases X's buster shots (lemons) horizontal speed by 50%.", "randomizable": true, "visibility": 15, "type": "Toggle", "default": true}, {"name": "buster_plus_in_pool", "display_name": "Buster Plus In Pool", "description": "Adds Buster Plus Chip from Mega Man X5 into the item pool.\n\nIncreases Buster (lemon) damage by 1.", "randomizable": true, "visibility": 15, "type": "Toggle", "default": true}, {"name": "weapon_plus_in_pool", "display_name": "Weapon Plus In Pool", "description": "Adds Weapon Plus Chip from Mega Man X6 into the item pool.\n\nIncreases Weapon damage by 1.", "randomizable": true, "visibility": 15, "type": "Toggle", "default": true}, {"name": "logic_charged_shotgun_ice", "display_name": "Charged Shotgun Ice Logic", "description": "Adds Charged Shotgun Ice as logic to some locations. Some of those may be hard to execute.", "randomizable": true, "visibility": 15, "type": "Toggle", "default": false}], "collapsed": false}, {"name": "Sigma Fortress Options", "options": [{"name": "logic_leg_sigma", "display_name": "Sigma's Fortress Legs Upgrade Logic", "description": "Sigma's Fortress will logically expect you to have the legs upgrade.", "randomizable": true, "visibility": 15, "type": "Toggle", "default": true}, {"name": "sigma_all_levels", "display_name": "Fortress Levels Bundle Unlock", "description": "Whether to unlock Sigma's Fortress 1-3 levels as a group or not.\nUnlocking level 4 requires getting all Fortress levels cleared.", "randomizable": true, "visibility": 15, "type": "Toggle", "default": false}, {"name": "sigma_open", "display_name": "Sigma Fortress Rules", "description": "Under which conditions will Sigma's Fortress open.\nIf no options are selected a multiworld item granting access to the stage will be created.\n\nMedals: Consider Maverick medals to get access to the fortress.\nWeapons: Consider weapons to get access to the fortress.\nArmor Upgrades: Consider upgrades to get access to the fortress.\nHeart Tanks: Consider heart tanks to get access to the fortress.\nSub Tanks: Consider sub tanks to get access to the fortress.", "randomizable": false, "visibility": 15, "type": "OptionSet", "default": ["Medals"], "options": ["Armor Upgrades", "Heart Tanks", "Medals", "Sub Tanks", "Weapons"]}, {"name": "sigma_medal_count", "display_name": "Sigma Medal Count", "description": "How many Maverick Medals are required to access Sigma's Fortress.", "randomizable": true, "visibility": 15, "type": "Range", "default": 8, "min": 0, "max": 8}, {"name": "sigma_weapon_count", "display_name": "Sigma Weapon Count", "description": "How many weapons are required to access Sigma's Fortress.", "randomizable": true, "visibility": 15, "type": "Range", "default": 6, "min": 0, "max": 6}, {"name": "sigma_upgrade_count", "display_name": "Sigma Armor Upgrade Count", "description": "How many armor upgrades are required to access Sigma's Fortress.", "randomizable": true, "visibility": 15, "type": "Range", "default": 3, "min": 0, "max": 4}, {"name": "sigma_heart_tank_count", "display_name": "Sigma Heart Tank Count", "description": "How many Heart Tanks are required to access Sigma's Fortress.", "randomizable": true, "visibility": 15, "type": "Range", "default": 6, "min": 0, "max": 6}, {"name": "sigma_sub_tank_count", "display_name": "Sigma Sub Tank Count", "description": "How many Sub Tanks are required to access Sigma's Fortress.", "randomizable": true, "visibility": 15, "type": "Range", "default": 2, "min": 0, "max": 2}], "collapsed": false}, {"name": "Boss Weaknesses", "options": [{"name": "boss_weakness_rando", "display_name": "Boss Weakness Randomization", "description": "Every main boss will have its weakness randomized.\nvanilla: Bosses retain their original weaknesses\nshuffled: Bosses have their weaknesses shuffled\nchaotic_double: Bosses will have two random weaknesses under the chaotic set\nchaotic_single: Bosses will have one random weakness under the chaotic set\n\nThe chaotic set makes every weapon charge level a separate weakness instead of keeping\nthem together, meaning that a boss can be weak to Charged Rolling Shield but not its\nuncharged version.", "randomizable": true, "visibility": 15, "type": "Choice", "default": 0, "choices": [{"name": "vanilla", "display_name": "Vanilla", "value": 0}, {"name": "shuffled", "display_name": "Shuffled", "value": 1}, {"name": "chaotic_double", "display_name": "Chaotic Double", "value": 3}, {"name": "chaotic_single", "display_name": "Chaotic Single", "value": 2}]}, {"name": "boss_weakness_strictness", "display_name": "Boss Weakness Strictness", "description": "How strict boss weaknesses will be.\nnot_strict: Allow every weapon to deal damage to the bosses\nweakness_and_buster: Only allow the weakness and buster to deal damage to the bosses\nweakness_and_upgraded_buster: Only allow the weakness and buster charge level 3 to deal damage to the bosses\nonly_weakness: Only the weakness will deal damage to the bosses", "randomizable": true, "visibility": 15, "type": "Choice", "default": 0, "choices": [{"name": "not_strict", "display_name": "Not Strict", "value": 0}, {"name": "weakness_and_buster", "display_name": "Weakness And Buster", "value": 1}, {"name": "weakness_and_upgraded_buster", "display_name": "Weakness And Upgraded Buster", "value": 2}, {"name": "only_weakness", "display_name": "Only Weakness", "value": 3}]}, {"name": "boss_weakness_plando", "display_name": "Button Configuration", "description": "Forces bosses to have a specific weakness. Uses the names that appear on the chaotic weakness set.\n\nFormat: \n  Boss Name: Weakness Name", "randomizable": false, "visibility": 15, "type": "Unknown"}, {"name": "boss_randomize_hp", "display_name": "Boss Randomize HP", "description": "Wheter to randomize the boss' hp or not.\noff: Bosses' HP will not be randomized\nweak: Bosses will have [1,32] HP\nregular: Bosses will have [16,48] HP\nstrong: Bosses will have [32,64] HP\nchaotic: Bosses will have [1,64] HP", "randomizable": true, "visibility": 15, "type": "Choice", "default": 0, "choices": [{"name": "off", "display_name": "Off", "value": 0}, {"name": "weak", "display_name": "Weak", "value": 1}, {"name": "regular", "display_name": "Regular", "value": 2}, {"name": "strong", "display_name": "Strong", "value": 3}, {"name": "chaotic", "display_name": "Chaotic", "value": 4}]}, {"name": "logic_boss_weakness", "display_name": "Boss Weakness Logic", "description": "Every main boss will logically expect you to have its weakness.", "randomizable": true, "visibility": 15, "type": "Toggle", "default": true}], "collapsed": false}, {"name": "Aesthetic", "options": [{"name": "player_palettes", "display_name": "Set Custom Palettes", "description": "Allows you to create colors for each weapon X has. Includes charge levels and Gold Armor customization.\nThis will override the option preset\n\nEach one expects 16 values which are mapped to X's colors.\nThe values can be in SNES RGB (bgr555) with the $ prefix or PC RGB (rgb888) with the # prefix.", "randomizable": false, "visibility": 15, "type": "Unknown"}, {"name": "palette_default", "display_name": "X Palette", "description": "Which color to use for X's default color", "randomizable": true, "visibility": 15, "type": "Choice", "default": 0, "choices": [{"name": "blue", "display_name": "Blue", "value": 0}, {"name": "gold_armor", "display_name": "Gold Armor", "value": 1}, {"name": "acid_burst", "display_name": "Acid Burst", "value": 6}, {"name": "parasitic_bomb", "display_name": "Parasitic Bomb", "value": 7}, {"name": "triad_thunder", "display_name": "Triad Thunder", "value": 8}, {"name": "spinning_blade", "display_name": "Spinning Blade", "value": 9}, {"name": "ray_splasher", "display_name": "Ray Splasher", "value": 10}, {"name": "gravity_well", "display_name": "Gravity Well", "value": 11}, {"name": "frost_shield", "display_name
{"name": "stacklands", "game": "Stacklands", "version": "0.2.5", "hidden": false, "groups": [{"name": "Game Options", "options": [{"name": "progression_balancing", "display_name": "Progression Balancing", "description": "A system that can move progression earlier, to try and prevent the player from getting stuck and bored early.\n\nA lower setting means more getting stuck. A higher setting means less getting stuck.", "randomizable": true, "visibility": 15, "type": "NamedRange", "default": 50, "min": 0, "max": 99, "presets": {"disabled": 0, "normal": 50, "extreme": 99}}, {"name": "accessibility", "display_name": "Accessibility", "description": "Set rules for reachability of your items/locations.\n\n**Full:** ensure everything can be reached and acquired.\n\n**Minimal:** ensure what is needed to reach your goal can be acquired.", "randomizable": true, "visibility": 15, "type": "Choice", "default": 0, "choices": [{"name": "full", "display_name": "Full", "value": 0}, {"name": "minimal", "display_name": "Minimal", "value": 2}]}], "collapsed": false}, {"name": "Run Settings", "options": [{"name": "boards", "display_name": "Boards", "description": "Select which boards will be included in the run.\n\nMainland Only           -> Include Mainland\nMainland and Forest     -> Include Mainland and The Dark Forest\nMainland and Island     -> Include Mainland and The Island\nAll                     -> Include Mainland, The Dark Forest and The Island\n\nAll quests for each selected board will be added as location checks.", "randomizable": true, "visibility": 15, "type": "Choice", "default": 3, "choices": [{"name": "mainland_only", "display_name": "Mainland Only", "value": 1}, {"name": "mainland_and_forest", "display_name": "Mainland And Forest", "value": 3}, {"name": "mainland_and_island", "display_name": "Mainland And Island", "value": 5}, {"name": "all", "display_name": "All", "value": 7}]}, {"name": "board_expansion_mode", "display_name": "Board Expansion Mode", "description": "Select how board expansion works in the run.\n\nVanilla -> Build the Shed / Warehouse / Lighthouse from the Ideas as per vanilla to expand the board as you like.\nItems   -> Adds 'Board Expansion' items to the item pool and disables all Sheds / Warehouses / Lighthouses when built.", "randomizable": true, "visibility": 15, "type": "Choice", "default": 0, "choices": [{"name": "vanilla", "display_name": "Vanilla", "value": 0}, {"name": "items", "display_name": "Items", "value": 1}]}, {"name": "board_expansion_amount", "display_name": "Board Expansion Amount", "description": "How much a Board Expansion item will increase the card limit by.\nIf <Board Expansion Mode> option is 'Vanilla' then this setting will be ignored.\n\nNOTE: The card limit for your run will be capped at 20 + (Expansion Amount * Expansion Count).\n      The lower you set Expansion Amount and Expansion Count, the more challenging resource management will be.\n      Physical board size will still be capped at the largest vanilla size (without Lighthouses).", "randomizable": true, "visibility": 15, "type": "Range", "default": 10, "min": 4, "max": 14}, {"name": "board_expansion_count", "display_name": "Board Expansion Count", "description": "How many 'Board Expansion' items are added to the item pool for each compatible board (Mainland & Island).\nIf <Board Expansion Mode> option is 'Vanilla' then this setting will be ignored.\n\nNOTE: The card limit for your run will be capped at 20 + (Expansion Amount * Expansion Count).\n      The lower you set Expansion Amount and Expansion Count, the more challenging resource management will be.\n      Physical board size will still be capped at the largest vanilla size (without Lighthouses).", "randomizable": true, "visibility": 15, "type": "Range", "default": 8, "min": 4, "max": 10}, {"name": "moon_length", "display_name": "Moon Length", "description": "Set the length of each moon for the run - this disables and overrides the 'Moon Length' option in the 'Start New Run' menu.", "randomizable": true, "visibility": 15, "type": "Choice", "default": 1, "choices": [{"name": "short", "display_name": "Short", "value": 0}, {"name": "normal", "display_name": "Normal", "value": 1}, {"name": "long", "display_name": "Long", "value": 2}]}, {"name": "pausing", "display_name": "Enable Pausing", "description": "The player keeps the ability to be able to pause time.\nIf disabled, time will only be paused by cutscenes and end-of-moon routines.", "randomizable": true, "visibility": 15, "type": "Toggle", "default": true}], "collapsed": false}, {"name": "Goal", "options": [{"name": "goal", "display_name": "Goal", "description": "Select the goal for the run.\n\nAll Bosses  -> Kill each boss from every board selected in the <Boards> option.\nRandom Boss -> Kill one randomly selected boss from the boards selected in the <Boards> option.\n\nMore goals to be added in future...", "randomizable": true, "visibility": 15, "type": "Choice", "default": 1, "choices": [{"name": "all_bosses", "display_name": "All Bosses", "value": 1}, {"name": "random_boss", "display_name": "Random Boss", "value": 2}]}], "collapsed": false}, {"name": "Sanities", "options": [{"name": "equipmentsanity", "display_name": "Equipmentsanity", "description": "Add checks for crafting one of each Equipment card. (E.g. Club, Sword, Blunderbuss etc.)\nWill only add checks for Equipment that are reachable on the boards selected in the <Boards> option.\n\nThis will add 16 checks to Mainland and 6 checks to The Island.", "randomizable": true, "visibility": 15, "type": "Toggle", "default": false}, {"name": "foodsanity", "display_name": "Foodsanity", "description": "Add checks for cooking one of each Food card. (E.g. Stew, Fruit Salad, Tamago Sushi etc.)\nWill only add checks for Foods that are reachable on the boards selected in the <Boards> option.\n\nThis will add 3 checks to Mainland and 3 checks to The Island.", "randomizable": true, "visibility": 15, "type": "Toggle", "default": false}, {"name": "locationsanity", "display_name": "Locationsanity", "description": "Add checks for exploring one of each Location card. (E.g. Mountain, Old Village, Jungle etc.)\nWill only add checks for Locations that are reachable on the boards selected in the <Boards> option.\n\nThis will add 4 checks to Mainland and 2 checks to The Island.", "randomizable": true, "visibility": 15, "type": "Toggle", "default": false}, {"name": "mobsanity", "display_name": "Mobsanity", "description": "Add checks for killing one of each Mob card. (E.g. Elf, Giant Snail, Tiger etc.)\nWill only add checks for Mobs that are reachable on the boards selected in the <Boards> option.\n\nThis will add 18 checks to Mainland, 3 checks to The Dark Forest and 9 checks to The Island.", "randomizable": true, "visibility": 15, "type": "Toggle", "default": false}, {"name": "mobsanity_balancing", "display_name": "Mobsanity Balancing", "description": "Greatly increases chance for all Packs / Strange Portals / Dark Forest Waves to spawn reachable Mobs that you have not yet killed.\n\nIt is recommended to set this to 'true' to prevent relying on RNG to reach all Mobsanity checks.\nIf set to 'false' you will be at the mercy of RNG to spawn all Mob types to reach all Mobsanity checks.\n\nThis setting is ignored if the <Mobsanity> option is 'false'.", "randomizable": true, "visibility": 15, "type": "Toggle", "default": true}, {"name": "structuresanity", "display_name": "Structuresanity", "description": "Add checks for building one of each reachable Structure card. (E.g Garden, Market, Distillery etc.)\nWill only add checks for Structures that are reachable on the boards selected in the <Boards> option.\n\nThis will add 16 checks to Mainland and 10 checks to The Island.", "randomizable": true, "visibility": 15, "type": "Toggle", "default": false}], "collapsed": false}, {"name": "Traps", "options": [{"name": "trap_fill", "display_name": "Trap Fill Percentage", "description": "The percentage of the filler item pool that should be populated with trap items.\n\n0   -> No trap items will be included in the filler item pool\n25  -> Approximately 25% of the filler item pool will be trap items\n50  -> Approximately 50% of the filler item pool will be trap items\netc.", "randomizable": true, "visibility": 15, "type": "Range", "default": 25, "min": 0, "max": 100}, {"name": "feed_villagers_trap_weight", "display_name": "Feed Villagers Trap Weighting", "description": "The weighting of Feed Villagers Trap in the trap pool.\nThe higher this number relative to the other trap weightings, the more often it is likely to appear.\n\nFeed Villager Trap will force all villagers on the current board to be fed - villagers not fed will die.\n\nIf <Trap Fill> is 0 then this setting will be ignored.", "randomizable": true, "visibility": 15, "type": "Range", "default": 50, "min": 0, "max": 100}, {"name": "mob_trap_weight", "display_name": "Mob Trap Weighting", "description": "The weighting of Mob Traps in the trap pool.\nThe higher this number relative to the other trap weightings, the more often it is likely to appear.\n\nMob Traps will spawn a random, basic enemy to the current board - killing mobs from Mob Traps will not count towards Mobsanity checks.\n\nIf <Trap Fill> is 0 then this setting will be ignored.", "randomizable": true, "visibility": 15, "type": "Range", "default": 50, "min": 0, "max": 100}, {"name": "sell_cards_trap_weight", "display_name": "Sell Cards Trap Weighting", "description": "The weighting of Sell Cards Trap in the trap pool\nThe higher this number relative to the other trap weightings, the more often it is likely to appear.\n\nSell Cards Trap forces you to immediately sell <Sell Cards Trap Amount> of cards from the current board.\n\nIf <Trap Fill> is 0 then this setting will be ignored.", "randomizable": true, "visibility": 15, "type": "Range", "default": 50, "min": 0, "max": 100}, {"name": "sell_cards_trap_amount", "display_name": "Sell Cards Trap Amount", "description": "How many cards a Sell Cards Trap will force you to sell.\n\nYou will be forced to sell this amount of all sellable cards when you receive this trap. If you have fewer than\nthis amount, you will instead be forced to sell all remaining sellable cards.\n\nIf <Trap Fill> is 0 or <Sell Cards Trap Weight> is 0 then this setting will be ignored.", "randomizable": true, "visibility": 15, "type": "Range", "default": 3, "min": 1, "max": 10}, {"name": "strange_portal_trap_weight", "display_name": "Strange Portal Trap Weighting", "description": "The weighting of Strange Portal Trap items in the trap pool.\nThe higher this number relative to the other trap weightings, the more often it is likely to appear.\n\nStrange Portal Traps will spawn a Strange Portal to the current board.\nPortals from these traps cannot be used to travel to The Dark Forest and killing enemies spawned from these Portals will not count towards Mobsanity checks.\n\nIf <Trap Fill> is 0 then this setting will be ignored.", "randomizable": true, "visibility": 15, "type": "Range", "default": 50, "min": 0, "max": 100}], "collapsed": false}, {"name": "QoL", "options": [{"name": "red_structure_spawn", "display_name": "Strange Portal Spawn Location", "description": "The position on the board where red structures (Strange Portal / Rare Portal / Pirate Ship) will spawn.\n\nVanilla -> Red structures will spawn in random locations on the current board, as per vanilla behaviour.\nAll Other Values -> Red structures will attempt to spawn at a fixed point in the specified area of the current board.", "randomizable": true, "visibility": 15, "type": "Choice", "default": 0, "choices": [{"name": "vanilla", "display_name": "Vanilla", "value": 0}, {"name": "top_left", "display_name": "Top Left", "value": 1}, {"name": "top_right", "display_name": "Top Right", "value": 2}, {"name": "bottom_left", "display_name": "Bottom Left", "value": 3}, {"name": "bottom_right", "display_name": "Bottom Right", "value": 4}, {"name": "middle", "display_name": "Middle", "value": 5}]}], "collapsed": false}, {"name": "Item & Location Options", "options": [{"name": "local_items", "display_name": "Local Items", "description": "Forces these items to be in their native world.", "randomizable": false, "visibility": 15, "type": "OptionSet", "default": [], "options": ["Humble Beginnings Booster Pack", "Seeking Wisdom Booster Pack", "Reap & Sow Booster Pack", "Curious Cuisine Booster Pack", "Logic and Reason Booster Pack", "The Armory Booster Pack", "Explorers Booster Pack", "Order and Structure Booster Pack", "Idea: Brick", "Idea: Brickyard", "Idea: Campfire", "Idea: Club", "Idea: Coin Chest", "Idea: Cooked Meat", "Idea: Farm", "Idea: Frittata", "Idea: Growth", "Idea: House", "Idea: Iron Bar", "Idea: Iron Shield", "Idea: Lumber Camp", "Idea: Magic Wand", "Idea: Market", "Idea: Offspring", "Idea: Omelette", "Idea: Plank", "Idea: Quarry", "Idea: Shed", "Idea: Slingshot", "Idea: Smelter", "Idea: Smithy", "Idea: Spear", "Idea: Spiked Plank", "Idea: Stick", "Idea: Stove", "Idea: Sword", "Idea: Temple", "Idea: Throwing Stars", "Idea: University", "Idea: Warehouse", "Idea: Wooden Shield", "Idea: Axe", "Idea: Chicken", "Idea: Hammer", "Idea: Pickaxe", "Idea: Bone Spear", "Idea: Boomerang", "Idea: Chainmail Armor", "Idea: Magic Blade", "Idea: Magic Ring", "Idea: Magic Staff", "Idea: Magic Tome", "Idea: Fruit Salad", "Idea: Milkshake", "Idea: Stew", "Idea: Animal Pen", "Idea: Breeding Pen", "Idea: Butchery", "Idea: Crane", "Idea: Dustbin", "Idea: Garden", "Idea: Hotpot", "Idea: Iron Mine", "Idea: Resource Chest", "Idea: Sawmill", "Idea: Stable Portal", "On the Shore Booster Pack", "Island of Ideas Booster Pack", "Grilling and Brewing Booster Pack", "Island Insights Booster Pack", "Advanced Archipelago Booster Pack", "Enclave Explorers Booster Pack", "Idea: Bow", "Idea: Bottle of Rum", "Idea: Bottle of Water", "Idea: Broken Bottle", "Idea: Cathedral", "Idea: Ceviche", "Idea: Charcoal", "Idea: Coin", "Idea: Composter", "Idea: Dis
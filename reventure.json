{"name": "reventure", "game": "Reventure", "version": "0.0.0", "hidden": false, "groups": [{"name": "Game Options", "options": [{"name": "progression_balancing", "display_name": "Progression Balancing", "description": "A system that can move progression earlier, to try and prevent the player from getting stuck and bored early.\n\nA lower setting means more getting stuck. A higher setting means less getting stuck.", "randomizable": true, "visibility": 15, "type": "NamedRange", "default": 50, "min": 0, "max": 99, "presets": {"disabled": 0, "normal": 50, "extreme": 99}}, {"name": "accessibility", "display_name": "Accessibility", "description": "Set rules for reachability of your items/locations.\n\n**Full:** ensure everything can be reached and acquired.\n\n**Minimal:** ensure what is needed to reach your goal can be acquired.", "randomizable": true, "visibility": 15, "type": "Choice", "default": 0, "choices": [{"name": "full", "display_name": "Full", "value": 0}, {"name": "minimal", "display_name": "Minimal", "value": 2}]}, {"name": "endings", "display_name": "Endings", "description": "How many endings are required to be completed to win the game.", "randomizable": true, "visibility": 15, "type": "Range", "default": 40, "min": 0, "max": 99}, {"name": "randomizeGems", "display_name": "Gems", "description": "If the gem unlocks should be randomized", "randomizable": true, "visibility": 15, "type": "Toggle", "default": true}, {"name": "gemsInPool", "display_name": "Gems in Pool", "description": "How many Gems are in the pool", "randomizable": true, "visibility": 15, "type": "Range", "default": 4, "min": 0, "max": 40}, {"name": "gemsRequired", "display_name": "Gems Required", "description": "What percentage of available gems (rounded down) is required to open the door", "randomizable": true, "visibility": 15, "type": "Range", "default": 75, "min": 0, "max": 100}, {"name": "hardjumps", "display_name": "RequireFailableJumps", "description": "This includes jumps in logic that
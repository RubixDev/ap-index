{"name": "content_warning", "game": "Content Warning", "version": "0.1.0", "hidden": false, "groups": [{"name": "Game Options", "options": [{"name": "progression_balancing", "display_name": "Progression Balancing", "description": "A system that can move progression earlier, to try and prevent the player from getting stuck and bored early.\n\nA lower setting means more getting stuck. A higher setting means less getting stuck.", "randomizable": true, "visibility": 15, "type": "NamedRange", "default": 50, "min": 0, "max": 99, "presets": {"disabled": 0, "normal": 50, "extreme": 99}}, {"name": "accessibility", "display_name": "Accessibility", "description": "Set rules for reachability of your items/locations.\n\n**Full:** ensure everything can be reached and acquired.\n\n**Minimal:** ensure what is needed to reach your goal can be acquired.", "randomizable": true, "visibility": 15, "type": "Choice", "default": 0, "choices": [{"name": "full", "display_name": "Full", "value": 0}, {"name": "minimal", "display_name": "Minimal", "value": 2}]}, {"name": "viral_sensation", "display_name": "Viral Sensation Goal", "description": "Reach 1,000,000 views in a single quota.\nFired by the client when the threshold is crossed in-game.", "randomizable": true, "visibility": 15, "type": "Toggle", "default": true}, {"name": "views_goal", "display_name": "Views Goal", "description": "Reach the configurable lifetime view target (Views Goal Target).\nRequires Views Checks to be enabled \u2014 if Views Checks is off, this\ngoal is treated as off.", "randomizable": true, "visibility": 15, "type": "Toggle", "default": false}, {"name": "views_checks", "display_name": "Views Checks", "description": "When enabled, lifetime-view milestone locations are part of the pool.\nDisable to remove all view threshold locations from generation.\nIf off, views_goal is invalid.", "randomizable": true, "visibility": 15, "type": "Toggle", "default": true}, {"name": "views_goal_target", "display_name": "Views Goal Target", "description": "When Views Goal is enabled, the lifetime view total required to win.\nThe world uses the nearest lifetime-view milestone at or above this value.\nMaximum 33,739,000 \u2014 the highest reachable lifetime total at the maximum\nquota count (day 63).", "randomizable": true, "visibility": 15, "type": "Range", "default": 500000, "min": 0, "max": 33739000}, {"name": "quota_goal", "display_name": "Quota Goal", "description": "Reach and complete the configured number of quotas.\nRequires Quota Requirement to be enabled \u2014 if Quota Requirement is off,\nthis goal is treated as off.", "randomizable": true, "visibility": 15, "type": "Toggle", "default": false}, {"name": "quota_requirement", "display_name": "Quota Requirement", "description": "When enabled, quota checks are included in the location pool and\ncompleting quotas can be part of the goal.\nWhen disabled, all quota-related checks are removed from the pool.\nIf turned off, the Quota Goal will be invalid.", "randomizable": true, "visibility": 15, "type": "Toggle", "default": true}, {"name": "quota_count", "display_name": "Quota Count", "description": "The number of quotas to play through.  Drives the active count of\nQuota / Day Extraction / Sponsorship locations and (if Quota Goal is on)\nthe number required to win.\nEach quota is 3 days, so day-extraction checks run from day 1 to\nQuotaCount * 3.  Sponsorship checks run from 1 to QuotaCount - 1\n(capped at 20).", "randomizable": true, "visibility": 15, "type": "Range", "default": 5, "min": 1, "max": 21}, {"name": "monster_hunter", "display_name": "Monster Hunter Goal", "description": "Film a configurable number of distinct monsters (Monster Hunter Count)\nto win.", "randomizable": true, "visibility": 15, "type": "Toggle", "default": false}, {"name": "monster_hunter_count", "display_name": "Monster Hunter Count", "description": "When Monster Hunter is enabled, the number of distinct monsters that\nmust be filmed to win.  Minimum 5, maximum 33.\nNote: an average 5-quota run encounters 15-20 monsters.", "randomizable": true, "visibility": 15, "type": "Range", "default": 12, "min": 5, "max": 33}, {"name": "monster_tiers", "display_name": "Monster Tiers", "description": "When enabled, each non-difficult filmable monster gains two additional\nfilming location checks (2nd and 3rd sightings).  Adds up to 42 extra\nlocation checks across non-difficult monsters and artifacts.  No new\nlogic is added beyond the dungeon-depth rules of the base check.", "randomizable": true, "visibility": 15, "type": "Toggle", "default": false}, {"name": "filler_multi_sightings", "display_name": "Filler Multi-Sightings", "description": "When enabled, all 2nd / 3rd sighting locations created by Monster\nTiers hold filler items only \u2014 no progression items spawn there.\nDisable to let real items spawn behind multi-sighting checks at the\ncost of more required dives.  No effect when Monster Tiers is off.", "randomizable": true, "visibility": 15, "type": "Toggle", "default": true}, {"name": "difficult_monsters", "display_name": "Difficult Monsters Have Real Items", "description": "When enabled, difficult/rare monsters (Flicker, Cam Creep, Infiltrator,\nBlack Hole Bot, Ear, Snail Spawner, Big Slap, Ultra Knifo, Weeping)\ncan have real (non-filler) items behind their base filming checks.\nTier 2 / Tier 3 of difficult monsters always remain filler regardless\nof this option.", "randomizable": true, "visibility": 15, "type": "Toggle", "default": false}, {"name": "hat_collector", "display_name": "Hat Collector Goal", "description": "Purchase a configurable number of hats (Hat Collector Count) to win.", "randomizable": true, "visibility": 15, "type": "Toggle", "default": false}, {"name": "hat_collector_count", "display_name": "Hat Collector Count", "description": "When Hat Collector is enabled, the number of hats that must be\npurchased to win.  Minimum 5, maximum 31 (total hats available).", "randomizable": true, "visibility": 15, "type": "Range", "default": 15, "min": 5, "max": 31}, {"name": "include_sponsorships", "display_name": "Include Sponsorships", "description": "When enabled, sponsorship checks are included in the pool.\nEach completed sponsorship grants the next sponsorship check in\norder; the active count per seed is QuotaCount - 1, capped at 20.", "randomizable": true, "visibility": 15, "type": "Toggle", "default": true}, {"name": "sponsor_filler", "display_name": "Sponsor Filler", "description": "When enabled (default), all sponsor locations contain filler items.\nSponsorships are RNG-dependent and can be hard to complete; this keeps\nprogression away from them by default.  Disable to let progression items\nspawn at sponsor locations.", "randomizable": true, "visibility": 15, "type": "Toggle", "default": true}, {"name": "multiplayer_mode", "display_name": "Multiplayer Mode", "description": "Enable if this game is played in multiplayer (more than one player).\nWhen enabled, multiplayer-only monster locations (Weeping) are added to\nthe world and can receive real items.\nWhen disabled (default / solo play), those locations are completely\nomitted from generation \u2014 the player would never be able to film them\nwithout other players in the lobby.", "randomizable": true, "visibility": 15, "type": "Toggle", "default": false}, {"name": "death_link", "display_name": "Death Link", "description": "Enable Death Link. When enabled, if any player in the Death Link group\ndies in their respective game, all players in that group will die.\nContent Warning counts as dead when the entire team wipes. If the team is not in the old world\nwhen another player dies they will not be affected by Death Link until they return to the old world.", "randomizable": true, "visibility": 15, "type": "Toggle", "default": false}], "collapsed": false}, {"name": "Item & Location Options", "options": [{"name": "local_items", "display_name": "Local Items", "description": "Forces these items to be in their native worl
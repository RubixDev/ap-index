{"name": "portal2", "game": "Portal 2", "version": "0.7.1", "hidden": false, "groups": [{"name": "Game Options", "options": [{"name": "progression_balancing", "display_name": "Progression Balancing", "description": "A system that can move progression earlier, to try and prevent the player from getting stuck and bored early.\n\nA lower setting means more getting stuck. A higher setting means less getting stuck.", "randomizable": true, "visibility": 15, "type": "NamedRange", "default": 50, "min": 0, "max": 99, "presets": {"disabled": 0, "normal": 50, "extreme": 99}}, {"name": "accessibility", "display_name": "Accessibility", "description": "Set rules for reachability of your items/locations.\n\n**Full:** ensure everything can be reached and acquired.\n\n**Minimal:** ensure what is needed to reach your goal can be acquired.", "randomizable": true, "visibility": 15, "type": "Choice", "default": 0, "choices": [{"name": "full", "display_name": "Full", "value": 0}, {"name": "minimal", "display_name": "Minimal", "value": 2}]}, {"name": "death_link", "display_name": "Death Link", "description": "When you die, everyone who enabled death link dies. Of course, the reverse is true too.", "randomizable": true, "visibility": 15, "type": "Toggle", "default": false}], "collapsed": false}, {"name": "Location Options", "options": [{"name": "game_mode", "display_name": "Game Mode", "description": "What map generation and logic options are set:\nnormal -> Each chapter is randomised with it's own maps\nchaotic -> Any map can be in any chapter\nopen_world -> maps appear in the correct order in the game and are all playable from the start", "randomizable": true, "visibility": 15, "type": "Choice", "default": 0, "choices": [{"name": "normal", "display_name": "Normal", "value": 0}, {"name": "chaotic", "display_name": "Chaotic", "value": 1}, {"name": "open_world", "display_name": "Open World", "value": 2}]}, {"name": "cutscene_levels", "display_name": "Cutscene Levels", "description": "Determines whether cutscene maps are added to the map pool", "randomizable": true, "visibility": 15, "type": "Toggle", "default": false}, {"name": "remove_locations", "display_name": "Removed Locations", "description": "Which maps will be removed entirly from the map pool.\nDifferent from Excluded Locations as Removed Locations will not be playable\nduring the game. Excluded Locations are still in the map pool.", "randomizable": false, "visibility": 15, "type": "OptionSet", "default": [], "options": ["Container Ride Completion", "Portal Carousel Completion", "Portal Gun Completion", "Smooth Jazz Completion", "Cube Momentum Completion", "Future Starter Completion", "Secret Panel Completion", "Wake Up Completion", "Incinerator Completion", "Laser Intro Completion", "Laser Stairs Completion", "Dual Lasers Completion", "Laser Over Goo Completion", "Catapult Intro Completion", "Trust Fling Completion", "Pit Flings Completion", "Fizzler Intro Completion", "Ceiling Catapult Completion", "Ricochet Completion", "Bridge Intro Completion", "Bridge the Gap Completion", "Turret Intro Completion", "Laser Relays Completion", "Turret Blocker Completion", "Laser Vs. Turret Completion", "Pull The Rug Completion", "Column Blocker Completion", "Laser Chaining Completion", "Triple Laser Completion", "Jailbreak Completion", "Escape Completion", "Turret Factory Completion", "Turret Sabotage Completion", "Neurotoxin Sabotage Completion", "Core Completion", "Underground Completion", "Cave Johnson Completion", "Repulsion Intro Completion", "Bomb Flings Completion", "Crazy Box Completion", "PotatOS Completion", "Propulsion Intro Completion", "Propulsion Flings Completion", "Conversion Intro Completion", "Three Gels Completion", "Test Completion", "Funnel Intro Completion", "Ceiling Button Completion", "Wall Button Completion", "Polarity Completion", "Funnel Catch Completion", "Stop The Box Completion", "Laser Catapult Completion", "Laser Platform Completion", "Propulsion Catch Completion", "Repulsi
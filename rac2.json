{"name": "rac2", "game": "Ratchet & Clank 2", "version": "0.0.0", "hidden": false, "groups": [{"name": "Game Options", "options": [{"name": "progression_balancing", "display_name": "Progression Balancing", "description": "A system that can move progression earlier, to try and prevent the player from getting stuck and bored early.\n\nA lower setting means more getting stuck. A higher setting means less getting stuck.", "randomizable": true, "visibility": 15, "type": "NamedRange", "default": 50, "min": 0, "max": 99, "presets": {"disabled": 0, "normal": 50, "extreme": 99}}, {"name": "accessibility", "display_name": "Accessibility", "description": "Set rules for reachability of your items/locations.\n\n**Full:** ensure everything can be reached and acquired.\n\n**Minimal:** ensure what is needed to reach your goal can be acquired.", "randomizable": true, "visibility": 15, "type": "Choice", "default": 0, "choices": [{"name": "full", "display_name": "Full", "value": 0}, {"name": "minimal", "display_name": "Minimal", "value": 2}]}, {"name": "death_link", "display_name": "Death Link", "description": "When you die, everyone who enabled death link dies. Of course, the reverse is true too.", "randomizable": true, "visibility": 15, "type": "Toggle", "default": false}, {"name": "starting_weapons", "display_name": "Starting Weapons", "description": "Randomize what two weapons you start the game with.\nVanilla: Start with the Lancer and Gravity Bomb.\nBalanced: Start with two random weapons that are relatively balanced.\nNon-Broken: Start with two random weapons besides RYNO II and Zodiac.\nUnrestricted: Start with any two non-upgraded weapons.", "randomizable": true, "visibility": 15, "type": "Choice", "default": 0, "choices": [{"name": "vanilla", "display_name": "Vanilla", "value": 0}, {"name": "balanced", "display_name": "Balanced", "value": 1}, {"name": "non_broken", "display_name": "Non Broken", "value": 2}, {"name": "unrestricted", "display_name": "Unrestricted", "value": 3}]}, {"name": "randomize_megacorp_vendor", "display_name": "Randomize Megacorp Vendor", "description": "Randomize what items appear at the Megacorp vendor. New items will get added as you visit more planets.\nWhen enabled, you can switch between buying items and buying ammo by pressing up/down when in the vendor.", "randomizable": true, "visibility": 15, "type": "Toggle", "default": false}, {"name": "randomize_gadgetron_vendor", "display_name": "Randomize Gadgetron Vendor", "description": "Randomize what items appear at the Gadgetron vendor on Barlow.", "randomizable": true, "visibility": 15, "type": "Toggle", "default": false}, {"name": "exclude_very_expensive_items", "display_name": "Exclude Very Expensive Items", "description": "Exclude RYNO II and Zodiac from the randomization leaving them at their vanilla locations.\nThis will only take effect if the corresponding vendors are randomized", "randomizable": true, "visibility": 15, "type": "Toggle", "default": true}, {"name": "skip_wupash_nebula", "display_name": "Skip Wupash Nebula", "description": "Skips the Wupash Nebula ship section that appears when first traveling to Maktar Nebula.", "randomizable": true, "visibility": 15, "type": "Toggle", "default": true}, {"name": "enable_bolt_multiplier", "display_name": "Enable Bolt Multiplier", "description": "Enables the bolt multiplier feature without being in New Game+.", "randomizable": true, "visibility": 15, "type": "Toggle", "default": false}, {"name": "no_revisit_reward_change", "display_name": "Remove Revisit Rewards Change", "description": "In the vanilla game, rewards given when killing enemies change when you come back to a previously visited planet\n(bolts & experience). Enabling this option removes this behavior, making the experience and bolts obtained more\nstable throughout the seed.", "randomizable": true, "visibility": 15, "type": "Toggle", "default": false}, {"name": "no_kill_reward_degradation", "display_name": "Remove Kill Rewards Degradation", "description": "In the vanilla game, rewards given by a specific enemy decrease each time you kill it (bolts & experience).\nEnabling this option removes this behavior, making the experience and bolts obtained more stable throughout\nthe seed.", "randomizable": true, "visibility": 15, "type": "Toggle", "default": false}, {"name": "free_challenge_selection", "display_name": "Free Challenge Selection", "description": "Makes all hoverbike and spaceship challenges selectable right away, which means you don't have to win a\nchallenge to access the next one.", "randomizable": true, "visibility": 15, "type": "Toggle", "default": false}, {"name": "nanotech_xp_multiplier", "display_name": "Nanotech XP Multiplier", "description": "A multiplier applied to experience gained for Nanotech levels, in percent.", "randomizable": true, "visibility": 15, "type": "Range", "default": 100, "min": 20, "max": 600}, {"name": "weapon_xp_multiplier", "display_name": "Weapon XP Multiplier", "description": "A multiplier applied to experience gained for weapon levels, in percent.", "randomizable": true, "visibility": 15, "type": "Range", "default": 100, "min": 30, "max": 600}, {"name": "extra_spaceship_challenge_locations", "display_name": "Extra Spaceship Challenge Locations", "description": "In the vanilla game, only the first challenge and the race challenge completed perfectly give an item as a\nreward. If enabled, this option makes all spaceship challenges reward an item on first completion.", "randomizable": true, "visibility": 15, "type": "Toggle", "default": false}, {"name": "extend_weapon_progression", "display_name": "Extended Weapon Progression", "description": "If enabled, make all weapon tiers obtainable through weapon experience. This means LV2 (orange) weapons can\nupgrade into LV3 (yellow) weapons, which can then upgrade into LV4 (blue) weapons.\nThis effectively makes all weapons that are usually restricted to NG+ available with enough grinding.", "randomizable": true, "visibility": 15, "type": "Toggle", "default": false}, {"name": "first_person_mode_glitch_in_logic", "display_name": "First Person Mode Glitch In Logic", "description": "Determines if logic should take first person mode glitches into account when evaluating which locations are\nreachable. Various difficulty levels can be picked:\n- Easy: simple climbs (e.g. getting the Platinum Bolt near Oozla scientist)\n- Medium: harder climbs and basic lateral movement (e.g. Getting to the Notak Worker Bots without the Heli-pack nor the Thermanator)\n- Hard: full navigation following walls (e.g. Getting to the Mutated Protopet only with the Infiltrator)", "randomizable": true, "visibility": 15, "type": "Choice", "default": 0, "choices": [{"name": "disabled", "display_name": "Disabled", "value": 0}, {"name": "easy", "display_name": "Easy", "value": 1}, {"name": "medium", "display_name": "Medium", "value": 2}, {"name": "hard", "display_name": "Hard", "value": 3}]}], "collapsed": false}, {"name": "Item & Location Options", "options": [{"name": "local_items", "display_name": "Local Items", "description": "Forces these items to be in their native world.", "randomizable": false, "visibility": 15, "type": "OptionSet", "default": [], "options": ["Heli-Pack", "Thruster-Pack", "Mapper", "Armor Magnetizer", "Levitator", "Swingshot", "Gravity Boots", "Grindboots", "Glider", "Dynamo", "Electrolyzer", "Thermanator", "Tractor Beam", "Qwark Statuette", "Box Breaker", "Infiltrator", "Charge Boots", "Hypnomatic", "Clank Zapper", "Bomb Glove", "Visibomb Gun", "Sheepinator", "Decoy Glove", "Tesla Claw", "Chopper", "Pulse Rifle", "Seeker Gun", "Hoverbomb Gun", "Blitz Gun", "Minirocket Tube", "Plasma Coil", "Lava Gun", "Lancer", "Synthenoid", "Spiderbot Glove", "Bouncer", "Miniturret Glove", "Gravity Bomb", "Zodiac", "RYNO II", "Shield Charger", "Walloper", "Heavy Lancer", "Kilonoid", "Plasma Storm", "Meteor Gun", "Megaturret Glove", "Multi-Star", "Vaporizer", "HK-22", "Blitz Cannon", "Megarocket Cannon", "Tetrabo
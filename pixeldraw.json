{"name": "pixeldraw", "game": "PixelDraw", "version": "1.3.0", "hidden": false, "groups": [{"name": "Game Options", "options": [{"name": "progression_balancing", "display_name": "Progression Balancing", "description": "A system that can move progression earlier, to try and prevent the player from getting stuck and bored early.\n\nA lower setting means more getting stuck. A higher setting means less getting stuck.", "randomizable": true, "visibility": 15, "type": "NamedRange", "default": 50, "min": 0, "max": 99, "presets": {"disabled": 0, "normal": 50, "extreme": 99}}, {"name": "accessibility", "display_name": "Accessibility", "description": "Set rules for reachability of your items/locations.\n\n**Full:** ensure everything can be reached and acquired.\n\n**Minimal:** ensure what is needed to reach your goal can be acquired.", "randomizable": true, "visibility": 15, "type": "Choice", "default": 0, "choices": [{"name": "full", "display_name": "Full", "value": 0}, {"name": "minimal", "display_name": "Minimal", "value": 2}]}], "collapsed": false}, {"name": "Gameplay Options", "options": [{"name": "trap_chance", "display_name": "Trap Chance", "description": "Percentage chance that any given filler item will be replaced by a trap.", "randomizable": true, "visibility": 15, "type": "Range", "default": 0, "min": 0, "max": 100}, {"name": "death_link", "display_name": "Death Link", "description": "Whether or not deathlink will be used.", "randomizable": true, "visibility": 15, "type": "Toggle", "default": false}, {"name": "randomize_enemy_deaths", "display_name": "Randomize Enemy Death", "description": "Adds locations for killing enemies.", "randomizable": true, "visibility": 15, "type": "Toggle", "default": false}, {"name": "randomize_compatibility_chips", "display_name": "Randomize Compatibility Chips", "description": "Randomizes compatibility chips.\nEach action that gets you them has as many checks as it would have chips normally.\nEach chip is an item.", "randomizable": t